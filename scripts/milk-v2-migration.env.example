# 腾讯云 API 密钥（云开发控制台 → 设置 → 环境 → 登录方式 / 或腾讯云 CAM）
TCB_SECRET_ID=your_secret_id
TCB_SECRET_KEY=your_secret_key

# 可选：覆盖 project.config.json 中的 defaultEnv
# TCB_ENV=prod-7g5lap9xcf106dbf
