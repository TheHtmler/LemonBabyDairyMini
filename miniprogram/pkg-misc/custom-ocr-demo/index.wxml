<view class="demo-page">
  <view class="hero-card">
    <text class="hero-title">自建 OCR 实验</text>
    <text class="hero-subtitle">选图后上传到云存储，由云函数 recognizeReportCustom 转发到你的 OCR 服务。小程序端无需配置 upload 合法域名。</text>
  </view>

  <view class="section-card">
    <view class="section-title">说明</view>
    <text class="field-tip">请在云函数环境变量配置 CUSTOM_OCR_API_KEY，可选 CUSTOM_OCR_URL（默认 http://60.205.243.92/ocr/file）。</text>
  </view>

  <view class="section-card">
    <view class="section-title">识别实验</view>
    <view class="type-chip-group">
      <view
        wx:for="{{reportTypeOptions}}"
        wx:key="value"
        class="type-chip {{selectedReportType === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onReportTypeTap"
      >
        {{item.label}}
      </view>
    </view>

    <button class="primary-btn" loading="{{recognizing}}" disabled="{{recognizing}}" bindtap="onChooseAndRecognize">
      {{recognizing ? '识别中…' : '选择报告照片并识别'}}
    </button>
    <text class="field-tip">会先压缩到约 800KB 内；小于 480KB 时直传云函数，跳过云存储上传。</text>
  </view>

  <view class="section-card" wx:if="{{debugInfo}}">
    <view class="section-title">调试信息</view>
    <text class="field-tip">{{debugInfo}}</text>
  </view>

  <view class="section-card" wx:if="{{previewPath}}">
    <view class="section-title">预览图片</view>
    <image class="preview-image" src="{{previewPath}}" mode="widthFix" bindtap="onPreviewImage" />
  </view>

  <view class="section-card" wx:if="{{ocrLines.length}}">
    <view class="section-header">
      <text class="section-title">OCR 原始行</text>
      <text class="section-meta">共 {{ocrLines.length}} 行</text>
    </view>
    <view class="anchor-item" wx:for="{{ocrLines}}" wx:key="index">
      <text class="anchor-index">#{{index + 1}} · {{item.confidence || '-'}}</text>
      <text class="anchor-text">{{item.text}}</text>
    </view>
  </view>

  <view class="section-card" wx:if="{{parsedIndicatorKeys.length}}">
    <view class="section-header">
      <text class="section-title">reportOcrParser 试解析</text>
      <text class="section-meta">{{parsedIndicatorKeys.length}} 项</text>
    </view>
    <view class="parsed-item" wx:for="{{parsedIndicatorKeys}}" wx:key="*this">
      <text class="parsed-key">{{item}}</text>
      <text class="parsed-value">{{parsedIndicators[item].value}}</text>
      <text class="parsed-range" wx:if="{{parsedIndicators[item].minRange || parsedIndicators[item].maxRange}}">
        {{parsedIndicators[item].minRange || '-'}} ~ {{parsedIndicators[item].maxRange || '-'}}
      </text>
    </view>
  </view>

  <view class="section-card" wx:if="{{rawJson}}">
    <view class="section-header">
      <text class="section-title">云函数原始返回</text>
      <text class="copy-link" bindtap="onCopyRawJson">复制</text>
    </view>
    <text class="raw-json">{{rawJson}}</text>
  </view>

  <view class="section-card" wx:if="{{lastError}}">
    <view class="section-title error-title">最近错误</view>
    <text class="error-text">{{lastError}}</text>
  </view>
</view>
