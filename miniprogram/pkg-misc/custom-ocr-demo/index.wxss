.demo-page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 122, 0.4), transparent 28%),
    linear-gradient(180deg, #FFF7DC 0%, #FFF2C8 100%);
  box-sizing: border-box;
}

.hero-card,
.section-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.08);
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.hero-card {
  background: linear-gradient(135deg, #FFCB38 0%, #FFB800 100%);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #5F3900;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(95, 57, 0, 0.78);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.section-meta,
.copy-link,
.field-tip {
  font-size: 22rpx;
  color: #8A7C60;
}

.copy-link {
  color: #C68400;
}

.type-chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #7A5A00;
  background: rgba(255, 184, 0, 0.12);
  border: 2rpx solid rgba(255, 184, 0, 0.18);
}

.type-chip.active {
  color: #5F3900;
  background: #FFD666;
  border-color: #FFB800;
  font-weight: 700;
}

.primary-btn {
  margin: 0;
  background: linear-gradient(135deg, #FFCB38 0%, #FFB800 100%);
  color: #5F3900;
  font-weight: 700;
  border: none;
  border-radius: 999rpx;
}

.primary-btn[disabled] {
  background: #E0E0E0;
  color: #999999;
}

.field-tip {
  display: block;
  margin-top: 16rpx;
  line-height: 1.5;
}

.preview-image {
  width: 100%;
  border-radius: 16rpx;
  background: #FFF9E8;
}

.anchor-item,
.parsed-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 184, 0, 0.12);
}

.anchor-item:last-child,
.parsed-item:last-child {
  border-bottom: none;
}

.anchor-index,
.parsed-key {
  display: block;
  font-size: 22rpx;
  color: #8A7C60;
}

.anchor-text,
.parsed-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #333333;
  word-break: break-all;
}

.parsed-range {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #7A5A00;
}

.raw-json {
  display: block;
  font-size: 22rpx;
  line-height: 1.6;
  color: #444444;
  word-break: break-all;
  white-space: pre-wrap;
}

.error-title {
  color: #D93026;
}

.error-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #D93026;
  word-break: break-all;
}
