<view class="notice-settings-page">
  <view wx:if="{{hasAccess}}" class="page-shell">
    <view class="hero-card">
      <text class="hero-title">首页公告配置</text>
      <text class="hero-subtitle">控制首页顶部跑马灯公告的显示与文案。保存后所有用户进入首页即可看到最新内容。</text>
      <view class="meta-row">
        <text>最近保存</text>
        <text class="meta-value">{{updatedAtText}}</text>
      </view>
      <view class="meta-row" wx:if="{{updatedByText}}">
        <text>最近操作</text>
        <text class="meta-value">{{updatedByText}}</text>
      </view>
    </view>

    <view class="config-card">
      <view class="switch-row">
        <view class="switch-copy">
          <text class="section-title">显示公告</text>
          <text class="field-hint">关闭后首页不再展示跑马灯公告。</text>
        </view>
        <switch checked="{{visible}}" color="#ffb800" bindchange="onVisibleChange" />
      </view>
    </view>

    <view class="config-card">
      <text class="section-title">公告内容</text>
      <textarea
        class="message-textarea"
        value="{{text}}"
        placeholder="请输入首页公告文案"
        maxlength="120"
        bindinput="onTextInput"
      />
      <text class="field-hint">建议控制在 60 字以内，过长会在跑马灯中滚动展示。</text>
    </view>

    <view class="save-section">
      <button class="save-button" bindtap="onSaveConfig" loading="{{saving}}" disabled="{{saving || loading}}">
        {{saving ? '保存中...' : '保存配置'}}
      </button>
    </view>
  </view>

  <view wx:else class="empty-card">
    <text class="empty-title">无权限访问</text>
    <text class="empty-subtitle">该配置仅开发者可见。</text>
  </view>
</view>
