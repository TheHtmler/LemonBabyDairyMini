/* ===== 页面 ===== */
.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 122, 0.4), transparent 28%),
    linear-gradient(180deg, #FFF7DC 0%, #FFF2C8 100%);
  box-sizing: border-box;
}

/* ===== 顶部卡片 ===== */
.hero-card {
  background: linear-gradient(135deg, #FFCB38 0%, #FFB800 100%);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.18);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #5F3900;
}

.hero-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(95, 57, 0, 0.72);
  line-height: 1.5;
}

/* ===== 药物列表 ===== */
.med-list {
  padding-bottom: 140rpx;
}

.empty-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 60rpx 24rpx;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.08);
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.empty-text {
  font-size: 28rpx;
  color: #8A7C60;
}

.med-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.08);
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.med-main {
  flex: 1;
  min-width: 0;
}

.med-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.med-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.med-tag {
  font-size: 22rpx;
  color: #8A7C60;
  background: #FFF7E3;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.med-notes {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.med-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

.action-btn.edit {
  background: rgba(255, 184, 0, 0.12);
  color: #E6A600;
  border: 2rpx solid rgba(255, 184, 0, 0.25);
}

.action-btn.edit:active {
  background: rgba(255, 184, 0, 0.22);
}

.action-btn.delete {
  background: rgba(255, 77, 79, 0.08);
  color: #ff4d4f;
  border: 2rpx solid rgba(255, 77, 79, 0.18);
}

.action-btn.delete:active {
  background: rgba(255, 77, 79, 0.16);
}

/* ===== FAB ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFC933 0%, #FFB800 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(255, 184, 0, 0.35);
  z-index: 100;
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

/* ===== 遮罩 ===== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 9999;
  pointer-events: none;
  transition: background 0.3s ease;
}

.mask.show {
  background: rgba(0, 0, 0, 0.45);
  pointer-events: auto;
}

/* ===== 底部面板 ===== */
.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFDF5;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  z-index: 10000;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.sheet-header {
  padding: 24rpx 32rpx 16rpx;
  text-align: center;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

/* ===== 表单区 ===== */
.sheet-scroll {
  flex: 1;
  overflow: hidden;
}

.sheet-body {
  padding: 8rpx 32rpx 16rpx;
}

.field-group {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #8A7C60;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.field-input-wrap {
  height: 88rpx;
  padding: 0 24rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}

.field-input-wrap:focus-within {
  border-color: #FFB800;
  background: #FFF2CC;
}

.field-input {
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  color: #333;
  background: transparent;
  border: none;
  padding: 0;
}

.input-placeholder {
  color: #C4B896;
}

/* 剂量行 */
.dosage-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}


.unit-picker {
  flex-shrink: 0;
}

.unit-tag {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #8A7C60;
  background: rgba(255, 184, 0, 0.1);
  border-radius: 16rpx;
  white-space: nowrap;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.unit-arrow {
  font-size: 32rpx;
  color: #C4B896;
  font-weight: 300;
}

/* 频率 */
.freq-box {
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  border-radius: 16rpx;
  padding: 20rpx;
}

.freq-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.freq-text {
  font-size: 28rpx;
  color: #5F3900;
  padding: 0 8rpx;
  line-height: 72rpx;
}

.freq-num {
  width: 100rpx;
  height: 72rpx;
  background: #fff;
  border: 2rpx solid rgba(255, 184, 0, 0.25);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  text-align: center;
  margin: 0 4rpx;
  box-sizing: border-box;
}

.freq-num:focus {
  border-color: #FFB800;
}

.freq-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.freq-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #8A7C60;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
}

.freq-chip:active {
  background: #FFB800;
  color: #fff;
  border-color: #FFB800;
}

/* 备注 */
.field-textarea-wrap {
  padding: 20rpx 24rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  border-radius: 16rpx;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}

.field-textarea-wrap:focus-within {
  border-color: #FFB800;
  background: #FFF2CC;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  background: transparent;
  border: none;
  padding: 0;
}

/* ===== 底部按钮 ===== */
.sheet-footer {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 32rpx 24rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: opacity 0.2s;
}

.btn-cancel {
  background: #F5F0E5;
  color: #8A7C60;
}

.btn-cancel::after {
  border: none;
}

.btn-cancel:active {
  opacity: 0.7;
}

.btn-confirm {
  background: linear-gradient(135deg, #FFC933 0%, #FFB800 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(255, 184, 0, 0.25);
}

.btn-confirm::after {
  border: none;
}

.btn-confirm:active {
  opacity: 0.85;
}
