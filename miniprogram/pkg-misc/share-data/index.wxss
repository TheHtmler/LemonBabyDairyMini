.invite-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 8%, rgba(255, 219, 88, 0.38), transparent 34%),
    linear-gradient(180deg, #fff8df 0%, #fff0bf 100%);
}

.invite-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-panel,
.state-card,
.code-panel,
.step-panel {
  border-radius: 34rpx;
  box-shadow: 0 14rpx 34rpx rgba(132, 86, 0, 0.12);
}

.hero-panel {
  padding: 36rpx 34rpx 38rpx;
  background: linear-gradient(145deg, #fffdf5 0%, #ffeaa0 100%);
  color: #3e2a08;
  border: 1rpx solid rgba(255, 184, 0, 0.18);
  position: relative;
  overflow: hidden;
}

.hero-panel::after {
  content: '';
  position: absolute;
  right: -48rpx;
  bottom: -70rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  background: rgba(255, 184, 0, 0.16);
}

.hero-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.eyebrow,
.hero-badge {
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.eyebrow {
  color: #7a5600;
  background: #fff3c4;
}

.hero-badge {
  color: #7a5600;
  background: rgba(255, 255, 255, 0.56);
}

.hero-title {
  display: block;
  font-size: 44rpx;
  line-height: 1.22;
  font-weight: 900;
  margin-bottom: 18rpx;
  position: relative;
  z-index: 1;
}

.hero-desc {
  display: block;
  color: #7c6534;
  font-size: 27rpx;
  line-height: 1.62;
  position: relative;
  z-index: 1;
}

.state-card {
  height: 320rpx;
  background: #fffdf5;
  border: 1rpx solid rgba(255, 184, 0, 0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #8a7443;
  font-size: 28rpx;
}

.loading-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 6rpx solid #ffe49b;
  border-top-color: #ffb800;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.invite-board {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.code-panel {
  padding: 30rpx;
  background: #fffdf5;
  border: 1rpx solid rgba(255, 184, 0, 0.2);
  overflow: hidden;
}

.code-panel.is-active {
  background:
    linear-gradient(145deg, rgba(255, 253, 245, 0.96), rgba(255, 241, 179, 0.96)),
    #fffdf5;
}

.code-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.code-label,
.code-subtitle {
  display: block;
}

.code-label {
  color: #3e2a08;
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.code-subtitle {
  color: #8a7443;
  font-size: 24rpx;
}

.status-pill {
  color: #2f6f37;
  background: #e6f7df;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 23rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.status-pill.muted {
  color: #987633;
  background: #fff0c3;
}

.code-frame {
  min-height: 220rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #fff8dc 0%, #ffe681 100%);
  border: 2rpx dashed rgba(255, 184, 0, 0.46);
  padding: 34rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.invite-code {
  display: block;
  color: #5b3b00;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 13rpx;
  margin-bottom: 22rpx;
  text-indent: 13rpx;
}

.expiry {
  color: #8a6420;
  font-size: 25rpx;
}

.empty-title {
  display: block;
  color: #4a3510;
  font-size: 34rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.empty-desc {
  color: #7c6534;
  font-size: 26rpx;
  line-height: 1.55;
}

.invite-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.primary-btn,
.secondary-btn,
.text-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  padding: 0;
}

.primary-btn::after,
.secondary-btn::after,
.text-btn::after {
  border: none;
}

.primary-btn {
  color: #4a3000;
  background: #ffbf1f;
  box-shadow: 0 10rpx 22rpx rgba(255, 184, 0, 0.24);
}

.secondary-btn {
  color: #6e4c00;
  background: #fff2c8;
}

.text-btn {
  color: #8a5f00;
  background: rgba(255, 253, 245, 0.72);
}

.wide {
  grid-column: 1 / -1;
}

.step-panel {
  background: #fffdf5;
  border: 1rpx solid rgba(255, 184, 0, 0.16);
  padding: 26rpx 28rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(138, 116, 67, 0.12);
}

.step-item:last-child {
  border-bottom: none;
}

.step-index {
  color: #b28100;
  background: #fff0b8;
  width: 58rpx;
  height: 42rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.step-text {
  color: #6d5625;
  font-size: 27rpx;
  line-height: 1.45;
}
