<view class="invite-page">
  <view class="invite-shell">
    <view class="hero-panel">
      <view class="hero-row">
        <text class="eyebrow">成员协作</text>
        <text class="hero-badge">30 天有效</text>
      </view>
      <text class="hero-title">把{{babyName}}的记录交给家人一起守护</text>
      <text class="hero-desc">邀请码只用于加入当前宝宝记录，对方确认后即可查看和记录同一份数据。</text>
    </view>

    <view wx:if="{{loading}}" class="state-card">
      <view class="loading-dot"></view>
      <text>正在准备邀请码...</text>
    </view>

    <view wx:else class="invite-board">
      <view class="code-panel {{hasInviteCode ? 'is-active' : 'is-empty'}}">
        <view class="code-header">
          <view>
            <text class="code-label">邀请码</text>
            <text class="code-subtitle">{{hasInviteCode ? '发给家人即可加入' : '生成后即可邀请家人'}}</text>
          </view>
          <text class="status-pill {{hasInviteCode ? '' : 'muted'}}">{{hasInviteCode ? '有效中' : '待生成'}}</text>
        </view>

        <view class="code-frame">
          <block wx:if="{{hasInviteCode}}">
            <text class="invite-code">{{inviteCode}}</text>
            <text class="expiry">有效期至 {{inviteCodeExpiry}}</text>
          </block>
          <block wx:else>
            <text class="empty-title">还没有可用邀请码</text>
            <text class="empty-desc">生成一个 8 位邀请码，家人可通过链接或手动输入加入。</text>
          </block>
        </view>
      </view>

      <view class="invite-action-grid">
        <button wx:if="{{!hasInviteCode}}" class="primary-btn wide" loading="{{generating}}" bindtap="generateInviteCode">生成邀请码</button>
        <block wx:else>
          <button class="primary-btn" bindtap="onCopyInviteCode">复制邀请码</button>
          <button class="secondary-btn" bindtap="onRefreshInviteCode">刷新邀请码</button>
        </block>
      </view>

      <view class="step-panel">
        <view class="step-item">
          <text class="step-index">01</text>
          <text class="step-text">复制邀请码发给家人</text>
        </view>
        <view class="step-item">
          <text class="step-index">02</text>
          <text class="step-text">家人确认后加入记录</text>
        </view>
        <view class="step-item">
          <text class="step-index">03</text>
          <text class="step-text">在成员管理里备注或解除</text>
        </view>
      </view>
    </view>
  </view>
</view>