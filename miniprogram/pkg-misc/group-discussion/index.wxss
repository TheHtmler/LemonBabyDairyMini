.group-discussion-page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 122, 0.4), transparent 28%),
    linear-gradient(180deg, #fff7dc 0%, #fff2c8 100%);
  box-sizing: border-box;
}

.hero-card,
.section-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.08);
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.hero-card {
  background: linear-gradient(135deg, #ffcb38 0%, #ffb800 100%);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #5f3900;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(95, 57, 0, 0.78);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.section-meta {
  font-size: 22rpx;
  color: #8a7c60;
}

.qr-card {
  text-align: center;
}

.qr-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-image {
  width: 420rpx;
  border-radius: 16rpx;
}

.qr-tip,
.state-text {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a7c60;
}

.empty-card {
  text-align: center;
}

.state-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #5f3900;
}

.empty-card .state-text {
  margin-top: 10rpx;
}
