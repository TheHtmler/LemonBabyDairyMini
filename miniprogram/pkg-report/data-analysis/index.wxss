/* pages/data-analysis/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF3C4 0%, #FFF9EA 360rpx, #F8FAF5 100%);
  padding-bottom: 48rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #FFE4B5;
  border-top-color: #FFB800;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-spinner.compact {
  width: 44rpx;
  height: 44rpx;
  border-width: 5rpx;
  flex-shrink: 0;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* 主要内容 */
.content {
  width: 100%;
  padding: 24rpx 0 0;
  box-sizing: border-box;
}

.analysis-control-panel {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 184, 0, 0.18);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(143, 103, 0, 0.08);
}

.analysis-control-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.analysis-title-block {
  flex: 1;
  min-width: 0;
}

.analysis-eyebrow {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #9B6D00;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.analysis-period-label {
  display: block;
  font-size: 26rpx;
  line-height: 1.25;
  color: #3A2B00;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 时间维度选择 */
.dimension-selector {
  background: #FFFFFF;
  padding: 30rpx 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.range-status-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 54rpx;
  padding: 0 20rpx;
  flex-shrink: 0;
  background: #FFF1BE;
  border-radius: 999rpx;
  border: 1rpx solid #F2DA91;
}

.range-status-pill text {
  font-size: 23rpx;
  color: #8B6500;
  font-weight: 800;
}

.range-preset-list {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 26rpx;
}

.range-preset-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 10rpx;
  background: #FFF5D6;
  border: 1rpx solid #F2DA91;
  border-radius: 18rpx;
  transition: all 0.2s;
}

.range-preset-item text {
  font-size: 23rpx;
  color: #8E6A0A;
  font-weight: 700;
  white-space: nowrap;
}

.range-preset-item.active {
  background: linear-gradient(135deg, #FFD559 0%, #FFB800 100%);
  border-color: #FFB800;
  box-shadow: 0 8rpx 18rpx rgba(255, 184, 0, 0.22);
}

.range-preset-item.active text {
  color: #4D3700;
  font-weight: 800;
}

.range-preset-item:active {
  transform: scale(0.97);
}

.period-controls {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 26rpx;
}

/* 日期导航 */
.date-navigation {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  padding: 40rpx 30rpx;
  background: #FFFFFF;
  margin-top: 2rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #FFF5D6;
  border-radius: 50%;
  transition: all 0.2s;
}

.period-nav-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  height: 64rpx;
  padding: 0 22rpx;
  flex-shrink: 0;
  background: #FFF5D6;
  border: 1rpx solid #F2DA91;
  border-radius: 999rpx;
  transition: all 0.2s;
}

.period-nav-button text {
  font-size: 24rpx;
  color: #8B6500;
  font-weight: 700;
}

.period-nav-hover {
  background: #FFE7A1;
  transform: translateY(1rpx);
}

.nav-btn-hover {
  background: #FFE4B5;
  transform: scale(0.95);
}

.nav-icon {
  font-size: 24rpx;
  color: #FFB800;
}

.date-range {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
  margin-top: 18rpx;
  padding: 18rpx 28rpx;
  background: #FFFDF6;
  border: 1rpx solid #F4E2A6;
  border-radius: 18rpx;
  transition: all 0.2s;
}

/* 仅月视图可点击 */
.date-range.clickable:active {
  background: #F0F0F0;
  transform: scale(0.98);
}

.date-text {
  font-size: 25rpx;
  color: #705000;
  font-weight: 600;
  text-align: center;
  flex: 1;
  white-space: nowrap;
}

.date-picker-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 12rpx;
  border-radius: 50%;
  background: #FFEDB0;
  color: #A67300;
  font-size: 21rpx;
  font-weight: 700;
  flex-shrink: 0;
}

/* 日期选择器 */
.date-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(76, 54, 0, 0.34);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s;
  padding: 32rpx;
  box-sizing: border-box;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.date-picker-modal {
  width: 660rpx;
  max-width: 100%;
  background: linear-gradient(180deg, #FFF8DC 0%, #FFFFFF 48%, #FFFDF6 100%);
  border: 1rpx solid rgba(255, 184, 0, 0.28);
  border-radius: 34rpx;
  overflow: hidden;
  animation: slideUp 0.3s;
  box-shadow: 0 28rpx 70rpx rgba(90, 64, 0, 0.22);
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  background: linear-gradient(135deg, #FFB800 0%, #FFA500 100%);
}

.picker-hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 150rpx;
  padding: 32rpx 88rpx 28rpx 32rpx;
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.9) 0, rgba(255, 255, 255, 0) 28%),
    linear-gradient(135deg, #FFE17B 0%, #FFB800 58%, #F4A300 100%);
}

.picker-hero::after {
  content: "";
  position: absolute;
  right: -34rpx;
  bottom: -46rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
}

.picker-hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.picker-kicker {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: rgba(84, 58, 0, 0.72);
  font-weight: 700;
  letter-spacing: 2rpx;
}

.picker-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #3A2B00;
}

.picker-mode-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.35;
  color: rgba(74, 51, 0, 0.72);
}

.picker-hero-mark {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 22rpx rgba(122, 83, 0, 0.14);
}

.picker-hero-number {
  font-size: 34rpx;
  line-height: 1;
  color: #A76F00;
  font-weight: 900;
}

.picker-hero-unit {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #7E5A00;
  font-weight: 700;
}

.picker-close {
  position: absolute;
  top: 22rpx;
  right: 24rpx;
  z-index: 2;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #6F4D00;
  background: rgba(255, 255, 255, 0.45);
  border-radius: 50%;
}

.picker-mode-tabs {
  display: flex;
  gap: 12rpx;
  padding: 24rpx 30rpx 0;
  background: transparent;
}

.picker-mode-tab {
  flex: 1;
  padding: 19rpx 0;
  text-align: center;
  background: rgba(255, 245, 214, 0.92);
  border: 1rpx solid #EED995;
  border-radius: 999rpx;
  transition: all 0.2s;
}

.picker-mode-tab text {
  font-size: 26rpx;
  color: #8B6500;
  font-weight: 700;
}

.picker-mode-tab.active {
  background: linear-gradient(135deg, #FFD559 0%, #FFB800 100%);
  border-color: #FFB800;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.24);
}

.picker-mode-tab.active text {
  color: #4D3700;
}

.picker-content {
  padding: 28rpx 30rpx 30rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.picker-year-switcher {
  display: grid;
  grid-template-columns: 142rpx 1fr 142rpx;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 30rpx;
  padding: 10rpx;
  background: #FFF8DE;
  border: 1rpx solid #F2DFA4;
  border-radius: 28rpx;
}

.picker-year-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  background: #FFFFFF;
  border: 1rpx solid #F3E2B0;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 14rpx rgba(122, 83, 0, 0.06);
}

.picker-year-btn text {
  font-size: 23rpx;
  color: #8B6500;
  font-weight: 800;
}

.picker-year-btn-hover {
  background: #FFE9A8;
  transform: translateY(1rpx);
}

.picker-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF1BE;
  border: 1rpx solid #F0D783;
  border-radius: 50%;
  font-size: 28rpx;
  color: #8B6500;
  font-weight: 700;
}

.picker-btn:active {
  background: #FFE49A;
}

.picker-value {
  flex: 1;
  text-align: center;
}

.picker-year {
  font-size: 36rpx;
  font-weight: 800;
  color: #3A2B00;
}

.picker-months {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.month-item {
  padding: 22rpx 10rpx;
  text-align: center;
  background: #FFFDF6;
  border: 1rpx solid #F3E3B3;
  border-radius: 18rpx;
  transition: all 0.2s;
}

.month-item.active {
  background: linear-gradient(180deg, #FFE27B 0%, #FFB800 100%);
  border-color: #FFB800;
  box-shadow: 0 8rpx 18rpx rgba(255, 184, 0, 0.2);
}

.month-item:active {
  transform: scale(0.95);
}

.month-text {
  font-size: 28rpx;
  color: #705000;
  font-weight: 700;
}

.month-item.active .month-text {
  color: #3A2B00;
  font-weight: 800;
}

.range-picker-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.range-picker-hint {
  padding: 18rpx 22rpx;
  background: #FFF6D5;
  border: 1rpx solid #F3DF9F;
  border-radius: 18rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #8B6500;
}

.range-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  background: #FFFDF6;
  border: 1rpx solid #F4E2A6;
  border-radius: 22rpx;
}

.range-field-label {
  font-size: 26rpx;
  color: #5F4A16;
  font-weight: 700;
}

.range-picker-value {
  min-width: 220rpx;
  padding: 16rpx 20rpx;
  text-align: center;
  background: linear-gradient(180deg, #FFF4CA 0%, #FFE8A3 100%);
  border: 1rpx solid #F1D276;
  border-radius: 999rpx;
  font-size: 25rpx;
  color: #5F4A16;
  font-weight: 700;
}

.range-picker-value.empty {
  color: #A9976C;
  font-weight: 500;
}

.picker-footer {
  display: flex;
  border-top: 1rpx solid #F3E6BF;
  background: rgba(255, 253, 246, 0.92);
}

.picker-action {
  flex: 1;
  padding: 30rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.picker-action.cancel {
  color: #9B8A5F;
  border-right: 1rpx solid #F3E6BF;
}

.picker-action.cancel:active {
  background: #F5F5F5;
}

.picker-action.confirm {
  color: #A67300;
}

.picker-action.confirm:active {
  background: #FFF5D6;
}

/* 统计卡片 */
.statistics-card {
  margin: 0 24rpx 28rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 30rpx;
  box-shadow: 0 12rpx 34rpx rgba(79, 92, 45, 0.08);
}

.analysis-data-shell {
  position: relative;
  min-height: 360rpx;
}

.analysis-data-shell.is-refreshing .statistics-card,
.analysis-data-shell.is-refreshing .empty-state,
.analysis-data-shell.is-refreshing .charts-container {
  filter: saturate(0.92);
}

.analysis-refresh-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 160rpx;
  background: rgba(255, 249, 232, 0.74);
}

.analysis-refresh-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(255, 184, 0, 0.28);
  border-radius: 24rpx;
  box-shadow: 0 18rpx 44rpx rgba(104, 77, 0, 0.14);
}

.analysis-refresh-title {
  display: block;
  margin-bottom: 4rpx;
  font-size: 26rpx;
  color: #3A2B00;
  font-weight: 800;
}

.analysis-refresh-desc {
  display: block;
  font-size: 22rpx;
  color: #8B6500;
}

.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-title {
  display: block;
  font-size: 32rpx;
  color: #2F2A12;
  font-weight: 700;
}

.stat-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #96845B;
}

.stat-days {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  background: #FFF4CA;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8B6500;
  font-weight: 600;
}

.stat-summary-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.stat-summary-item {
  padding: 20rpx 16rpx;
  background: linear-gradient(180deg, #FFF9E8 0%, #FFF3C8 100%);
  border: 1rpx solid #F3DF9F;
  border-radius: 20rpx;
}

.stat-summary-item .stat-value {
  font-size: 30rpx;
}

.calorie-source-card {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #FFFDF4;
  border: 1rpx solid #F2E4BA;
  border-radius: 22rpx;
}

.calorie-source-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.calorie-source-title {
  font-size: 25rpx;
  color: #5F4A16;
  font-weight: 700;
}

.calorie-source-subtitle {
  font-size: 20rpx;
  color: #9B8A5F;
}

.calorie-source-bar {
  display: flex;
  height: 18rpx;
  overflow: hidden;
  background: #F7EBC8;
  border-radius: 999rpx;
}

.calorie-source-segment {
  min-width: 4rpx;
  height: 100%;
}

.calorie-source-segment.milk {
  background: linear-gradient(90deg, #FFCB45, #FFB800);
}

.calorie-source-segment.food {
  background: linear-gradient(90deg, #8BCB6A, #4CAF50);
}

.calorie-source-segment.treatment {
  background: linear-gradient(90deg, #70B7FF, #2196F3);
}

.calorie-source-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.calorie-source-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.source-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.calorie-source-item.milk .source-dot {
  background: #FFB800;
}

.calorie-source-item.food .source-dot {
  background: #4CAF50;
}

.calorie-source-item.treatment .source-dot {
  background: #2196F3;
}

.source-name {
  font-size: 21rpx;
  color: #7D704E;
  font-weight: 600;
}

.source-value {
  font-size: 20rpx;
  line-height: 1.25;
  color: #3B331F;
}

.stat-section {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #F2E8C8;
}

.stat-section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #7B641E;
  font-weight: 700;
}

.stat-mini-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-item {
  background: #FFF9E8;
  border: 1rpx solid #F4E8C3;
  border-radius: 18rpx;
  padding: 20rpx;
}

.stat-item-wide {
  grid-column: span 2;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #8D805F;
  margin-bottom: 10rpx;
}

.stat-value {
  display: block;
  font-size: 34rpx;
  color: #2F2A12;
  font-weight: 700;
  line-height: 1.2;
}

.stat-range {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.35;
  color: #9B8A5F;
}

.stat-value.natural {
  color: #4CAF50;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.stat-value.special {
  color: #2196F3;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.stat-value.regular {
  color: #795548;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.stat-value.carbs {
  color: #D9801F;
}

.stat-value.fat {
  color: #C05D75;
}

.stat-unit {
  font-size: 24rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 图表容器 */
.charts-container {
  padding: 0 24rpx 56rpx;
}

.chart-section {
  background: #FFFFFF;
  border-radius: 30rpx;
  padding: 24rpx 18rpx 18rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(66, 80, 34, 0.07);
}

.chart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.chart-title {
  display: block;
  font-size: 28rpx;
  color: #2F2A12;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.chart-subtitle {
  display: block;
  font-size: 21rpx;
  line-height: 1.35;
  color: #8D805F;
}

.chart-axis-hint {
