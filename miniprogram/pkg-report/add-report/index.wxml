<!--pages/add-report/index.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="content">
    <view class="report-meta-bar">
      <view class="meta-card">
        <text class="meta-label">检测日期</text>
        <picker mode="date" value="{{reportDate}}" bindchange="onDateChange" class="meta-picker">
          <view class="meta-picker-content">
            <text class="meta-value">{{reportDate || '请选择日期'}}</text>
            <text class="meta-icon">📅</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="report-type-section">
      <view class="section-header">
        <text class="section-title">报告类型</text>
      </view>
      <scroll-view class="type-scroll" scroll-x="true" show-scrollbar="false">
        <view
          wx:for="{{reportTypes}}"
          wx:key="key"
          wx:for-item="type"
          class="type-chip {{selectedReportType === type.key ? 'active' : ''}}"
          bindtap="onReportTypeChange"
          data-type="{{type.key}}"
        >
          <text class="type-chip-icon">{{type.icon}}</text>
          <text class="type-chip-name">{{type.name}}</text>
        </view>
      </scroll-view>
    </view>

    <view class="indicator-list">
      <view
        wx:for="{{currentIndicators}}"
        wx:key="key"
        wx:for-item="indicator"
        class="indicator-row"
      >
        <view class="indicator-row-top">
          <view class="indicator-meta">
            <view class="indicator-title">
              <text class="indicator-name">{{indicator.name}}</text>
              <text class="indicator-abbr">{{indicator.abbr}}</text>
              <text wx:if="{{!indicator.optional && !indicator.isRatio}}" class="required-mark">*</text>
            </view>
          </view>
        </view>

        <view class="compact-input-grid {{(!indicator.isRatio || indicator.allowRangeInput) ? '' : 'value-only'}}">
          <view class="compact-cell value-cell">
            <text class="compact-label">检测值</text>
            <input
              class="compact-input"
              type="digit"
              placeholder="数值"
              value="{{indicatorData[indicator.key].value}}"
              data-indicator="{{indicator.key}}"
              data-field="value"
              bindinput="onIndicatorValueInput"
              bindblur="onIndicatorValueBlur"
            />
          </view>

          <block wx:if="{{!indicator.isRatio || indicator.allowRangeInput}}">
            <view class="compact-cell">
              <text class="compact-label">最小值</text>
              <input
                class="compact-input"
                type="digit"
                placeholder="{{indicatorData[indicator.key].minRange ? '已填' : '最小'}}"
                value="{{indicatorData[indicator.key].minRange}}"
                data-indicator="{{indicator.key}}"
                data-field="minRange"
                bindinput="onIndicatorValueInput"
                bindblur="onIndicatorValueBlur"
              />
            </view>
            <view class="compact-cell">
              <text class="compact-label">最大值</text>
              <input
                class="compact-input"
                type="digit"
                placeholder="{{indicatorData[indicator.key].maxRange ? '已填' : '最大'}}"
                value="{{indicatorData[indicator.key].maxRange}}"
                data-indicator="{{indicator.key}}"
                data-field="maxRange"
                bindinput="onIndicatorValueInput"
                bindblur="onIndicatorValueBlur"
              />
            </view>
          </block>
        </view>

        <view wx:if="{{indicatorData[indicator.key].optimalRange}}" class="optimal-range">
          <text class="optimal-label">最优范围</text>
          <text class="optimal-value">
            {{indicatorData[indicator.key].optimalRange.min}} - {{indicatorData[indicator.key].optimalRange.max}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-section">
    <view class="disclaimer">
      <text class="disclaimer-text">仅用于记录检测结果，不能替代医生解读。</text>
    </view>
    <view class="save-section">
      <button class="save-button" bindtap="onSaveReport" disabled="{{saving}}">
        <text class="save-text">{{saving ? '保存中...' : '保存报告'}}</text>
      </button>
    </view>
  </view>
</view>
