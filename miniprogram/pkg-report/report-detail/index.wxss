.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top right, rgba(255, 217, 128, 0.28), transparent 34%),
    linear-gradient(180deg, #fffaf0 0%, #fff4db 100%);
  box-sizing: border-box;
}

.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(201, 136, 23, 0.15);
  border-top: 4rpx solid #c98817;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #8d7449;
  margin-top: 20rpx;
}

.content {
  width: 100%;
}

.report-header {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(201, 136, 23, 0.12);
  box-shadow: 0 8rpx 24rpx rgba(201, 136, 23, 0.08);
}

.header-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.report-title {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.title-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c1d09;
}

.date-text,
.lab-text {
  font-size: 24rpx;
  color: #8d7449;
}

.header-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  box-shadow: 0 6rpx 16rpx rgba(201, 136, 23, 0.18);
}

.action-btn.danger {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(198, 40, 40, 0.22);
  box-shadow: none;
}

.action-btn.danger .action-label {
  color: #c62828;
}

.action-icon {
  font-size: 24rpx;
}

.action-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c1d09;
}

.status-banner {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-banner.normal {
  background: rgba(76, 175, 80, 0.12);
  color: #2e7d32;
}

.status-banner.abnormal {
  background: rgba(244, 67, 54, 0.1);
  color: #c62828;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #5f3d00;
  margin-bottom: 16rpx;
}

.indicators-section {
  margin-bottom: 24rpx;
}

.indicators-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.indicator-item {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(201, 136, 23, 0.1);
}

.indicator-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.indicator-info {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.indicator-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c1d09;
}

.indicator-abbr {
  font-size: 22rpx;
  color: #8d7449;
}

.status-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.normal {
  background: rgba(76, 175, 80, 0.12);
  color: #2e7d32;
}

.status-badge.high,
.status-badge.low {
  background: rgba(244, 67, 54, 0.1);
  color: #c62828;
}

.status-badge.empty {
  background: rgba(141, 116, 73, 0.1);
  color: #8d7449;
}

.indicator-values {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.value-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 44rpx;
}

.value-label {
  width: 152rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 44rpx;
  color: #8d7449;
}

.value-value {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  line-height: 44rpx;
}

.value-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c1d09;
  text-align: right;
}

.value-text.high,
.value-text.low {
  color: #c62828;
}

.value-text.empty {
  color: #b5a48a;
  font-weight: 500;
}

.value-unit {
  font-size: 22rpx;
  font-weight: 500;
}

.value-text.optimal,
.value-row.optimal .value-label {
  color: #6b5430;
}

.report-info-section {
  margin-bottom: 24rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(201, 136, 23, 0.1);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(201, 136, 23, 0.08);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 24rpx;
  color: #8d7449;
}

.info-value {
  font-size: 24rpx;
  color: #2c1d09;
  font-weight: 600;
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
}

.secondary-btn {
  flex: 1;
  margin: 0;
  padding: 0;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.92);
  color: #5f3d00;
  border: 1rpx solid rgba(201, 136, 23, 0.16);
}

.secondary-btn.danger {
  color: #c62828;
  border-color: rgba(244, 67, 54, 0.18);
}

.secondary-btn[disabled] {
  opacity: 0.6;
}

.secondary-btn::after {
  border: none;
}
