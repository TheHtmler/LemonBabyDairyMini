<view class="container">
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="content">
    <view class="report-header">
      <view class="header-main">
        <view class="report-title">
          <text class="title-text">{{reportData.reportTypeName}}</text>
          <text class="date-text">{{reportData.formattedDate}}</text>
          <text wx:if="{{reportData.labName}}" class="lab-text">{{reportData.labName}}</text>
        </view>
        <view class="header-actions">
          <view class="action-btn edit" bindtap="onEditReport">
            <text class="action-icon">✏️</text>
            <text class="action-label">编辑</text>
          </view>
        </view>
      </view>
      <view wx:if="{{reportSummary.abnormalCount > 0}}" class="status-banner abnormal">
        {{reportSummary.abnormalCount}} 项指标异常，请注意
      </view>
      <view wx:else class="status-banner normal">本次指标均在参考范围内</view>
    </view>

    <view class="indicators-section">
      <text class="section-title">指标详情</text>
      <view class="indicators-list">
        <view wx:for="{{indicatorConfigs}}" wx:key="key" class="indicator-item">
          <view class="indicator-header">
            <view class="indicator-info">
              <text class="indicator-name">{{item.displayName || item.name}}</text>
              <text wx:if="{{item.abbr && item.abbr !== item.displayName && item.abbr !== item.name}}" class="indicator-abbr">{{item.abbr}}</text>
            </view>
            <view wx:if="{{reportData.indicators[item.key] && reportData.indicators[item.key].value && reportData.indicators[item.key].status !== 'normal'}}" class="status-badge {{reportData.indicators[item.key].status}}">
              {{reportData.indicators[item.key].status === 'high' ? '偏高' :
                reportData.indicators[item.key].status === 'low' ? '偏低' : '未知'}}
            </view>
            <view wx:elif="{{!reportData.indicators[item.key] || !reportData.indicators[item.key].value}}" class="status-badge empty">未填写</view>
          </view>

          <view class="indicator-values">
            <view class="value-row">
              <view class="value-label">检测值</view>
              <view class="value-value">
                <block wx:if="{{reportData.indicators[item.key] && reportData.indicators[item.key].value}}">
                  <text class="value-text {{reportData.indicators[item.key].status}}">{{reportData.indicators[item.key].value}}</text>
                  <text wx:if="{{item.unit}}" class="value-unit">{{item.unit}}</text>
                </block>
                <text wx:else class="value-text empty">—</text>
              </view>
            </view>
            <view wx:if="{{(!item.isRatio || item.allowRangeInput) && reportData.indicators[item.key] && reportData.indicators[item.key].minRange}}" class="value-row">
              <view class="value-label">参考范围</view>
              <view class="value-value">
                <text class="value-text">{{reportData.indicators[item.key].minRange}} – {{reportData.indicators[item.key].maxRange}}</text>
              </view>
            </view>
            <view wx:if="{{reportData.indicators[item.key] && reportData.indicators[item.key].optimalRange}}" class="value-row optimal">
              <view class="value-label">最优范围</view>
              <view class="value-value">
                <text class="value-text optimal">{{reportData.indicators[item.key].optimalRange.min}} – {{reportData.indicators[item.key].optimalRange.max}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="report-info-section">
      <text class="section-title">报告信息</text>
      <view class="info-card">
        <view class="info-row">
          <text class="info-label">已填写</text>
          <text class="info-value">{{reportSummary.filledCount}}/{{reportSummary.totalCount}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">更新时间</text>
          <text class="info-value">{{reportData.formattedUpdatedAt}}</text>
        </view>
      </view>
    </view>

    <view class="secondary-actions">
      <button class="secondary-btn" bindtap="onCopyReport">复制报告</button>
      <button class="secondary-btn danger" bindtap="onDeleteReport" disabled="{{deleting}}">
        {{deleting ? '删除中...' : '删除报告'}}
      </button>
    </view>
  </view>
</view>
