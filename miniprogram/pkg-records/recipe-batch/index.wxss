.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff6d8 0%, #fffaf0 100%);
}

.hero {
  padding: 22rpx 26rpx;
  margin-bottom: 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffcb38 0%, #ffb800 100%);
}

.hero-title,
.ingredient-name,
.ingredient-ref,
.ingredient-current,
.panel-title,
.summary-title,
.summary-weight,
.summary-value,
.summary-label {
  display: block;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #5f3900;
}

.loading-state {
  padding: 80rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
  color: #8a7c60;
}

.batch-panel,
.summary-card {
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.batch-panel {
  padding: 22rpx 22rpx 8rpx;
}

.intake-panel {
  padding: 22rpx;
}

.panel-title {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4c402f;
}

.ingredient-row {
  padding: 16rpx 0 18rpx;
  border-bottom: 2rpx solid rgba(158, 114, 12, 0.08);
}

.ingredient-row:last-child {
  border-bottom: none;
}

.ingredient-head {
  margin-bottom: 12rpx;
}

.ingredient-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.ingredient-ref {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #a8956d;
}

.ingredient-current {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #7a5a12;
  font-weight: 600;
}

.quantity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.compact-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.14);
  border-radius: 16rpx;
  background: #fff9ea;
  box-sizing: border-box;
  font-size: 28rpx;
}

.unit-label {
  flex-shrink: 0;
  width: 40rpx;
  color: #8a7c60;
  font-size: 26rpx;
  text-align: center;
}

.summary-card {
  padding: 22rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.35);
  background: linear-gradient(180deg, #fff4c8 0%, #fffaf0 100%);
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.12);
}

.summary-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #5f4a12;
}

.summary-weight {
  font-size: 24rpx;
  font-weight: 700;
  color: #c78200;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 108rpx;
  padding: 14rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.88);
  box-sizing: border-box;
  text-align: center;
}

.summary-value {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.15;
  font-weight: 800;
  color: #333;
}

.summary-label {
  width: 100%;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a7c60;
}

.mode-tabs {
  display: flex;
  gap: 0;
  margin-bottom: 16rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #fff4d2;
  box-sizing: border-box;
}

.mode-tab {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 12rpx;
  color: #8a7c60;
  font-size: 26rpx;
  background: transparent;
}

.mode-tab.active {
  background: #ffb800;
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.28);
}

.mode-tab.disabled {
  opacity: 0.35;
}

.intake-preview {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #fff7df;
  box-sizing: border-box;
}

.intake-preview-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.intake-preview-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #5f4a12;
}

.intake-preview-meta {
  font-size: 22rpx;
  font-weight: 700;
  color: #c78200;
}

.intake-preview-grid .summary-item {
  min-height: 96rpx;
  background: rgba(255, 255, 255, 0.92);
}

.intake-preview-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b2a17b;
}

.scroll-space {
  height: 24rpx;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  width: 100%;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 250, 240, 0.98);
  box-shadow: 0 -6rpx 18rpx rgba(71, 51, 0, 0.08);
  box-sizing: border-box;
}

/* 原生 button 必须显式清掉默认外边距，否则左右会对不齐 */
.confirm-btn {
  display: block;
  width: 100% !important;
  height: 84rpx;
  margin: 0 !important;
  padding: 0 !important;
  border: none;
  border-radius: 18rpx;
  background: #ffb800;
  color: #fff;
  box-sizing: border-box;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.confirm-btn[disabled] {
  background: #ead8a0;
  color: rgba(255, 255, 255, 0.9);
}

.confirm-btn::after {
  border: none !important;
}
