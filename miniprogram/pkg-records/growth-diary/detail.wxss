.detail-container {
  padding: 20rpx 16rpx 80rpx;
  background: #fff5d6;
  min-height: 100vh;
  box-sizing: border-box;
}

.loading-card,
.empty-card,
.detail-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.1);
}

.loading-card {
  padding: 60rpx 28rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: #9b7a00;
}

.detail-card {
  padding: 28rpx 24rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.detail-date {
  font-size: 24rpx;
  color: #9b7a00;
}

.detail-author {
  font-size: 22rpx;
  color: #c49a00;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3b2d00;
  line-height: 1.4;
}

.detail-notes {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6a5200;
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #fff5d6;
}

.detail-publish {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #fff0c2;
  font-size: 24rpx;
  color: #9b7a00;
  line-height: 1.4;
}

.share-hint {
  margin-top: 24rpx;
  padding: 0 8rpx;
  text-align: center;
}

.share-hint-text {
  font-size: 24rpx;
  color: #9b7a00;
}

.empty-card {
  padding: 80rpx 28rpx;
  text-align: center;
}

.empty-emoji {
  display: block;
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #4c3a00;
}

.empty-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9b7a00;
  line-height: 1.5;
}
