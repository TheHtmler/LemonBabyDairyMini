.diary-container {
  padding: 20rpx 16rpx 80rpx;
  background: #fff5d6;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4c3a00;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8a6b00;
  font-size: 24rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 26rpx;
  border: none;
  line-height: 2.2;
}

.action-btn.primary {
  background: #ffb800;
  color: #fff;
}

.action-btn.ghost {
  background: #fffaf0;
  color: #8a6b00;
  border: 1rpx solid #ffe1a3;
}

.action-btn[disabled] {
  opacity: 0.6;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  max-height: 84vh;
  background: linear-gradient(180deg, #fffdf8 0%, #ffffff 18%);
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  padding: 0 28rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0 16rpx;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3b2d00;
}

.modal-close {
  font-size: 26rpx;
  color: #9b7a00;
  padding: 8rpx 4rpx;
}

.modal-body {
  flex: 1;
  max-height: 56vh;
  min-height: 200rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #7a5b00;
  margin-bottom: 10rpx;
}

.form-input,
.form-textarea,
.picker-value {
  display: block;
  background: #fffaf0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #3b2d00;
  border: 1rpx solid #ffe1a3;
  box-sizing: border-box;
  width: 100%;
}

.form-input,
.picker-value {
  height: 80rpx;
  min-height: 80rpx;
  line-height: 80rpx;
}

.form-textarea {
  min-height: 160rpx;
  padding: 18rpx 20rpx;
  line-height: 1.5;
}

.picker-value {
  color: #7a5b00;
}

.form-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  padding-top: 8rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item,
.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.photo-thumb {
  width: 100%;
  height: 100%;
  background: #fff5d6;
}

.photo-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(60, 40, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fffaf0;
  border: 2rpx dashed #ffd369;
  color: #9b7a00;
}

.photo-add-icon {
  font-size: 40rpx;
  line-height: 1;
}

.photo-add-text {
  margin-top: 6rpx;
  font-size: 22rpx;
}

.timeline-section {
  margin-top: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b2d00;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.timeline-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.timeline-item {
  position: relative;
  padding-left: 34rpx;
}

.timeline-dot {
  position: absolute;
  left: 6rpx;
  top: 22rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ffb800;
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(255, 184, 0, 0.2);
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 13rpx;
  top: 44rpx;
  width: 2rpx;
  height: calc(100% - 16rpx);
  background: #ffe5a4;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.1);
}

.timeline-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.timeline-date {
  font-size: 22rpx;
  color: #9b7a00;
}

.timeline-author {
  font-size: 22rpx;
  color: #c49a00;
}

.timeline-title {
  font-size: 28rpx;
  color: #3b2d00;
  font-weight: 600;
}

.timeline-notes {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6a5200;
  line-height: 1.5;
  white-space: pre-wrap;
}

.timeline-thumbs {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.timeline-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #fff5d6;
}

.timeline-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #fff0c2;
}

.link-btn {
  font-size: 24rpx;
  color: #c49a00;
  padding: 4rpx 0;
  background: transparent;
  border: none;
  line-height: 1.4;
  margin: 0;
  display: inline;
}

.link-btn::after {
  border: none;
}

/* 微信 button 默认很高很宽，压成和「编辑」一样的文字链 */
.share-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto !important;
  min-width: 0 !important;
  min-height: 0 !important;
  height: auto !important;
  padding: 0 !important;
  margin: 0 !important;
  font-size: 24rpx !important;
  font-weight: 400;
  line-height: 1.4 !important;
  color: #c49a00 !important;
  background: transparent !important;
  border: none !important;
  border-radius: 0;
  box-sizing: content-box;
  vertical-align: middle;
}

.share-btn::after {
  border: none;
}

.link-btn.danger {
  color: #d97757;
}

.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.08);
}

.empty-emoji {
  display: block;
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #4c3a00;
  font-weight: 600;
}

.empty-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9b7a00;
}
