.diary-container {
  padding: 20rpx 16rpx 80rpx;
  background: #fff5d6;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4c3a00;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8a6b00;
  font-size: 24rpx;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 26rpx;
  border: none;
  line-height: 2.2;
}

.action-btn.primary {
  background: #ffb800;
  color: #fff;
}

.action-btn.ghost {
  background: #fffaf0;
  color: #8a6b00;
  border: 1rpx solid #ffe1a3;
}

.action-btn[disabled] {
  opacity: 0.6;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 184, 0, 0.12);
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b2d00;
  margin-bottom: 18rpx;
}

.form-item {
  margin-bottom: 18rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #7a5b00;
  margin-bottom: 8rpx;
}

.form-input,
.form-textarea,
.picker-value {
  background: #fffaf0;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 26rpx;
  color: #3b2d00;
  border: 1rpx solid #ffe1a3;
  box-sizing: border-box;
  width: 100%;
}

.form-textarea {
  min-height: 140rpx;
  line-height: 1.5;
}

.picker-value {
  color: #7a5b00;
}

.form-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item,
.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.photo-thumb {
  width: 100%;
  height: 100%;
  background: #fff5d6;
}

.photo-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(60, 40, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fffaf0;
  border: 2rpx dashed #ffd369;
  color: #9b7a00;
}

.photo-add-icon {
  font-size: 40rpx;
  line-height: 1;
}

.photo-add-text {
  margin-top: 6rpx;
  font-size: 22rpx;
}

.timeline-section {
  margin-top: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b2d00;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.timeline-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.timeline-item {
  position: relative;
  padding-left: 34rpx;
}

.timeline-dot {
  position: absolute;
  left: 6rpx;
  top: 22rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ffb800;
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(255, 184, 0, 0.2);
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 13rpx;
  top: 44rpx;
  width: 2rpx;
  height: calc(100% - 16rpx);
  background: #ffe5a4;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.1);
}

.timeline-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.timeline-date {
  font-size: 22rpx;
  color: #9b7a00;
}

.timeline-author {
  font-size: 22rpx;
  color: #c49a00;
}

.timeline-title {
  font-size: 28rpx;
  color: #3b2d00;
  font-weight: 600;
}

.timeline-notes {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6a5200;
  line-height: 1.5;
  white-space: pre-wrap;
}

.timeline-thumbs {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.timeline-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #fff5d6;
}

.timeline-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #fff0c2;
}

.link-btn {
  font-size: 24rpx;
  color: #c49a00;
  padding: 4rpx 0;
}

.link-btn.danger {
  color: #d97757;
}

.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.08);
}

.empty-emoji {
  display: block;
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #4c3a00;
  font-weight: 600;
}

.empty-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9b7a00;
}
