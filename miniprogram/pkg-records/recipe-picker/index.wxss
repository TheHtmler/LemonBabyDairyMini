.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff6d8 0%, #fffaf0 100%);
}

.hero {
  padding: 30rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffcb38 0%, #ffb800 100%);
  color: #5f3900;
}

.eyebrow,
.hero-title,
.hero-copy,
.empty-icon,
.empty-title,
.empty-copy,
.recipe-name,
.recipe-meta {
  display: block;
}

.eyebrow {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(95, 57, 0, 0.75);
}

.loading-state,
.empty-state {
  padding: 60rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
  color: #8a7c60;
}

.empty-icon {
  font-size: 56rpx;
}

.empty-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #4c402f;
}

.empty-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.recipe-card {
  padding: 24rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.14);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.recipe-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.recipe-main {
  flex: 1;
  min-width: 0;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.recipe-meta {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8a7c60;
}

.select-mark {
  flex-shrink: 0;
  color: #c78200;
  font-size: 40rpx;
  line-height: 1;
}
