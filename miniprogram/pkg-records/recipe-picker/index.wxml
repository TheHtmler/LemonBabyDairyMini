<view class="page">
  <view class="hero">
    <text class="eyebrow">本顿食谱</text>
    <text class="hero-title">这顿做了哪道菜？</text>
    <text class="hero-copy">点选一道食谱后，进入下一页填写当次用量和宝宝吃了多少。</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">正在加载食谱...</view>

  <view class="empty-state" wx:elif="{{!loading && recipeCount === 0}}">
    <text class="empty-icon">🥣</text>
    <text class="empty-title">还没有可用食谱</text>
    <text class="empty-copy">{{emptyHint || '请先到“我的 → 食谱管理”创建原料组合。'}}</text>
  </view>

  <view class="recipe-list" wx:elif="{{!loading && recipeCount > 0}}">
    <view
      class="recipe-card"
      wx:for="{{recipes}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="selectRecipe"
    >
      <view class="recipe-head">
        <view class="recipe-main">
          <text class="recipe-name">{{item.name}}</text>
          <text class="recipe-meta">{{item.ingredientCount}} 种原料 · {{item.ingredientNames || '未命名原料'}}</text>
        </view>
        <text class="select-mark">›</text>
      </view>
    </view>
  </view>
</view>
