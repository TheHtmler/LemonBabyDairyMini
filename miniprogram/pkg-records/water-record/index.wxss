.page {
  position: relative;
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background:
    radial-gradient(ellipse 90% 60% at 50% 18%, rgba(255, 236, 150, 0.75), transparent 58%),
    radial-gradient(ellipse 70% 50% at 80% 70%, rgba(160, 220, 245, 0.22), transparent 55%),
    linear-gradient(180deg, #FFF7D8 0%, #FFEFB8 55%, #FFE6A0 100%);
}

.hero {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 28rpx 0 0;
}

.amount-bar {
  flex-shrink: 0;
  text-align: center;
  margin-bottom: 0;
  padding: 12rpx 24rpx 0;
  opacity: 0;
  transform: translateY(10rpx);
  transition: opacity 360ms ease, transform 360ms ease;
  z-index: 5;
}

.page.is-entered .amount-bar {
  opacity: 1;
  transform: translateY(0);
}

.amount-bar.is-popping .amount-value {
  animation: amount-pop 420ms cubic-bezier(0.22, 1.35, 0.36, 1);
}

.amount-label {
  display: block;
  font-size: 24rpx;
  color: rgba(95, 57, 0, 0.62);
}

.amount-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
  margin-top: 2rpx;
}

.amount-value {
  font-size: 64rpx;
  line-height: 1;
  font-weight: 800;
  color: #5F3900;
  letter-spacing: -2rpx;
  display: inline-block;
}

.amount-unit {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(95, 57, 0, 0.62);
}

.amount-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(95, 57, 0, 0.48);
}

.vessel-slot {
  flex: 1;
  min-height: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.vessel-stage {
  position: relative;
  width: 100vw;
  height: 100vw;
  max-width: 100%;
  max-height: 100%;
  aspect-ratio: 1 / 1;
  opacity: 0;
  transform: scale(0.96);
  transition: opacity 380ms ease, transform 420ms cubic-bezier(0.22, 1.15, 0.36, 1);
}

.page.is-entered .vessel-stage {
  opacity: 1;
  transform: scale(1);
}

.vessel-stage.is-splashing .vessel-overlay {
  animation: vessel-nudge 420ms ease;
}

.vessel-glow {
  position: absolute;
  left: 16%;
  top: 20%;
  width: 68%;
  height: 68%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(90, 188, 230, 0.18), transparent 70%);
  z-index: 0;
  pointer-events: none;
}

.water-canvas,
.water-static,
.vessel-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.vessel-overlay {
  z-index: 2;
  pointer-events: none;
}

.water-canvas,
.water-static {
  z-index: 1;
  pointer-events: none;
}

/* 与 canvas 内腔椭圆比例一致，弹窗期间静态占位 */
.water-static-clip {
  position: absolute;
  left: 25.89%;
  top: 28.21%;
  width: 48.14%;
  height: 56.1%;
  border-radius: 50%;
  overflow: hidden;
}

.water-static-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(132, 214, 245, 0.95) 0%,
    rgba(86, 186, 232, 0.96) 45%,
    rgba(48, 148, 210, 0.98) 100%
  );
}

.splash-ring {
  position: absolute;
  left: 50%;
  top: 58%;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  border: 4rpx solid rgba(120, 205, 245, 0.75);
  border-radius: 50%;
  z-index: 4;
  pointer-events: none;
  animation: splash-ring 480ms ease-out forwards;
}

.water-drop {
  position: absolute;
  left: 50%;
  top: 8%;
  z-index: 5;
  margin-left: -22rpx;
  font-size: 44rpx;
  line-height: 1;
  opacity: 0;
  pointer-events: none;
}

.water-drop.is-falling {
  animation: drop-fall 580ms cubic-bezier(0.4, 0.05, 0.7, 0.2) forwards;
}

.dock {
  flex-shrink: 0;
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  margin: -28rpx 16rpx calc(10rpx + env(safe-area-inset-bottom));
  padding: 14rpx 14rpx 14rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 247, 0.94);
  border: 2rpx solid rgba(255, 184, 0, 0.18);
  box-shadow: 0 12rpx 28rpx rgba(95, 57, 0, 0.08);
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 360ms ease 100ms, transform 360ms ease 100ms;
  z-index: 6;
}

.page.is-entered .dock {
  opacity: 1;
  transform: translateY(0);
}

.dock-main {
  flex: 1;
  min-width: 0;
}

.dock-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dock-title {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(95, 57, 0, 0.72);
}

.dock-all-btn {
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
  min-height: 48rpx;
  padding: 6rpx 16rpx 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 184, 0, 0.16);
  border: 2rpx solid rgba(255, 184, 0, 0.28);
  box-sizing: border-box;
}

.dock-all-btn-press {
  opacity: 0.78;
  transform: scale(0.97);
}

.dock-all-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #9A6A00;
  line-height: 1;
}

.dock-all-arrow {
  font-size: 28rpx;
  font-weight: 700;
  color: #9A6A00;
  line-height: 1;
  margin-top: -2rpx;
}

.chip-scroll {
  width: 100%;
  white-space: nowrap;
}

.chip-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.record-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-width: 132rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(231, 245, 255, 0.9);
  border: 2rpx solid rgba(99, 169, 231, 0.18);
}

.record-chip-press {
  opacity: 0.82;
}

.chip-time {
  font-size: 22rpx;
  color: rgba(58, 95, 122, 0.75);
}

.chip-volume {
  margin-top: 2rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2F6F9F;
}

.dock-empty {
  min-height: 84rpx;
  display: flex;
  align-items: center;
}

.dock-empty-text {
  font-size: 24rpx;
  color: rgba(95, 57, 0, 0.45);
}

.fab {
  flex-shrink: 0;
  width: 120rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #FFCB38 0%, #FFB800 100%);
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.fab-press {
  opacity: 0.9;
  transform: scale(0.96);
}

.fab-plus {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #5F3900;
}

.fab-label {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(95, 57, 0, 0.8);
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(40, 28, 8, 0.36);
  z-index: 20;
  opacity: 0;
  transition: opacity 200ms ease;
}

.drawer-mask.visible {
  opacity: 1;
}

.record-sheet,
.list-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  max-height: 82vh;
  padding: 18rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #FFFDF7;
  transform: translateY(105%);
  transition: transform 260ms cubic-bezier(0.22, 1.12, 0.36, 1);
  box-shadow: 0 -12rpx 36rpx rgba(95, 57, 0, 0.12);
  box-sizing: border-box;
}

.record-sheet.visible,
.list-sheet.visible {
  transform: translateY(0);
}

.list-sheet {
  display: flex;
  flex-direction: column;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(95, 57, 0, 0.16);
  margin: 0 auto 20rpx;
}

.sheet-title-row {
  margin-bottom: 16rpx;
}

.sheet-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5F3900;
  margin-bottom: 8rpx;
}

.sheet-sub {
  font-size: 24rpx;
  color: rgba(95, 57, 0, 0.5);
}

.list-scroll {
  flex: 1;
  max-height: 58vh;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 4rpx;
  border-bottom: 1rpx solid rgba(255, 184, 0, 0.12);
}

.list-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.list-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #5F3900;
}

.list-volume {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F6F9F;
}

.list-actions {
  display: flex;
  gap: 22rpx;
}

.list-action {
  font-size: 26rpx;
  color: #C48900;
}

.list-action.danger {
  color: #C46B5A;
}

.list-empty {
  padding: 48rpx 0;
  text-align: center;
  color: rgba(95, 57, 0, 0.45);
  font-size: 26rpx;
}

.record-sheet {
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
}

.sheet-body {
  flex: 1;
  max-height: 56vh;
  padding-bottom: 12rpx;
  box-sizing: border-box;
}

.compact-grid {
  display: flex;
  gap: 12rpx;
}

.compact-field {
  flex: 1;
  min-width: 0;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #7C6B45;
}

.compact-picker,
.compact-input,
.notes-area {
  width: 100%;
  min-height: 64rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #FFF9EA;
  border: 2rpx solid rgba(255, 184, 0, 0.14);
  color: #302400;
  font-size: 24rpx;
}

.compact-picker {
  display: flex;
  align-items: center;
}

.volume-input-wrap {
  position: relative;
}

.volume-input {
  padding-right: 56rpx;
  font-weight: 600;
}

.volume-unit {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: rgba(95, 57, 0, 0.55);
}

.quick-block,
.notes-block {
  margin-top: 20rpx;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-chip {
  min-width: 96rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 14rpx;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(255, 184, 0, 0.12);
  color: #5F3900;
  font-size: 24rpx;
  font-weight: 700;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  box-sizing: border-box;
}

.quick-chip-press {
  opacity: 0.85;
}

.quick-chip.active {
  background: rgba(255, 184, 0, 0.28);
  border-color: rgba(255, 184, 0, 0.55);
}

.notes-area {
  min-height: 120rpx;
  line-height: 1.5;
}

.sheet-footer {
  flex-shrink: 0;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  height: 84rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FFD45A 0%, #FFB800 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
  box-shadow: 0 10rpx 22rpx rgba(255, 184, 0, 0.22);
}

.save-btn-press {
  opacity: 0.9;
}

.save-btn[disabled] {
  opacity: 0.58;
}

.save-btn::after {
  border: none;
}

.list-main-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}

.list-notes {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(95, 57, 0, 0.5);
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@keyframes vessel-nudge {
  0% { transform: scale(1); }
  40% { transform: scale(1.015); }
  100% { transform: scale(1); }
}

@keyframes splash-ring {
  0% { transform: scale(0.4); opacity: 0.9; }
  100% { transform: scale(3.2); opacity: 0; }
}

@keyframes drop-fall {
  0% { opacity: 0; transform: translateY(-20rpx) scale(0.6); }
  18% { opacity: 1; }
  78% { opacity: 1; transform: translateY(190rpx) scale(1); }
  100% { opacity: 0; transform: translateY(210rpx) scale(0.5); }
}

@keyframes amount-pop {
  0% { transform: scale(1); }
  40% { transform: scale(1.12); color: #2F6F9F; }
  100% { transform: scale(1); }
}
