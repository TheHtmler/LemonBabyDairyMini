<view class="page">
  <view class="overview-card">
    <view class="overview-main">
      <text class="overview-title">{{mode === 'edit' ? '编辑本顿食物' : (mealDraft.mealLabel || '本顿食物')}}</text>
      <text class="overview-subtitle">{{formattedSelectedDate}} · {{mealDraft.mealTime}}</text>
    </view>
    <view class="overview-count">
      <text class="overview-count-value">{{mealDraft.items.length}}</text>
      <text class="overview-count-label">已加食物</text>
    </view>
  </view>

  <view class="section-card meal-meta-card">
    <view class="section-header">
      <text class="section-title">餐次设置</text>
      <text class="section-meta">{{mode === 'edit' ? '修改后会覆盖原餐次' : '这顿饭只设置一次'}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">时间</text>
      <picker mode="time" value="{{mealDraft.mealTime}}" bindchange="onMealTimeChange">
        <view class="field-picker">{{mealDraft.mealTime}}</view>
      </picker>
    </view>
    <view class="label-group">
      <view
        class="label-chip {{mealDraft.mealLabel === item ? 'active' : ''}}"
        wx:for="{{mealLabels}}"
        wx:key="*this"
        data-label="{{item}}"
        bindtap="onMealLabelTap"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section-card items-card">
    <view class="section-header">
      <text class="section-title">本顿食物</text>
      <text class="section-meta">已添加 {{mealDraft.items.length}} 种</text>
    </view>
    <nutrition-target-preview
      preview="{{mealTargetPreview}}"
      title="保存本顿后的目标"
      subtitle="按今日已记录 + 本顿食物预估"
      wx:if="{{mealDraft.items.length > 0}}"
    />
    <view class="meal-summary-grid" wx:if="{{mealDraft.items.length > 0}}">
      <view class="meal-summary-item">
        <text class="meal-summary-value">{{mealSummary.calories || 0}}</text>
        <text class="meal-summary-label">总热量 kcal</text>
      </view>
      <view class="meal-summary-item">
        <text class="meal-summary-value">{{mealSummary.protein || 0}}</text>
        <text class="meal-summary-label">总蛋白 g</text>
      </view>
      <view class="meal-summary-item">
        <text class="meal-summary-value">{{mealSummary.carbs || 0}}</text>
        <text class="meal-summary-label">总碳水 g</text>
      </view>
      <view class="meal-summary-item">
        <text class="meal-summary-value">{{mealSummary.fat || 0}}</text>
        <text class="meal-summary-label">总脂肪 g</text>
      </view>
    </view>
    <view class="empty-state" wx:if="{{mealDraft.items.length === 0}}">
      <text>先点底部“添加食物”，把这顿饭的食物逐个加进来。</text>
    </view>
    <view class="meal-item" wx:for="{{mealDraft.items}}" wx:key="localId">
      <view class="meal-item-main">
        <text class="meal-item-name">{{item.nameSnapshot}}</text>
        <text class="meal-item-meta">{{item.quantity}}{{item.unit}} · {{item.nutrition.calories || 0}} kcal · 蛋白 {{item.nutrition.protein || 0}} g</text>
        <text class="meal-item-detail">碳水 {{item.nutrition.carbs || 0}} g · 脂肪 {{item.nutrition.fat || 0}} g · 纤维 {{item.nutrition.fiber || 0}} g</text>
      </view>
      <view class="meal-item-actions">
        <view class="text-btn" data-id="{{item.localId}}" bindtap="editMealItem">编辑</view>
        <view class="text-btn danger" data-id="{{item.localId}}" bindtap="removeMealItem">删除</view>
      </view>
    </view>
  </view>

  <view class="section-card note-card">
    <view class="section-header">
      <text class="section-title">备注</text>
      <text class="section-meta">可选，不影响主要记录流程</text>
    </view>
    <view class="field-block">
      <textarea
        class="notes-input"
        value="{{mealDraft.mealNote}}"
        placeholder="可选，记录这顿饭的说明"
        bindinput="onMealNoteInput"
      />
    </view>
  </view>

  <view class="footer-bar">
    <button class="footer-btn cancel" bindtap="onCancel">取消</button>
    <button class="footer-btn secondary" bindtap="openFoodDrawer">添加食物</button>
    <button class="footer-btn confirm" bindtap="saveMeal" disabled="{{mealDraft.items.length === 0}}">
      {{mode === 'edit' ? '保存修改' : '保存本顿'}}
    </button>
  </view>

  <view class="drawer-mask" wx:if="{{drawerVisible}}" bindtap="closeFoodDrawer"></view>
  <view class="food-drawer {{drawerVisible ? 'visible' : ''}}">
    <view class="drawer-handle"></view>
    <view class="drawer-header">
      <view class="drawer-header-main">
        <text class="drawer-title">{{drawerStep === 'batch' ? '填写份量' : (editingItemId ? '编辑食物' : '添加食物')}}</text>
        <text class="drawer-subtitle">{{drawerStep === 'batch' ? '给每种食物填写本顿份量' : '确认份量后加入这顿饭'}}</text>
      </view>
      <view class="drawer-close" bindtap="closeFoodDrawer">关闭</view>
    </view>

    <view class="drawer-body batch-body" wx:if="{{drawerStep === 'batch'}}">
      <nutrition-target-preview
        preview="{{batchTargetPreview}}"
        title="蛋白目标"
        subtitle="按已输入份量实时预估"
      />
      <view
        class="batch-food-card"
        wx:for="{{batchFoodDrafts}}"
        wx:key="foodId"
        wx:for-index="draftIndex"
      >
        <view class="batch-food-header">
          <view class="batch-food-main">
            <text class="batch-food-name">{{item.food.name}}</text>
            <text class="batch-food-sub">{{item.food.category || '未分类'}} · {{item.unit || 'g'}}</text>
          </view>
          <text class="food-option-source">{{item.food.sourceLabel}}</text>
        </view>
        <view class="field-row quantity-row">
          <text class="field-label">份量</text>
          <input
            type="digit"
            class="quantity-input"
            value="{{item.quantity}}"
            placeholder="请输入份量"
            data-index="{{draftIndex}}"
            bindinput="onBatchQuantityInput"
          />
          <text class="unit-text">{{item.unit || 'g'}}</text>
        </view>
        <view class="batch-preview" wx:if="{{item.nutritionPreview}}">
          <text>{{item.nutritionPreview.calories || 0}} kcal</text>
          <text>蛋白 {{item.nutritionPreview.protein || 0}} g</text>
        </view>
      </view>
      <view class="batch-actions">
        <button class="add-item-btn secondary" bindtap="backToFoodPicker">继续选食物</button>
        <button class="add-item-btn" bindtap="addSelectedFoodsToMeal">加入本顿</button>
      </view>
    </view>

    <view class="drawer-body edit-body" wx:if="{{drawerStep === 'edit'}}">
      <view class="selected-food-card">
        <view class="selected-food-main">
          <text class="selected-food-name">{{currentFoodDraft.food ? currentFoodDraft.food.name : '未选择食物'}}</text>
          <text class="selected-food-sub">{{currentFoodDraft.food ? (currentFoodDraft.food.category || '未分类') : '请先选择食物'}}</text>
        </view>
      </view>
      <view class="field-row quantity-row">
        <text class="field-label">份量</text>
        <input
          type="digit"
          class="quantity-input"
          value="{{currentFoodDraft.quantity}}"
          placeholder="请输入份量"
          bindinput="onDraftQuantityInput"
        />
        <text class="unit-text">{{currentFoodDraft.unit || 'g'}}</text>
      </view>
      <nutrition-target-preview
        preview="{{draftTargetPreview}}"
        title="加入后目标提醒"
        subtitle="按当前份量实时预估"
      />
      <view class="preview-grid" wx:if="{{currentFoodDraft.nutritionPreview}}">
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.calories || 0}}</text>
          <text class="preview-label">kcal</text>
        </view>
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.protein || 0}}</text>
          <text class="preview-label">蛋白</text>
        </view>
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.carbs || 0}}</text>
          <text class="preview-label">碳水</text>
        </view>
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.fat || 0}}</text>
          <text class="preview-label">脂肪</text>
        </view>
      </view>
      <button class="add-item-btn" bindtap="addOrUpdateMealItem">
        {{editingItemId ? '更新这项食物' : '加入本顿'}}
      </button>
    </view>
  </view>
</view>
