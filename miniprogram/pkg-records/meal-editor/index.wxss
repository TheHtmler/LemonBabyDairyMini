.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 122, 0.5), transparent 28%),
    linear-gradient(180deg, #FFF6D8 0%, #FFF2C8 100%);
  padding: 24rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.overview-card {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FFCB38 0%, #FFB800 100%);
  box-shadow: 0 12rpx 28rpx rgba(255, 184, 0, 0.2);
}

.overview-main {
  flex: 1;
  min-width: 0;
}

.overview-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #5F3900;
}

.overview-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(95, 57, 0, 0.74);
}

.overview-count {
  flex-shrink: 0;
  min-width: 134rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.24);
  text-align: center;
}

.overview-count-value {
  display: block;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #5F3900;
}

.overview-count-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(95, 57, 0, 0.74);
}

.section-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.1);
  border: 2rpx solid rgba(255, 184, 0, 0.12);
  backdrop-filter: blur(8rpx);
}

.meal-meta-card {
  background: rgba(255, 251, 238, 0.96);
}

.items-card {
  margin-bottom: 0;
}

.note-card {
  background: rgba(255, 251, 238, 0.92);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.2;
  color: #333333;
  font-weight: 700;
}

.section-meta {
  font-size: 24rpx;
  line-height: 1.4;
  color: #8A7C60;
  text-align: right;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.field-block {
  margin-top: 8rpx;
}

.field-label.block {
  display: block;
  width: auto;
  margin-bottom: 12rpx;
}

.field-label {
  flex-shrink: 0;
  width: 88rpx;
  font-size: 26rpx;
  color: #6B604D;
}

.field-picker,
.quantity-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.18);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.label-group {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.label-chip,
.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  color: #8A7C60;
  font-size: 24rpx;
  box-sizing: border-box;
}

.label-chip.active,
.category-chip.active {
  background: #FFB800;
  border-color: #FFB800;
  color: #ffffff;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.2);
}

.notes-input {
  width: 100%;
  min-height: 132rpx;
  padding: 18rpx 20rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.18);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
}

.empty-state {
  padding: 34rpx 24rpx;
  text-align: center;
  background: #FFF7E3;
  border-radius: 18rpx;
  color: #8A7C60;
  font-size: 26rpx;
}

.empty-state.compact {
  padding: 24rpx;
}

.meal-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meal-summary-item {
  padding: 18rpx 16rpx;
  border-radius: 18rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.14);
}

.meal-summary-value {
  display: block;
  font-size: 32rpx;
  line-height: 1.1;
  color: #8A4B00;
  font-weight: 700;
}

.meal-summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8A7C60;
}

.meal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(255, 184, 0, 0.12);
}

.meal-item:first-of-type {
  border-top: none;
  padding-top: 0;
}

.meal-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meal-item-title-row,
.selected-food-title-row,
.batch-food-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 100%;
  min-width: 0;
}

.meal-item-name {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meal-item-meta {
  font-size: 23rpx;
  color: #8A7C60;
  line-height: 1.5;
}

.meal-item-detail {
  font-size: 22rpx;
  color: #A08E73;
  line-height: 1.5;
}

.meal-item-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.text-btn {
  font-size: 24rpx;
  color: #C78200;
}

.text-btn.danger {
  color: #D46B08;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 246, 216, 0.98);
  box-sizing: border-box;
  box-shadow: 0 -8rpx 20rpx rgba(255, 184, 0, 0.08);
}

.footer-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 18rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.footer-btn.cancel {
  background: #ffffff;
  color: #8A7C60;
  border: 2rpx solid rgba(255, 184, 0, 0.18);
}

.footer-btn.secondary {
  background: #FFF0BC;
  color: #8A4B00;
}

.footer-btn.confirm {
  background: #FFB800;
  color: #ffffff;
}

.footer-btn::after {
  border: none;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.34);
  z-index: 99;
}

.food-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 78vh;
  max-height: 78vh;
  display: flex;
  flex-direction: column;
  padding: 16rpx 20rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFDF7;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -18rpx 36rpx rgba(0, 0, 0, 0.14);
  box-sizing: border-box;
  transform: translateY(105%);
  transition: transform 0.22s ease;
  z-index: 100;
}

.food-drawer.visible {
  transform: translateY(0);
}

.drawer-handle {
  width: 88rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(138, 124, 96, 0.3);
  margin: 0 auto 18rpx;
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.drawer-header-main {
  flex: 1;
  min-width: 0;
}

.drawer-title {
  display: block;
  font-size: 34rpx;
  color: #333333;
  font-weight: 700;
}

.drawer-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8A7C60;
}

.drawer-close {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #FFF4CD;
  color: #8A4B00;
  font-size: 24rpx;
}

.drawer-body {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.notes-input.compact {
  min-height: 112rpx;
}

.food-option-source {
  align-self: center;
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #fff1cf;
  color: #b97800;
  font-size: 20rpx;
  line-height: 1;
}

.food-option-source.mine {
  background: #e5f6ec;
  color: #2e9e5b;
}

.food-option-source.recipe {
  background: #eee7ff;
  color: #7652b7;
}

.add-type-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  padding: 16rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #fffdf7;
  box-sizing: border-box;
  box-shadow: 0 -18rpx 36rpx rgba(0, 0, 0, 0.14);
  transform: translateY(105%);
  transition: transform 0.22s ease;
}

.add-type-sheet.visible {
  transform: translateY(0);
}

.add-type-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.add-type-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 142rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  border-radius: 22rpx;
  background: #fff7e3;
  box-sizing: border-box;
}

.add-type-card.recipe {
  border-color: rgba(118, 82, 183, 0.18);
  background: #f8f4ff;
}

.add-type-icon {
  flex-shrink: 0;
  font-size: 48rpx;
}

.add-type-main {
  flex: 1;
  min-width: 0;
}

.add-type-title,
.add-type-copy {
  display: block;
}

.add-type-title {
  color: #333;
  font-size: 30rpx;
  font-weight: 700;
}

.add-type-copy {
  margin-top: 8rpx;
  color: #8a7c60;
  font-size: 23rpx;
  line-height: 1.5;
}

.add-type-arrow {
  flex-shrink: 0;
  color: #c78200;
  font-size: 42rpx;
}

.batch-body {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 0;
  overflow-y: auto;
  padding-bottom: 12rpx;
}

.batch-food-card {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.14);
}

.batch-food-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.batch-food-main {
  flex: 1;
  min-width: 0;
}

.batch-food-name {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 28rpx;
  color: #333333;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.batch-food-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #8A7C60;
}

.batch-preview {
  display: flex;
  gap: 18rpx;
  margin-top: 12rpx;
  font-size: 23rpx;
  color: #8A4B00;
}

.batch-actions {
  position: sticky;
  bottom: 0;
  z-index: 2;
  display: flex;
  gap: 14rpx;
  padding-top: 8rpx;
  background: #FFFDF7;
}

.edit-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  min-height: 0;
  overflow-y: auto;
  padding-bottom: 12rpx;
}

.selected-food-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #FFF7E3;
}

.selected-food-main {
  flex: 1;
  min-width: 0;
}

.selected-food-name {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.selected-food-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8A7C60;
}

.selected-food-switch {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #FFE8A0;
  color: #8A4B00;
  font-size: 24rpx;
}

.quantity-row {
  margin-bottom: 0;
}

/* 份量行：label 随文案宽度，输入框占满右侧剩余空间 */
.quantity-row .field-label {
  width: auto;
  max-width: 45%;
  white-space: nowrap;
}

.quantity-row .quantity-input {
  flex: 1 1 auto;
  min-width: 0;
}

.unit-text {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8A7C60;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  align-items: stretch;
}

.preview-grid-recipe {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.preview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 112rpx;
  padding: 18rpx 12rpx;
  border-radius: 16rpx;
  background: #FFF7E3;
  text-align: center;
  box-sizing: border-box;
}

.preview-value {
  display: block;
  width: 100%;
  font-size: 28rpx;
  line-height: 1.2;
  color: #333333;
  font-weight: 700;
}

.preview-label {
  display: block;
  width: 100%;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: #8A7C60;
}

.add-item-btn {
  position: sticky;
  bottom: 0;
  z-index: 2;
  width: 100%;
  height: 84rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 18rpx;
  border: none;
  background: #FFB800;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 -10rpx 18rpx rgba(255, 253, 247, 0.94), 0 8rpx 16rpx rgba(255, 184, 0, 0.2);
}

.add-item-btn.secondary {
  background: #FFF0BC;
  color: #8A4B00;
  box-shadow: none;
}

.add-item-btn::after {
  border: none;
}
