.v2-page {
  display: block;
  width: 100%;
}

.page {
  min-height: 100vh;
  padding: 18rpx 18rpx 200rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 216, 132, 0.22), transparent 36%),
    linear-gradient(180deg, #fffaf0 0%, #fff5e2 100%);
  box-sizing: border-box;
}

.section-card {
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.primary-card {
  padding: 22rpx;
  border: 1rpx solid rgba(214, 173, 92, 0.22);
  box-shadow: 0 10rpx 28rpx rgba(123, 84, 23, 0.08);
}

.secondary-card {
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(214, 173, 92, 0.12);
  box-shadow: 0 8rpx 20rpx rgba(123, 84, 23, 0.04);
}

.info-card {
  padding: 16rpx 18rpx;
}

.mix-card {
  background: linear-gradient(180deg, #fffef9 0%, #fff5df 100%);
}

.special-card {
  background: linear-gradient(180deg, #fffdf8 0%, #fff0e8 100%);
  border-color: rgba(225, 146, 101, 0.2);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.compact-panel-header {
  margin-bottom: 12rpx;
}

.panel-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.section-eyebrow {
  font-size: 18rpx;
  line-height: 1;
  letter-spacing: 1.5rpx;
  color: #c18b28;
}

.section-title {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #3f2a03;
}

.header-link {
  flex-shrink: 0;
  padding-top: 6rpx;
  color: #b87b12;
  font-size: 22rpx;
  line-height: 1;
}

.field-picker,
.field-input-shell {
  display: flex;
  align-items: center;
  min-height: 78rpx;
  border-radius: 18rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(214, 173, 92, 0.16);
}

.compact-picker {
  min-width: 152rpx;
  min-height: 66rpx;
  justify-content: center;
  padding: 0 18rpx;
  background: rgba(255, 247, 222, 0.96);
  font-size: 26rpx;
  color: #5d4310;
}

.recent-default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 4rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(214, 173, 92, 0.12);
}

.recent-default-text {
  flex: 1;
  min-width: 0;
  font-size: 19rpx;
  line-height: 1.4;
  color: #8d7344;
}

.recent-default-action {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 1;
  color: #b87b12;
}

.goal-entry-card {
  margin-bottom: 16rpx;
}

.goal-entry-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 173, 92, 0.14);
  box-shadow: 0 8rpx 20rpx rgba(123, 84, 23, 0.05);
}

.goal-entry-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.goal-entry-title {
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #4a3208;
}

.goal-entry-desc,
.component-meta {
  font-size: 18rpx;
  line-height: 1.4;
  color: #8d7344;
}

.goal-entry-arrow {
  flex-shrink: 0;
  color: #b87b12;
  font-size: 26rpx;
  line-height: 1;
}

.kind-switch {
  display: flex;
  gap: 10rpx;
}

.kind-switch.compact {
  margin-bottom: 4rpx;
}

.kind-chip {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 18rpx;
  background: rgba(255, 247, 222, 0.88);
  color: #7d632f;
  font-size: 23rpx;
}

.kind-chip.active {
  background: #ffb800;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.22);
}

.field-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.single-input-row {
  margin-bottom: 2rpx;
}

.field-block {
  flex: 1;
  min-width: 0;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 21rpx;
  color: #694d17;
}

.primary-input-shell {
  min-height: 82rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.field-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #2d220d;
}

.field-unit {
  margin-left: 8rpx;
  font-size: 21rpx;
  color: #8d7344;
}

.milk-entry-card,
.empty-state {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 248, 228, 0.78);
  border: 1rpx solid rgba(214, 173, 92, 0.12);
}

.milk-entry-card {
  background: rgba(255, 253, 247, 0.92);
  border-left-width: 6rpx;
  border-left-style: solid;
  border-left-color: rgba(214, 173, 92, 0.32);
}

.milk-entry-card--breast {
  background: linear-gradient(135deg, #fff7da 0%, #fffdf7 70%);
  border-left-color: #e0a52f;
}

.milk-entry-card--regular {
  background: linear-gradient(135deg, #eff8e0 0%, #fcfef8 70%);
  border-left-color: #5f8a1f;
}

.milk-entry-card--special {
  background: linear-gradient(135deg, #ebf2ff 0%, #f8fbff 70%);
  border-left-color: #4775c9;
}

.milk-entry-card--energy {
  background: linear-gradient(135deg, #fff3e2 0%, #fffcf6 70%);
  border-left-color: #b76a1b;
}

.milk-entry-card.just-added {
  animation: milkRowArrive 420ms cubic-bezier(0.22, 1, 0.36, 1);
}

.empty-state {
  color: #8d7344;
  font-size: 22rpx;
  text-align: center;
}

.milk-entry-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.component-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.component-name {
  color: #402d0d;
  font-size: 24rpx;
  font-weight: 600;
}

.powder-picker-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.remove-link {
  flex-shrink: 0;
  color: #c56a42;
  font-size: 20rpx;
}

.category-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 1rpx solid transparent;
  box-sizing: border-box;
  font-size: 22rpx;
  font-weight: 700;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.preview-grid-compact {
  margin-bottom: 0;
}

.preview-item {
  border-radius: 16rpx;
  padding: 12rpx;
  background: rgba(255, 248, 228, 0.88);
  box-sizing: border-box;
}

.compact-preview-item {
  padding: 12rpx 10rpx;
}

.preview-value {
  display: block;
  font-size: 25rpx;
  font-weight: 600;
  color: #402d0d;
}

.preview-label {
  display: block;
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #8d7344;
}

.notes-input {
  width: 100%;
  min-height: 116rpx;
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  background: rgba(255, 248, 228, 0.88);
  font-size: 23rpx;
  color: #2d220d;
}

.compact-notes-input {
  min-height: 108rpx;
}

.notes-card {
  margin-bottom: 12rpx;
}

.mode-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.mode-segment {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 228, 0.95);
  border: 1rpx solid rgba(214, 173, 92, 0.16);
}

.mode-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #8d7241;
}

.mode-chip.active {
  background: #ffffff;
  color: #5f4309;
  font-weight: 600;
  box-shadow: 0 5rpx 14rpx rgba(123, 84, 23, 0.08);
}

.dual-field-group {
  display: flex;
  flex-direction: column;
}

.dual-label-row {
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.dual-label-row .field-label {
  margin-bottom: 0;
}

.dual-label-block,
.dual-input-shell {
  flex: 1;
  min-width: 0;
}

.dual-field-row {
  gap: 12rpx;
}

.dual-input-row {
  align-items: center;
  justify-content: flex-start;
}

.link-arrow,
.link-arrow-spacer {
  flex: 0 0 32rpx;
}

.link-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
}

.link-arrow-hidden {
  opacity: 0;
}

.link-arrow-text {
  font-size: 24rpx;
  line-height: 1;
  color: rgba(141, 115, 68, 0.62);
}

.dialog-field-block {
  margin-bottom: 16rpx;
}

.picker-input-shell {
  gap: 12rpx;
}

.picker-text {
  color: #2d220d;
  font-size: 24rpx;
}

.add-milk-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 68rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  background: rgba(255, 247, 222, 0.95);
  color: #7d632f;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(214, 173, 92, 0.16);
}

.add-milk-dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx 18rpx;
  box-sizing: border-box;
  background: rgba(55, 40, 17, 0.36);
}

.add-milk-dialog-panel {
  width: 100%;
  max-width: 720rpx;
  max-height: 84vh;
  overflow-y: auto;
  padding: 24rpx 22rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffdf7 0%, #fff7e7 100%);
  box-shadow: 0 18rpx 42rpx rgba(70, 49, 16, 0.18);
  box-sizing: border-box;
  animation: addMilkDialogIn 220ms cubic-bezier(0.22, 1, 0.36, 1);
}

.add-milk-dialog-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.add-milk-dialog-title {
  font-size: 28rpx;
}

.add-milk-dialog-close {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 1;
  color: #b87b12;
  padding-top: 6rpx;
}

.add-milk-hint {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 1.4;
  color: #8d7344;
}

.add-milk-options {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.add-milk-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 248, 228, 0.68);
  border: 1rpx solid rgba(214, 173, 92, 0.1);
}

.add-milk-option-source {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.add-milk-option.selected {
  background: rgba(255, 239, 188, 0.92);
  border-color: rgba(214, 173, 92, 0.28);
}

.add-milk-option-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.add-milk-option-title {
  font-size: 23rpx;
  color: #402d0d;
  font-weight: 600;
}

.add-milk-option-subtitle,
.add-milk-check {
  font-size: 18rpx;
  color: #8d7344;
}

.add-milk-check {
  flex-shrink: 0;
}

@keyframes addMilkDialogIn {
  0% {
    opacity: 0;
    transform: translate3d(0, 28rpx, 0);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

.milk-fly-ghost {
  position: fixed;
  z-index: 70;
  pointer-events: none;
  will-change: transform;
}

.milk-fly-content {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx 12rpx 12rpx;
  border-radius: 999rpx;
  background: #ffd56a;
  color: #6a4603;
}

.milk-fly-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  color: #b87b12;
  font-size: 20rpx;
  font-weight: 700;
}

.milk-fly-text {
  font-size: 22rpx;
  font-weight: 700;
}

@keyframes milkRowArrive {
  0% {
    opacity: 0.72;
    transform: translate3d(0, -10rpx, 0);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@media (prefers-reduced-motion: reduce) {
  .add-milk-dialog-panel,
  .milk-fly-ghost,
  .milk-entry-card.just-added {
    animation-duration: 0.01ms;
    animation-iteration-count: 1;
  }
}

.footer-bar {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 36rpx;
  display: flex;
  gap: 12rpx;
  z-index: 20;
}

.footer-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  border: none;
}

.footer-btn::after {
  border: none;
}

.footer-btn.cancel {
  background: rgba(255, 255, 255, 0.95);
  color: #7a5f21;
}

.footer-btn.confirm {
  background: linear-gradient(135deg, #ffbe2f 0%, #f2a400 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.24);
}
