.planner-page {
  min-height: 100vh;
  padding: 20rpx 20rpx 190rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 86% 3%, rgba(255, 211, 92, 0.32), transparent 32%),
    radial-gradient(circle at 12% 18%, rgba(255, 244, 180, 0.62), transparent 26%),
    linear-gradient(180deg, #fffaf0 0%, #fff2d9 55%, #fff8ec 100%);
}

.planner-hero {
  position: relative;
  overflow: hidden;
  min-height: 198rpx;
  padding: 34rpx 28rpx;
  border-radius: 34rpx;
  background:
    linear-gradient(135deg, rgba(255, 245, 207, 0.98) 0%, rgba(255, 224, 128, 0.82) 100%);
  box-shadow: 0 18rpx 34rpx rgba(139, 91, 15, 0.12);
  border: 1rpx solid rgba(209, 157, 44, 0.18);
}

.hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  max-width: 560rpx;
}

.hero-eyebrow,
.section-kicker {
  font-size: 20rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  color: #b47a10;
}

.hero-title {
  max-width: 510rpx;
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #422b02;
}

.hero-desc {
  font-size: 23rpx;
  line-height: 1.55;
  color: #765624;
}

.lemon-orbit {
  position: absolute;
  right: -24rpx;
  top: -18rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 999rpx;
  border: 2rpx dashed rgba(255, 180, 0, 0.34);
  transform: rotate(-18deg);
}

.lemon-dot {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 44rpx 44rpx 44rpx 16rpx;
  background: #ffd33d;
  box-shadow: inset -10rpx -8rpx 0 rgba(231, 167, 0, 0.24);
}

.dot-a {
  left: 24rpx;
  top: 18rpx;
}

.dot-b {
  right: 18rpx;
  bottom: 34rpx;
  width: 48rpx;
  height: 48rpx;
}

.dot-c {
  left: 58rpx;
  bottom: -14rpx;
  width: 34rpx;
  height: 34rpx;
}

.goal-card {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(214, 173, 92, 0.13);
  box-shadow: 0 8rpx 20rpx rgba(123, 84, 23, 0.05);
}

.goal-card.natural {
  background: #fffdfa;
}

.goal-card.special {
  background: #fff7f0;
}

.goal-card.energy {
  background: #fff9dc;
}

.goal-card.done {
  opacity: 0.74;
}

.goal-label,
.goal-sub,
.section-tip,
.source-remain,
.plan-group-help,
.nutrition-line {
  font-size: 20rpx;
  line-height: 1.35;
  color: #8a6a34;
}

.goal-value {
  display: block;
  margin: 8rpx 0 4rpx;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #4a3208;
}

.section-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 173, 92, 0.14);
  box-shadow: 0 12rpx 30rpx rgba(123, 84, 23, 0.07);
  box-sizing: border-box;
}

.chooser-card {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 252, 242, 0.96) 100%);
}

.mode-card {
  margin-top: 18rpx;
}

.mode-switch {
  display: flex;
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(255, 246, 218, 0.9);
}

.mode-tab {
  flex: 1;
  min-height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: #7d632f;
  font-size: 24rpx;
  font-weight: 700;
}

.mode-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #ffbd1f 0%, #ffa41f 100%);
  box-shadow: 0 8rpx 18rpx rgba(255, 164, 31, 0.24);
}

.coefficient-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.coefficient-grid.single .coefficient-field {
  flex: none;
  width: 100%;
}

.coefficient-field {
  flex: 1;
  min-width: 0;
}

.recommend-card {
  margin-top: 18rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 247, 219, 0.98) 100%);
  border-color: rgba(255, 184, 0, 0.22);
}

.plan-card {
  background:
    linear-gradient(180deg, rgba(255, 253, 246, 0.98) 0%, rgba(255, 248, 226, 0.96) 100%);
}

.section-header,
.source-group-head,
.plan-group-head,
.plan-item-head,
.plan-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #3f2a03;
}

.source-group,
.plan-group {
  margin-top: 22rpx;
}

.source-title,
.plan-group-title {
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #4a3208;
}

.source-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.source-option-card {
  padding: 10rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 231, 0.58);
}

.source-option-card.selected {
  background: rgba(255, 237, 176, 0.7);
}

.source-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
  padding: 12rpx 14rpx;
  border-radius: 999rpx;
  background: #fff8e7;
  border: 1rpx solid rgba(214, 173, 92, 0.14);
  color: #5f4413;
}

.source-chip.selected {
  background: #ffcf4f;
  border-color: #efb21e;
  box-shadow: 0 8rpx 18rpx rgba(255, 184, 0, 0.18);
}

.source-name {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
}

.source-check {
  min-width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  color: #8b6409;
}

.allocation-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 10rpx;
  padding: 0 4rpx 2rpx 52rpx;
}

.allocation-label {
  color: #8a6a34;
  font-size: 21rpx;
}

.allocation-input-shell {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  width: 150rpx;
  min-height: 58rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(214, 173, 92, 0.2);
  box-sizing: border-box;
}

.allocation-input {
  flex: 1;
  min-width: 0;
  height: 52rpx;
  text-align: right;
  font-size: 26rpx;
  color: #3f2a03;
}

.category-badge {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 14rpx;
  border: 1rpx solid transparent;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.source-empty,
.plan-empty {
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 247, 222, 0.82);
  color: #957441;
  font-size: 22rpx;
}

.summary-bubble {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.summary-pill {
  flex: 1;
  min-width: 0;
  padding: 16rpx 12rpx;
  border-radius: 22rpx;
  background: #fff8e1;
  text-align: center;
}

.summary-pill.primary {
  background: #ffcf4f;
  box-shadow: inset 0 -8rpx 0 rgba(210, 143, 0, 0.12);
}

.summary-value {
  display: block;
  font-size: 32rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #4a3208;
}

.summary-label {
  display: block;
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #8a6a34;
}

.detail-panel {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.recommend-empty {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 226, 0.86);
  color: #876536;
  font-size: 23rpx;
  line-height: 1.45;
}

.plan-item {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fffefa;
  border: 1rpx solid rgba(214, 173, 92, 0.12);
}

.plan-item.manual {
  background: #fff7e5;
  border-color: rgba(255, 184, 0, 0.34);
}

.plan-name-row {
  justify-content: flex-start;
  min-width: 0;
}

.plan-name {
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 25rpx;
  font-weight: 700;
  color: #4a3208;
}

.manual-chip,
.auto-chip {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  line-height: 1;
}

.manual-chip {
  background: #ffdf8a;
  color: #7a4e00;
}

.auto-chip {
  background: #eef8df;
  color: #5b7621;
}

.plan-fields {
  display: flex;
  gap: 14rpx;
  align-items: flex-end;
  margin-top: 16rpx;
}

.plan-fields.dual .plan-field {
  flex: 1;
  min-width: 0;
}

.plan-field {
  flex: 1;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 20rpx;
  color: #866532;
}

.field-input-shell {
  display: flex;
  align-items: center;
  min-height: 72rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 173, 92, 0.2);
  box-sizing: border-box;
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 28rpx;
  color: #3f2a03;
}

.field-unit {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8a6a34;
}

.link-mark {
  flex-shrink: 0;
  padding-bottom: 18rpx;
  color: #c88d16;
  font-size: 24rpx;
}

.nutrition-line {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 12rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 14rpx;
  padding: 18rpx 22rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 250, 240, 0.96);
  box-shadow: 0 -10rpx 28rpx rgba(123, 84, 23, 0.08);
  box-sizing: border-box;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
}

.footer-btn::after {
  border: none;
}

.footer-btn.ghost {
  background: #fff3d9;
  color: #78550d;
}

.footer-btn.primary {
  background: linear-gradient(135deg, #ffbd1f 0%, #ff9f1c 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(255, 159, 28, 0.26);
}
