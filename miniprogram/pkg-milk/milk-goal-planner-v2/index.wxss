.planner-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 88% 2%, rgba(255, 211, 92, 0.3), transparent 30%),
    radial-gradient(circle at 10% 16%, rgba(255, 244, 180, 0.55), transparent 24%),
    linear-gradient(180deg, #fffaf0 0%, #fff3da 55%, #fff8ec 100%);
}

/* 维度切换 */
.mode-switch {
  display: flex;
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 26rpx;
  background: rgba(255, 246, 218, 0.95);
  box-shadow: inset 0 0 0 1rpx rgba(214, 173, 92, 0.16);
}

.mode-tab {
  flex: 1;
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #7d632f;
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tab.active {
  color: #4a3208;
  background: linear-gradient(135deg, #ffe45e 0%, #ffcf3d 100%);
  box-shadow: 0 8rpx 18rpx rgba(255, 184, 0, 0.28);
}

/* 热量维度：天然优先 / 特殊优先 子切换 */
.priority-switch {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 6rpx;
  border-radius: 20rpx;
  background: rgba(255, 250, 235, 0.95);
  box-shadow: inset 0 0 0 1rpx rgba(214, 173, 92, 0.14);
}

.priority-tab {
  flex: 1;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #8a7038;
  font-size: 24rpx;
  font-weight: 600;
}

.priority-tab.active {
  color: #4a3208;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.18);
}

/* 卡片通用 */
.info-card,
.result-card,
.meal-card,
.detail-card,
.source-card {
  margin-top: 20rpx;
  padding: 26rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(214, 173, 92, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(123, 84, 23, 0.07);
  box-sizing: border-box;
}

/* 基础信息 */
.info-card {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 20rpx;
  align-items: flex-end;
}

.info-cell {
  flex: 1;
  min-width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.weight-cell {
  flex-basis: 100%;
}

.info-label {
  font-size: 22rpx;
  color: #8a6a34;
}

.info-input-shell {
  display: flex;
  align-items: center;
  min-height: 68rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  background: #fffdf6;
  border: 1rpx solid rgba(214, 173, 92, 0.24);
  box-sizing: border-box;
}

.info-input {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #3f2a03;
}

.info-suffix {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8a6a34;
}

.coef-target-hint {
  align-self: flex-start;
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff2cd;
  color: #9a6c0c;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.2;
  box-sizing: border-box;
}

.weight-show {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.weight-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #3f2a03;
  line-height: 1;
}

.weight-unit {
  font-size: 22rpx;
  color: #8a6a34;
}

.weight-edit {
  margin-left: 14rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1c9;
  color: #9a6c0c;
  font-size: 22rpx;
}

.weight-edit-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.weight-edit-row .info-input {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  min-height: 68rpx;
  border-radius: 18rpx;
  background: #fffdf6;
  border: 1rpx solid rgba(214, 173, 92, 0.24);
  box-sizing: border-box;
}

.weight-action {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.weight-action.confirm {
  background: linear-gradient(135deg, #ffcf3d 0%, #ffb01c 100%);
  color: #4a3208;
}

.weight-action.cancel {
  background: #fff3d9;
  color: #78550d;
}

/* 核心结果 */
.result-card {
  background: linear-gradient(160deg, #fff3b0 0%, #ffe066 100%);
  border-color: rgba(255, 184, 0, 0.3);
  box-shadow: 0 16rpx 34rpx rgba(214, 143, 0, 0.18);
}

.result-spark {
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #7a5408;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-head .result-spark {
  text-align: left;
}

.result-source-btn {
  flex: none;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #8a5a05;
  background: rgba(255, 213, 102, 0.4);
  border: 1rpx solid rgba(214, 173, 92, 0.5);
}

.result-source-current {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #a78a52;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx dashed rgba(160, 110, 10, 0.22);
}

.result-row:last-of-type {
  border-bottom: none;
  padding-bottom: 0;
}

.result-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.result-name-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.result-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f2a03;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-sub {
  font-size: 21rpx;
  color: #8a6510;
}

.result-amount {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.result-number {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 800;
  color: #3a2702;
}

.result-ml {
  font-size: 24rpx;
  font-weight: 700;
  color: #6b4a08;
}

.result-total {
  margin: 20rpx auto 0;
  width: fit-content;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 10rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(214, 173, 92, 0.35);
}

.result-total-label {
  font-size: 22rpx;
  color: #7a5408;
}

.result-total-number {
  font-size: 32rpx;
  font-weight: 800;
  color: #3a2702;
}

.result-total-unit {
  font-size: 22rpx;
  font-weight: 700;
  color: #6b4a08;
}

.result-hint {
  margin-top: 22rpx;
  text-align: center;
  font-size: 27rpx;
  font-weight: 700;
  color: #9a6c0c;
}

.result-hint.done {
  color: #3f7a1f;
}

.result-calorie {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(154, 108, 12, 0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.result-calorie-label {
  font-size: 22rpx;
  color: #9a6c0c;
}

.result-calorie-value {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.result-calorie-number {
  font-size: 38rpx;
  font-weight: 800;
  color: #c2570a;
}

.result-calorie-unit {
  font-size: 22rpx;
  color: #7a5408;
}

.result-calorie-total {
  font-size: 20rpx;
  color: #a78a52;
}

.result-protein {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(154, 108, 12, 0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.result-protein-values {
  display: flex;
  gap: 36rpx;
}

.result-protein-item {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.result-protein-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #7a5408;
}

/* 分顿建议 */
.meal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meal-title {
  font-size: 27rpx;
  font-weight: 800;
  color: #3f2a03;
}

.meal-stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meal-label {
  font-size: 24rpx;
  color: #8a6a34;
}

.stepper-btn {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #fff1c9;
  color: #9a6c0c;
  font-size: 32rpx;
  font-weight: 700;
}

.stepper-value {
  min-width: 44rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #3f2a03;
}

.meal-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #b08a4a;
}

.meal-note {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8a6a34;
}

.meal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 226, 0.7);
}

.meal-row-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.meal-row-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #4a3208;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meal-row-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.meal-row-volume {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.meal-row-volume-prefix {
  font-size: 21rpx;
  color: #8a6a34;
}

.meal-row-volume-number {
  font-size: 32rpx;
  font-weight: 800;
  color: #3a2702;
}

.meal-row-powder {
  font-size: 22rpx;
  color: #8a6510;
}

.meal-empty {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #957441;
  line-height: 1.5;
}

/* 计算依据 */
.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-title {
  font-size: 27rpx;
  font-weight: 800;
  color: #3f2a03;
}

.detail-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #9a7c45;
}

.detail-arrow {
  font-size: 36rpx;
  color: #b47a10;
  transition: transform 0.2s ease;
}

.detail-arrow.open {
  transform: rotate(180deg);
}

.detail-body {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-item {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 248, 226, 0.62);
}

.detail-item-title {
  font-size: 25rpx;
  font-weight: 700;
  color: #4a3208;
}

.detail-item-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
  margin-top: 8rpx;
}

.detail-stat {
  font-size: 22rpx;
  color: #8a6a34;
}

.detail-stat.strong {
  font-weight: 700;
  color: #4a3208;
}

.detail-stat.done {
  color: #3f7a1f;
}

.detail-breakdown {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #a78a52;
}

.detail-intake {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(214, 173, 92, 0.3);
}

.detail-intake-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #6b4a08;
}

.detail-intake-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.detail-intake-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #4a3208;
}

.detail-intake-values {
  display: flex;
  gap: 20rpx;
}

.detail-intake-value {
  font-size: 21rpx;
  color: #8a6a34;
}

/* 奶粉来源弹窗 */
.source-popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(40, 26, 4, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 50;
}

.source-popup {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #fffdf7;
  border-radius: 30rpx 30rpx 0 0;
  box-shadow: 0 -10rpx 30rpx rgba(123, 84, 23, 0.12);
}

.source-popup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.source-popup-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx;
  margin-bottom: 14rpx;
  border-radius: 16rpx;
  background: #fff6e0;
  border: 1rpx dashed rgba(214, 173, 92, 0.6);
}

.source-popup-tip-text {
  font-size: 22rpx;
  color: #8a7240;
}

.source-popup-tip-link {
  flex: none;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #8a5a05;
  background: rgba(255, 213, 102, 0.55);
  border: 1rpx solid rgba(214, 173, 92, 0.5);
}

.source-popup-body {
  max-height: 56vh;
}

.source-popup-done {
  margin-top: 22rpx;
  background: linear-gradient(135deg, #ffd766, #ffb84d);
  color: #5a3c02;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 999rpx;
  border: none;
}

/* 奶粉来源 */
.source-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.source-card-title {
  font-size: 27rpx;
  font-weight: 800;
  color: #3f2a03;
}

.multi-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff3d9;
}

.multi-toggle.on {
  background: #ffcf4f;
}

.multi-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #d6ad5c;
}

.multi-toggle.on .multi-dot {
  background: #4a3208;
}

.multi-text {
  font-size: 22rpx;
  color: #7a5408;
}

.source-group {
  margin-top: 18rpx;
}

.source-group-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 226, 0.62);
}

.source-group-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.source-group-label {
  font-size: 25rpx;
  font-weight: 700;
  color: #4a3208;
}

.source-group-selected {
  font-size: 24rpx;
  color: #9a6c0c;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-switch {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #c88d16;
  font-weight: 700;
}

.source-switch.muted {
  color: #b6a06f;
  font-weight: 400;
}

.source-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.source-option {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #fff8e7;
  border: 1rpx solid rgba(214, 173, 92, 0.16);
}

.source-option.selected {
  background: #ffe9a8;
  border-color: #efb21e;
}

.source-option-name {
  flex: 1;
  min-width: 0;
  font-size: 25rpx;
  color: #4a3208;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-option-check {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
  color: #c8890a;
}

/* 类别角标 */
.result-badge {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 14rpx;
  border: 1rpx solid transparent;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

/* 底部 */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 250, 240, 0.96);
  box-shadow: 0 -10rpx 28rpx rgba(123, 84, 23, 0.08);
  box-sizing: border-box;
}

.footer-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ffcf3d 0%, #ffb01c 100%);
  color: #4a3208;
}

.footer-btn::after {
  border: none;
}
