.feeding-record {
  display: flex;
  flex-direction: column;
}

.feeding-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.feeding-time {
  font-size: 26rpx;
  color: #999999;
}

.feeding-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.feeding-detail {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  color: #555555;
}

.milk-summary-row {
  display: block;
  min-width: 0;
  margin-bottom: 4rpx;
}

.milk-summary {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: #D69A16;
  font-weight: 600;
  white-space: normal;
  word-break: break-all;
}

.milk-summary-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.milk-summary-chip {
  flex: 0 1 calc((100% - 10rpx) / 2);
  max-width: 100%;
  display: inline-flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 8rpx 12rpx 8rpx 8rpx;
  border-radius: 18rpx;
  background: #FFF8E5;
  border: 1rpx solid rgba(255, 184, 0, 0.24);
  box-sizing: border-box;
}

.milk-summary-badge {
  flex-shrink: 0;
  margin-top: 1rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.milk-summary-chip-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.milk-summary-name {
  max-width: 100%;
  font-size: 25rpx;
  line-height: 1.4;
  color: #6B4A12;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.milk-summary-amount {
  font-size: 23rpx;
  line-height: 1.4;
  color: #9A6A12;
}

.metric-row {
  display: flex;
  flex-wrap: wrap;
  row-gap: 8rpx;
  gap: 12rpx;
}

.metric-row {
  font-size: 24rpx;
}

.feeding-detail .divider {
  color: #DDDDDD;
}

.feeding-detail .detail {
  color: #555555;
}

.feeding-notes {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888888;
}
