.feeding-record {
  display: flex;
  flex-direction: column;
}

.feeding-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.feeding-time {
  font-size: 26rpx;
  color: #999999;
}

.feeding-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.feeding-detail {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  color: #555555;
}

.milk-summary-chip-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  margin-bottom: 6rpx;
}

.milk-summary-chip {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 8rpx;
  line-height: 1.45;
}

.milk-summary-badge {
  flex-shrink: 0;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.28);
  background: #FFF4C9;
  color: #8A5B12;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
  font-weight: 700;
}

.milk-summary-name {
  flex-shrink: 0;
  max-width: 220rpx;
  color: #D69A16;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.milk-summary-amount {
  min-width: 0;
  color: #8A7C60;
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.milk-summary-row {
  display: block;
  min-width: 0;
  margin-bottom: 4rpx;
}

.milk-summary {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: #D69A16;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-row {
  display: flex;
  flex-wrap: wrap;
  row-gap: 8rpx;
  gap: 12rpx;
}

.metric-row {
  font-size: 24rpx;
}

.feeding-detail .divider {
  color: #DDDDDD;
}

.feeding-detail .detail {
  color: #555555;
}

.feeding-notes {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888888;
}
