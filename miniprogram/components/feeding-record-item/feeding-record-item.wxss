.feeding-record {
  display: flex;
  flex-direction: column;
}

.feeding-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.feeding-time {
  font-size: 26rpx;
  color: #999999;
}

.feeding-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.feeding-detail {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  color: #555555;
}

.milk-summary-row {
  display: block;
  min-width: 0;
  margin-bottom: 4rpx;
}

.milk-summary {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: #D69A16;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-row {
  display: flex;
  flex-wrap: wrap;
  row-gap: 8rpx;
  gap: 12rpx;
}

.metric-row {
  font-size: 24rpx;
}

.feeding-detail .divider {
  color: #DDDDDD;
}

.feeding-detail .detail {
  color: #555555;
}

.feeding-notes {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888888;
}
