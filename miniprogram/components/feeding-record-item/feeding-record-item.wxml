<view class="feeding-record" bindtap="handleTap">
  <view class="feeding-header" wx:if="{{showHeader}}">
    <text class="feeding-time">{{timeText}}</text>
    <text class="feeding-label" wx:if="{{showLabel}}">{{label}}</text>
  </view>
  <view class="feeding-detail">
    <view class="milk-summary-row" wx:if="{{milkSummaryText}}">
      <text class="milk-summary">{{milkSummaryText}}</text>
    </view>
    <view class="metric-row">
      <block wx:for="{{metricItems}}" wx:key="index">
        <text class="detail">{{item.text}}</text>
        <text class="divider" wx:if="{{index < metricItems.length - 1}}">|</text>
      </block>
    </view>
    <view class="feeding-notes" wx:if="{{record.notes}}">
      备注: {{record.notes}}
    </view>
  </view>
</view>
