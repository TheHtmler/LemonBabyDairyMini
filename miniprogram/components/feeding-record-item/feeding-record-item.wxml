<view class="feeding-record" bindtap="handleTap">
  <view class="feeding-header" wx:if="{{showHeader}}">
    <text class="feeding-time">{{timeText}}</text>
    <text class="feeding-label" wx:if="{{showLabel}}">{{label}}</text>
  </view>
  <view class="feeding-detail">
    <view class="milk-summary-row" wx:if="{{milkSummaryItems.length > 0}}">
      <view class="milk-summary-chip-list">
        <view class="milk-summary-chip" wx:for="{{milkSummaryItems}}" wx:key="index">
          <text class="milk-summary-badge {{item.badgeClass}}" style="{{item.badgeStyle}}">{{item.badge}}</text>
          <view class="milk-summary-chip-copy">
            <text class="milk-summary-name">{{item.name}}</text>
            <text class="milk-summary-amount">{{item.amountText}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="milk-summary-row" wx:elif="{{milkSummaryText}}">
      <text class="milk-summary">{{milkSummaryText}}</text>
    </view>
    <view class="metric-row">
      <block wx:for="{{metricItems}}" wx:key="index">
        <text class="detail">{{item.text}}</text>
        <text class="divider" wx:if="{{index < metricItems.length - 1}}">|</text>
      </block>
    </view>
    <view class="feeding-notes" wx:if="{{record.notes}}">
      备注: {{record.notes}}
    </view>
  </view>
</view>
