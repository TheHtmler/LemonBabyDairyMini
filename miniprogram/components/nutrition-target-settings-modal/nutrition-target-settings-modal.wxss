.target-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0);
  pointer-events: none;
  transition: background 0.28s ease;
}

.target-modal-mask.show {
  background: rgba(55, 38, 0, 0.38);
  pointer-events: auto;
}

.target-modal-sheet {
  position: relative;
  width: 100%;
  max-width: 660rpx;
  max-height: 78vh;
  display: flex;
  flex-direction: column;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #FFFDF5 0%, #FFF7DE 100%);
  box-shadow: 0 24rpx 70rpx rgba(72, 47, 0, 0.24);
  opacity: 0;
  transform: translateY(20rpx) scale(0.96);
  transition: opacity 0.24s ease, transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
}

.target-modal-sheet.show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.sheet-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 32rpx 18rpx;
}

.sheet-title {
  display: block;
  color: #3f2a03;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 800;
}

.sheet-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #9c7427;
  font-size: 22rpx;
  line-height: 1.4;
}

.sheet-close {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #b07b00;
  background: rgba(255, 184, 0, 0.12);
  font-size: 23rpx;
  font-weight: 700;
}

.mode-tabs {
  display: flex;
  gap: 12rpx;
  margin: 0 32rpx 18rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 184, 0, 0.18);
}

.mode-tab {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #9c7427;
  font-size: 24rpx;
  font-weight: 800;
}

.mode-tab.active {
  color: #5c3900;
  background: linear-gradient(135deg, #FFE27A, #FFB800);
  box-shadow: 0 8rpx 16rpx rgba(255, 184, 0, 0.22);
}

.sheet-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 0 32rpx 8rpx;
}

.loading {
  padding: 48rpx 0;
  color: #9c7427;
  text-align: center;
  font-size: 24rpx;
}

.target-section {
  margin-bottom: 0;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid rgba(255, 184, 0, 0.38);
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.12);
}

.section-head {
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  color: #3f2a03;
  font-size: 28rpx;
  font-weight: 800;
}

.section-desc {
  display: block;
  margin-top: 6rpx;
  color: #9c7427;
  font-size: 21rpx;
  line-height: 1.35;
}

.field-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-top: 16rpx;
}

.field-main {
  flex: 1;
  min-width: 0;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #72551a;
  font-size: 23rpx;
  font-weight: 700;
}

.field-input {
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.18);
  color: #2f2106;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #c6b48d;
}

.field-unit {
  flex-shrink: 0;
  min-width: 110rpx;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 18rpx;
  background: rgba(255, 184, 0, 0.12);
  color: #8d650e;
  font-size: 23rpx;
  font-weight: 800;
}

.sheet-footer {
  display: flex;
  gap: 18rpx;
  padding: 16rpx 32rpx 24rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: normal;
  font-weight: 800;
  box-sizing: border-box;
}

.btn-cancel::after,
.btn-confirm::after {
  border: none;
}

.btn-cancel {
  color: #8d7344;
  background: #ffffff;
}

.btn-confirm {
  color: #5c3900;
  background: linear-gradient(135deg, #FFE27A, #FFB800);
  box-shadow: 0 12rpx 22rpx rgba(255, 184, 0, 0.25);
}
