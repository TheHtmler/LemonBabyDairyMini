.container {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 217, 128, 0.28), transparent 34%),
    linear-gradient(180deg, #fffaf0 0%, #fff4db 100%);
  box-sizing: border-box;
  padding-bottom: 140rpx;
}

.content {
  width: 100%;
}

.loading-card,
.report-archive-list,
.detail-summary-card,
.detail-indicators-card,
.trend-summary-card,
.trend-section,
.nutrition-window-card,
.doctor-summary-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(133, 93, 23, 0.08);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.page-header {
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #5f3d00;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7a5a24;
}

.loading-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #5f3d00;
}

.loading-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7b6441;
}

.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.quick-action,
.archive-card,
.detail-stat,
.nutrition-metric,
.trend-card,
.indicator-item,
.summary-item {
  border-radius: 22rpx;
  background: #fffaf0;
  border: 1rpx solid rgba(201, 136, 23, 0.1);
}

.quick-action {
  padding: 20rpx;
}

.quick-action.primary {
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  border-color: rgba(201, 136, 23, 0.28);
}

.quick-action-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #2c1d09;
}

.quick-action-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6e5a3f;
}

.report-type-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.type-tab {
  min-width: 150rpx;
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
}

.type-tab.active {
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  border-color: rgba(201, 136, 23, 0.3);
  box-shadow: 0 10rpx 24rpx rgba(201, 136, 23, 0.18);
}

.type-tab-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #5f3d00;
}

.type-tab-count {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(95, 61, 0, 0.08);
  font-size: 20rpx;
  color: #7b6441;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2c1d09;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #7b6441;
}

.summary-actions,
.window-badge {
  padding: 10rpx 16rpx;
  border-radius: 18rpx;
  background: #fff6db;
  color: #7a5a24;
  font-size: 20rpx;
}

.archive-empty {
  margin-top: 18rpx;
  padding: 28rpx 22rpx;
  border-radius: 22rpx;
  background: #fffaf0;
  border: 1rpx dashed rgba(201, 136, 23, 0.18);
}

.archive-empty-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #5f3d00;
}

.archive-empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7b6441;
}

.archive-card-list,
.indicator-list,
.summary-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.archive-card {
  padding: 20rpx;
}

.archive-card-head,
.archive-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.archive-card-date {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #2c1d09;
}

.archive-card-type {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7b6441;
}

.archive-status,
.status-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.archive-status.normal,
.status-tag.normal {
  background: rgba(63, 132, 90, 0.12);
  color: #2f7a4d;
}

.archive-status.abnormal,
.status-tag.high {
  background: rgba(214, 74, 54, 0.12);
  color: #b63f2e;
}

.status-tag.low {
  background: rgba(232, 144, 31, 0.14);
  color: #b36500;
}

.archive-card-body {
  margin-top: 14rpx;
}

.archive-key-summary,
.detail-stat-copy,
.summary-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: #4e3b1d;
}

.archive-card-footer {
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.archive-meta,
.indicator-abbr,
.indicator-range,
.nutrition-metric-label,
.trend-overlay,
.window-note,
.indicator-group-hint,
.detail-stat-label,
.trend-point-date {
  font-size: 20rpx;
  color: #8d7449;
}

.archive-meta.emphasize {
  color: #b57900;
  font-weight: 700;
}

.preview-topbar {
  margin-bottom: 16rpx;
}

.preview-back {
  display: inline-flex;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(95, 61, 0, 0.08);
  color: #5f3d00;
  font-size: 22rpx;
}

.detail-summary-grid,
.trend-summary-grid,
.nutrition-metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.detail-stat {
  padding: 18rpx;
}

.detail-stat.long {
  grid-column: 1 / -1;
}

.detail-stat-value,
.nutrition-metric-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5f3d00;
}

.detail-stat-value.warn {
  color: #b63f2e;
}

.trend-link-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.trend-link-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  color: #5f3d00;
  font-size: 22rpx;
  font-weight: 600;
}

.trend-link-chip.secondary {
  background: #fff6db;
}

.trend-card {
  padding: 18rpx;
  margin-top: 18rpx;
}

.trend-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.trend-title,
.indicator-group-title,
.indicator-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c1d09;
}

.trend-points {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 18rpx;
}

.trend-point {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.trend-point-value {
  font-size: 22rpx;
  font-weight: 600;
  color: #8d7449;
}

.trend-point-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d8b26d;
  box-shadow: 0 0 0 8rpx rgba(216, 178, 109, 0.16);
}

.trend-point.active .trend-point-dot {
  background: #ffb800;
  box-shadow: 0 0 0 10rpx rgba(255, 184, 0, 0.18);
}

.trend-point.active .trend-point-value {
  color: #5f3d00;
}

.nutrition-metric {
  padding: 18rpx;
}

.nutrition-metric-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 16rpx;
}

.nutrition-metric-unit {
  font-size: 20rpx;
  color: #8d7449;
}

.indicator-group + .indicator-group {
  margin-top: 18rpx;
}

.indicator-group-head {
  margin-top: 18rpx;
  margin-bottom: 12rpx;
}

.indicator-item {
  padding: 18rpx;
}

.indicator-main,
.indicator-values {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.indicator-main {
  align-items: flex-start;
}

.indicator-values {
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.indicator-current {
  font-size: 22rpx;
  font-weight: 600;
  color: #5f3d00;
}

.summary-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 16rpx 18rpx;
}

.summary-bullet {
  font-size: 26rpx;
  line-height: 1.4;
  color: #b57900;
}

.bottom-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.action-button {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-button.edit {
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  color: #5f3d00;
}

.action-button.delete {
  background: #fff1ed;
  color: #c1523b;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 700;
}
