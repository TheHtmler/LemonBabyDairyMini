page {
  background: #fff4db;
  min-height: 100%;
  height: 100%;
  box-sizing: border-box;
}

.container {
  width: 100%;
  min-height: 100vh;
  min-height: 100%;
  padding: 20rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top right, rgba(255, 217, 128, 0.28), transparent 34%),
    linear-gradient(180deg, #fffaf0 0%, #fff4db 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.main-view {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.loading-card {
  margin-top: 120rpx;
  text-align: center;
}

.loading-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #5f3d00;
}

.main-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 250, 240, 0.92);
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
  border-radius: 20rpx;
}

.main-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #8d7449;
}

.main-tab.active {
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  color: #2c1d09;
  box-shadow: 0 6rpx 16rpx rgba(201, 136, 23, 0.18);
}

.type-scroll {
  display: flex;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.type-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 56rpx;
  padding: 0 18rpx;
  margin-right: 10rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
  box-sizing: border-box;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  color: #6b5430;
}

.type-pill.active {
  background: #fff0c2;
  border-color: rgba(201, 136, 23, 0.28);
  color: #2c1d09;
}

.pill-count {
  font-size: 20rpx;
  opacity: 0.65;
}

.compare-panel,
.archive-panel {
  flex: 1;
  width: 100%;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.compare-panel {
  padding-bottom: 220rpx;
}

.year-section {
  margin-bottom: 20rpx;
}

.year-label {
  display: block;
  margin: 8rpx 0 12rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #2c1d09;
  letter-spacing: -0.03em;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd577 0%, #ffbf4d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  box-shadow: 0 12rpx 28rpx rgba(201, 136, 23, 0.32);
  z-index: 30;
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #2c1d09;
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
  transform: translateY(-2rpx);
}

.report-row {
  display: grid;
  grid-template-columns: 120rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
  border-radius: 24rpx;
}

.date-month {
  display: block;
  font-size: 20rpx;
  color: #8d7449;
  font-weight: 600;
}

.date-day {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #2c1d09;
  line-height: 1;
  letter-spacing: -0.04em;
}

.report-type {
  display: block;
  font-size: 22rpx;
  color: #8d7449;
  margin-bottom: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.metric-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #fffaf0;
  color: #4e3b1d;
}

.metric-tag.warn {
  background: rgba(214, 74, 54, 0.12);
  color: #b63f2e;
}

.report-status {
  justify-self: end;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}

.report-status.warn {
  background: rgba(214, 74, 54, 0.12);
  color: #b63f2e;
}

.report-status.ok {
  background: rgba(47, 122, 77, 0.12);
  color: #2f7a4d;
}

.empty-card {
  padding: 48rpx 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx dashed rgba(201, 136, 23, 0.2);
  border-radius: 24rpx;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #5f3d00;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d7449;
}

.step-label {
  display: block;
  margin: 8rpx 0 10rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: #8d7449;
  letter-spacing: 0.08em;
}

.diet-label {
  margin-top: 16rpx;
}

.diet-empty-hint {
  padding: 20rpx 18rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx dashed rgba(201, 136, 23, 0.18);
  font-size: 22rpx;
  line-height: 1.5;
  color: #8d7449;
}

.picker-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 8rpx;
}

.picker-swap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.22);
  box-shadow: 0 4rpx 12rpx rgba(201, 136, 23, 0.08);
}

.picker-swap:active {
  transform: scale(0.94);
  background: rgba(255, 248, 230, 0.98);
}

.picker-swap-icon {
  font-size: 30rpx;
  font-weight: 800;
  color: #c98817;
  line-height: 1;
}

.picker-box {
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
  border-radius: 18rpx;
  text-align: center;
}

.picker-cap {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #2c1d09;
}

.picker-val {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #8d7449;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.metric-chip {
  display: inline-flex;
  flex-direction: row;
  align-items: baseline;
  gap: 6rpx;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(201, 136, 23, 0.15);
  color: #6b5430;
}

.chip-name {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.chip-abbr {
  font-size: 18rpx;
  font-weight: 600;
  color: #8d7449;
  line-height: 1.2;
}

.metric-chip.on {
  background: #2c1d09;
  border-color: #2c1d09;
  color: #fff;
}

.metric-chip.on .chip-abbr {
  color: rgba(255, 255, 255, 0.72);
}

.compare-empty.inline-hint {
  margin-top: 12rpx;
  padding: 20rpx 24rpx;
}

.compare-empty.inline-hint .empty-desc {
  margin: 0;
}

.result-divider {
  height: 1rpx;
  background: rgba(201, 136, 23, 0.15);
  margin: 12rpx 0;
}

.compare-summary-card {
  padding: 16rpx 18rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
}

.compare-summary-line {
  display: block;
  font-size: 22rpx;
  line-height: 1.45;
  color: #5f3d00;
  font-weight: 600;
}

.compare-summary-line + .compare-summary-line {
  margin-top: 6rpx;
  color: #8d7449;
}

.range-mismatch-banner {
  padding: 16rpx 18rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: rgba(232, 144, 31, 0.12);
  border: 1rpx solid rgba(179, 101, 0, 0.18);
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a5200;
  font-weight: 600;
}

.compare-date-sticky {
  position: sticky;
  top: 12rpx;
  z-index: 8;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 0 0 12rpx;
  background: rgba(255, 244, 219, 0.96);
  backdrop-filter: blur(8rpx);
  border-bottom: 1rpx solid rgba(201, 136, 23, 0.12);
}

.compare-date-col {
  text-align: center;
  padding: 10rpx 8rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
}

.compare-date-col.left {
  border-color: rgba(245, 166, 35, 0.28);
}

.compare-date-col.right {
  border-color: rgba(90, 159, 212, 0.28);
}

.compare-date-val {
  font-size: 24rpx;
  font-weight: 800;
  color: #2c1d09;
  font-variant-numeric: tabular-nums;
}

.cmp-card {
  padding: 18rpx 20rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.1);
  border-radius: 18rpx;
}

.cmp-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.cmp-title {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
}

.cmp-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #2c1d09;
  line-height: 1.3;
}

.cmp-abbr-sub {
  font-size: 20rpx;
  font-weight: 600;
  color: #8d7449;
}

.cmp-values {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.cmp-side {
  padding: 14rpx 12rpx;
  border-radius: 14rpx;
  background: #fffaf0;
  text-align: center;
}

.cmp-value-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.cmp-side-val {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #2c1d09;
  font-variant-numeric: tabular-nums;
}

.cmp-unit {
  font-size: 18rpx;
  font-weight: 700;
  color: #8d7449;
}

.cmp-status {
  display: inline-flex;
  margin-top: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
}

.cmp-status.high {
  background: rgba(214, 74, 54, 0.12);
  color: #b63f2e;
}

.cmp-status.low {
  background: rgba(232, 144, 31, 0.14);
  color: #b36500;
}

.cmp-status.normal {
  background: rgba(63, 132, 90, 0.12);
  color: #2f7a4d;
}

.cmp-status.unknown {
  background: rgba(160, 110, 20, 0.1);
  color: #8d7449;
}

.cmp-side-range {
  display: block;
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #8d7449;
}

.cmp-chg {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.cmp-chg.up { color: #b63f2e; }
.cmp-chg.down { color: #2f7a4d; }

.cmp-range-warn {
  display: block;
  margin-top: 10rpx;
  font-size: 18rpx;
  color: #b36500;
  font-weight: 600;
}

.diet-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  margin: 14rpx 0 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(201, 136, 23, 0.14);
  box-shadow: 0 8rpx 18rpx rgba(201, 136, 23, 0.07);
}

.diet-entry-card:active {
  transform: scale(0.98);
}

.diet-entry-copy {
  flex: 1;
  min-width: 0;
}

.diet-entry-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #2c1d09;
}

.diet-entry-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #8d7449;
}

.diet-entry-action {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff0c2;
  color: #5f3d00;
  font-size: 20rpx;
  font-weight: 800;
}

.diet-summary-card {
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 250, 240, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.14);
}

.diet-summary-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #5f3d00;
}

.diet-summary-line {
  display: block;
  font-size: 21rpx;
  line-height: 1.45;
  color: #6b5430;
  font-weight: 600;
}

.diet-summary-line + .diet-summary-line {
  margin-top: 6rpx;
}

.trend-compare-block {
  padding: 16rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.1);
  border-radius: 20rpx;
}

.trend-compare-head {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.trend-compare-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #2c1d09;
}

.trend-compare-unit {
  font-size: 18rpx;
  color: #8d7449;
}

.trend-compare-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.trend-side {
  min-width: 0;
  padding: 12rpx 10rpx;
  border-radius: 14rpx;
  background: #fffaf0;
}

.trend-side-meta-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.trend-side-meta {
  flex: 1;
  min-width: 0;
  font-size: 16rpx;
  color: #8d7449;
}

.trend-side-avg {
  flex-shrink: 0;
  font-size: 16rpx;
  font-weight: 600;
  color: #6a5320;
  white-space: nowrap;
}

.trend-side-avg.alt {
  color: #3f6288;
}

.sparkline {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 128rpx;
}

.spark-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  height: 100%;
}

.spark-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  width: 100%;
  flex: 1;
  min-height: 72rpx;
}

.spark-val {
  margin-bottom: 4rpx;
  font-size: 14rpx;
  font-weight: 600;
  line-height: 1.1;
  color: #6a5320;
  white-space: nowrap;
}

.spark-val.alt {
  color: #3f6288;
}

.spark-bar {
  width: 100%;
  max-width: 20rpx;
  min-height: 8rpx;
  border-radius: 6rpx 6rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #ffbf4d 0%, #f5a623 100%);
}

.spark-bar.missing {
  background: rgba(160, 110, 20, 0.12);
}

.spark-bar.alt {
  background: linear-gradient(180deg, #8ec5ff 0%, #5a9fd4 100%);
}

.spark-bar.alt.missing {
  background: rgba(90, 159, 212, 0.12);
}

.spark-x {
  margin-top: 4rpx;
  font-size: 14rpx;
  color: #8d7449;
}

.report-type-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
}

.report-type-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fffaf0;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -8rpx 32rpx rgba(201, 136, 23, 0.12);
}

.report-type-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 16rpx auto 0;
  background: rgba(201, 136, 23, 0.2);
  border-radius: 4rpx;
}

.report-type-header {
  padding: 20rpx 32rpx 12rpx;
  text-align: center;
}

.report-type-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2c1d09;
}

.report-type-list {
  padding: 8rpx 24rpx 16rpx;
  overflow-y: auto;
}

.report-type-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.12);
  border-radius: 20rpx;
}

.report-type-item:active {
  background: #fff0c2;
}

.report-type-icon {
  font-size: 36rpx;
  line-height: 1;
}

.report-type-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c1d09;
}

.report-type-footer {
  padding: 12rpx 24rpx 24rpx;
}

.report-type-cancel {
  width: 100%;
  padding: 20rpx 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(201, 136, 23, 0.18);
  font-size: 28rpx;
  font-weight: 700;
  color: #8d7449;
  line-height: 1.2;
}

.report-type-cancel::after {
  border: none;
}
