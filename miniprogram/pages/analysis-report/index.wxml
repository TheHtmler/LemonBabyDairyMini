<view class="container">
  <view wx:if="{{loading}}" class="loading-card">
    <text class="loading-title">正在整理报告档案</text>
    <text class="loading-desc">会先读取同类报告，再把趋势和喂养区间串起来。</text>
  </view>

  <view wx:else class="content archive-page">
    <view wx:if="{{previewMode === 'archive'}}" class="archive-view">
      <view class="page-header">
        <text class="page-title">检测报告</text>
        <text class="page-subtitle">{{modeHint}}</text>
      </view>

      <view class="primary-entry" bindtap="onAddReport">
        <text class="primary-entry-title">新增报告</text>
        <text class="primary-entry-desc">{{selectedFilterType === 'all' ? '进入录入页' : '按当前分类进入录入'}}</text>
      </view>

      <view class="report-type-tabs">
        <view
          wx:for="{{reportTypeTabs}}"
          wx:key="key"
          class="type-tab {{item.active ? 'active' : ''}}"
          data-type="{{item.key}}"
          bindtap="handleTypeFilterChange"
        >
          <text class="type-tab-label">{{item.label}}</text>
          <text class="type-tab-count">{{item.count}}</text>
        </view>
      </view>

      <view wx:if="{{selectedFilterType !== 'all'}}" class="trend-entry-inline" bindtap="openTrendView">
        <view>
          <text class="trend-entry-title">查看本类趋势</text>
          <text class="trend-entry-desc">查看当前分类的连续变化</text>
        </view>
        <text class="trend-entry-arrow">></text>
      </view>

      <view class="report-archive-list">
        <view class="section-head">
          <text class="section-title">报告档案</text>
        </view>
        <view wx:if="{{archiveReportCards.length === 0}}" class="archive-empty">
          <text class="archive-empty-title">当前分类还没有报告</text>
          <text class="archive-empty-desc">先录入一份，再开始看趋势</text>
        </view>
        <view wx:else class="archive-card-list">
          <view
            wx:for="{{archiveReportCards}}"
            wx:key="reportId"
            class="archive-card"
            data-report-id="{{item.reportId}}"
            bindtap="openDetailView"
          >
            <text class="archive-card-date">{{item.formattedDate}}</text>
            <text class="archive-card-type">{{item.reportTypeLabel}}</text>
            <text class="archive-key-summary">{{item.keySummary}}</text>
            <view class="archive-card-status-row">
              <view class="archive-status {{item.abnormalCount > 0 ? 'abnormal' : 'normal'}}">
                <text>{{item.statusText}}</text>
              </view>
              <text class="archive-detail-link">查看详情</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{previewMode === 'detail' && currentDetailView}}" class="detail-view">
      <view class="preview-topbar">
        <view class="preview-back" bindtap="goBackToArchive">
          <text>← 返回档案</text>
        </view>
      </view>

      <view class="detail-summary-card">
        <view class="section-head">
          <view>
            <text class="section-title">{{currentDetailView.reportTypeLabel}}</text>
            <text class="section-subtitle">{{currentDetailView.reportDate}} · 查看这一份完整报告</text>
          </view>
          <view class="summary-actions" data-report-id="{{currentDetailView.reportId}}" bindtap="openTrendView">
            <text>查看本类趋势</text>
          </view>
        </view>
        <view class="detail-summary-grid">
          <view class="detail-stat">
            <text class="detail-stat-value">{{currentDetailView.summary.filledCount}}</text>
            <text class="detail-stat-label">已填写指标</text>
          </view>
          <view class="detail-stat">
            <text class="detail-stat-value warn">{{currentDetailView.summary.abnormalCount}}</text>
            <text class="detail-stat-label">异常项</text>
          </view>
          <view class="detail-stat long">
            <text class="detail-stat-label">关键摘要</text>
            <text class="detail-stat-copy">{{currentDetailView.keySummary}}</text>
          </view>
        </view>
      </view>

      <view class="detail-indicators-card">
        <view class="section-head">
          <view>
            <text class="section-title">完整指标区</text>
            <text class="section-subtitle">按报告类型分组展示这一份报告的完整指标。</text>
          </view>
        </view>
        <view wx:for="{{currentDetailView.indicatorGroups}}" wx:key="key" class="indicator-group">
          <view class="indicator-group-head">
            <text class="indicator-group-title">{{item.title}}</text>
            <text class="indicator-group-hint">{{item.hint}}</text>
          </view>
          <view class="indicator-list">
            <view wx:for="{{item.items}}" wx:key="key" wx:for-item="indicator" class="indicator-item">
              <view class="indicator-main">
                <view>
                  <text class="indicator-name">{{indicator.name}}</text>
                  <text class="indicator-abbr">{{indicator.abbr}}</text>
                </view>
                <text class="status-tag {{indicator.status}}">{{indicator.status === 'high' ? '偏高' : indicator.status === 'low' ? '偏低' : indicator.status === 'normal' ? '范围内' : '待补充'}}</text>
              </view>
              <view class="indicator-values">
                <text class="indicator-current">本次 {{indicator.current}}</text>
                <text wx:if="{{indicator.minRange || indicator.maxRange}}" class="indicator-range">参考 {{indicator.minRange || '--'}} - {{indicator.maxRange || '--'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="bottom-actions">
        <button class="action-button edit" bindtap="onEditReport">
          <text class="btn-text">编辑报告</text>
        </button>
        <button class="action-button delete" bindtap="onDeleteReport">
          <text class="btn-text">删除报告</text>
        </button>
      </view>
    </view>

    <view wx:if="{{previewMode === 'trend' && currentTrendView}}" class="trend-view">
      <view class="preview-topbar">
        <view class="preview-back" bindtap="goBackToArchive">
          <text>← 返回档案</text>
        </view>
      </view>

      <view class="trend-summary-card">
        <view class="section-head">
          <view>
            <text class="section-title">{{currentTrendView.reportTypeLabel}}趋势</text>
            <text class="section-subtitle">选中 {{currentTrendView.selectedReportDate}}，自动对比上一份同类报告。</text>
          </view>
        </view>
        <view class="trend-summary-grid">
          <view class="detail-stat">
            <text class="detail-stat-value">{{currentTrendView.reportCount}}</text>
            <text class="detail-stat-label">同类报告数</text>
          </view>
          <view class="detail-stat">
            <text class="detail-stat-value">{{currentTrendView.selectedReportDate}}</text>
            <text class="detail-stat-label">本次报告</text>
          </view>
          <view class="detail-stat">
            <text class="detail-stat-value">{{currentTrendView.previousReportDate || '--'}}</text>
            <text class="detail-stat-label">上次报告</text>
          </view>
        </view>
        <view class="trend-link-row">
          <view class="trend-link-chip" data-report-id="{{currentTrendView.detailLinks.currentReportId}}" bindtap="openReportDetailFromTrend">
            <text>查看本次详情</text>
          </view>
          <view wx:if="{{currentTrendView.detailLinks.previousReportId}}" class="trend-link-chip secondary" data-report-id="{{currentTrendView.detailLinks.previousReportId}}" bindtap="openReportDetailFromTrend">
            <text>查看上次详情</text>
          </view>
        </view>
      </view>

      <view class="trend-section">
        <view class="section-head">
          <view>
            <text class="section-title">同类指标趋势</text>
            <text class="section-subtitle">默认展示本类最核心的指标级趋势。</text>
          </view>
        </view>
        <view wx:for="{{currentTrendView.trendMetrics}}" wx:key="key" class="trend-card">
          <view class="trend-card-head">
            <text class="trend-title">{{item.name}}</text>
            <text class="trend-overlay">{{item.overlayLabel}}</text>
          </view>
          <view class="trend-points">
            <view wx:for="{{item.points}}" wx:key="date" class="trend-point {{point.active ? 'active' : ''}}" wx:for-item="point">
              <text class="trend-point-value">{{point.value}}</text>
              <view class="trend-point-dot"></view>
              <text class="trend-point-date">{{point.date}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:for="{{currentTrendView.nutritionWindows}}" wx:key="key" class="nutrition-window-card">
        <view class="section-head">
          <view>
            <text class="section-title">{{item.label}}</text>
            <text class="section-subtitle">{{item.dateRange}}</text>
          </view>
          <view class="window-badge">
            <text>{{item.badge}}</text>
          </view>
        </view>
        <view class="nutrition-metrics-grid">
          <view wx:for="{{item.metrics}}" wx:key="label" wx:for-item="metric" class="nutrition-metric">
            <text class="nutrition-metric-label">{{metric.label}}</text>
            <view class="nutrition-metric-value-row">
              <text class="nutrition-metric-value">{{metric.value}}</text>
              <text class="nutrition-metric-unit">{{metric.unit}}</text>
            </view>
          </view>
        </view>
        <text class="window-note">{{item.note}}</text>
      </view>

      <view class="doctor-summary-card">
        <view class="section-head">
          <view>
            <text class="section-title">区间对比摘要</text>
            <text class="section-subtitle">把同类趋势和这段时间的喂养背景串起来看。</text>
          </view>
        </view>
        <view class="summary-list">
          <view wx:for="{{currentTrendView.doctorSummary}}" wx:key="*this" class="summary-item">
            <text class="summary-bullet">•</text>
            <text class="summary-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
