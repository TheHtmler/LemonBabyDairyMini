<view class="container">
  <view wx:if="{{loading}}" class="loading-card">
    <text class="loading-title">正在整理报告</text>
  </view>

  <view wx:else class="main-view">
    <view class="main-tabs">
      <view class="main-tab {{mainTab === 'archive' ? 'active' : ''}}" data-tab="archive" bindtap="switchMainTab">
        <text>档案</text>
      </view>
      <view class="main-tab {{mainTab === 'compare' ? 'active' : ''}}" data-tab="compare" bindtap="switchMainTab">
        <text>对比</text>
      </view>
    </view>

    <view wx:if="{{mainTab === 'archive'}}" class="archive-panel">
      <scroll-view scroll-x class="type-scroll" enable-flex>
        <view
          wx:for="{{reportTypeTabs}}"
          wx:key="key"
          class="type-pill {{item.active ? 'active' : ''}}"
          data-type="{{item.key}}"
          bindtap="handleTypeFilterChange"
        >
          <text>{{item.label}}</text>
          <text class="pill-count">{{item.count}}</text>
        </view>
      </scroll-view>

      <view class="archive-list">
        <view wx:if="{{archiveYearGroups.length === 0}}" class="empty-card">
          <text class="empty-title">还没有报告</text>
          <text class="empty-desc">点右下角 ＋ 录入第一份</text>
        </view>
        <view wx:for="{{archiveYearGroups}}" wx:key="year" class="year-section">
          <text class="year-label">{{item.year}}</text>
          <view
            wx:for="{{item.reports}}"
            wx:key="reportId"
            wx:for-item="report"
            class="report-row"
            data-report-id="{{report.reportId}}"
            bindtap="openDetailView"
          >
            <view class="date-col">
              <text class="date-month">{{report.formattedMonth}}</text>
              <text class="date-day">{{report.formattedDay}}</text>
            </view>
            <view class="report-main">
              <text class="report-type">{{report.reportTypeLabel}}</text>
              <view class="tag-row">
                <text wx:for="{{report.keyTags}}" wx:key="key" wx:for-item="tag" class="metric-tag {{tag.abnormal ? 'warn' : ''}}">{{tag.text}}</text>
              </view>
            </view>
            <view class="status-dot {{report.abnormalCount > 0 ? 'warn' : 'ok'}}"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{mainTab === 'compare'}}" class="compare-panel">
      <scroll-view scroll-x class="type-scroll compare-types" enable-flex>
        <view
          wx:for="{{compareTypeTabs}}"
          wx:key="key"
          class="type-pill {{compareReportType === item.key ? 'active' : ''}}"
          data-type="{{item.key}}"
          bindtap="handleCompareTypeChange"
        >
          <text>{{item.label}}</text>
        </view>
      </scroll-view>

      <view wx:if="{{compareReportOptions.length < 2}}" class="empty-card compare-empty">
        <text class="empty-title">{{compareReportOptions.length === 1 ? '还需要一份同类报告' : '暂无足够报告'}}</text>
        <text class="empty-desc">录入至少两份 {{currentCompareView.reportTypeLabel || '同类'}} 报告后可对比</text>
      </view>

      <block wx:else>
        <text class="step-label">① 选报告</text>
        <view class="picker-row">
          <picker mode="selector" range="{{compareReportOptions}}" range-key="label" value="{{compareReportAIndex}}" bindchange="onCompareReportAChange">
            <view class="picker-box">
              <text class="picker-cap">{{compareReportOptions[compareReportAIndex].date}}</text>
              <text class="picker-val">报告 A · 点击切换 ▾</text>
            </view>
          </picker>
          <view class="picker-swap" bindtap="onSwapCompareReports" aria-role="button" aria-label="交换左右报告">
            <text class="picker-swap-icon">⇄</text>
          </view>
          <picker mode="selector" range="{{compareReportOptions}}" range-key="label" value="{{compareReportBIndex}}" bindchange="onCompareReportBChange">
            <view class="picker-box">
              <text class="picker-cap">{{compareReportOptions[compareReportBIndex].date}}</text>
              <text class="picker-val">报告 B · 点击切换 ▾</text>
            </view>
          </picker>
        </view>

        <view wx:if="{{!currentCompareView || !currentCompareView.canCompare}}" class="empty-card compare-empty inline-hint">
          <text class="empty-desc">请选择两份不同的报告</text>
        </view>

        <block wx:if="{{currentCompareView && currentCompareView.canCompare}}">

        <text class="step-label">② 选指标</text>
        <view class="chip-row">
          <view
            wx:for="{{currentCompareView.metricOptions}}"
            wx:key="key"
            class="metric-chip {{item.selected ? 'on' : ''}}"
            data-key="{{item.key}}"
            bindtap="toggleCompareMetric"
          >
            <text class="chip-name">{{item.name}}</text>
            <text wx:if="{{item.abbr && item.abbr !== item.name}}" class="chip-abbr">{{item.abbr}}</text>
          </view>
        </view>

        <view class="result-divider"></view>
        <text class="step-label">③ 结果</text>

        <view wx:if="{{currentCompareView.hasRangeMismatch}}" class="range-mismatch-banner">
          <text>{{currentCompareView.rangeMismatchText}}</text>
        </view>

        <view class="compare-date-sticky">
          <view class="compare-date-col left">
            <text class="compare-date-val">{{currentCompareView.reportA.date}}</text>
          </view>
          <view class="compare-date-col right">
            <text class="compare-date-val">{{currentCompareView.reportB.date}}</text>
          </view>
        </view>

        <view wx:for="{{currentCompareView.compareRows}}" wx:key="key" class="cmp-card">
          <view class="cmp-head">
            <view class="cmp-title">
              <text class="cmp-name">{{item.name}}</text>
              <text wx:if="{{item.abbr}}" class="cmp-abbr-sub">{{item.abbr}}</text>
            </view>
            <text class="cmp-chg {{item.direction === 'up' ? 'up' : item.direction === 'down' ? 'down' : ''}}">{{item.delta}}</text>
          </view>
          <view class="cmp-values">
            <view class="cmp-side">
              <text class="cmp-side-val">{{item.current}}</text>
              <text wx:if="{{item.rangeA}}" class="cmp-side-range">参考 {{item.rangeA}}</text>
            </view>
            <view class="cmp-side">
              <text class="cmp-side-val">{{item.previous}}</text>
              <text wx:if="{{item.rangeB}}" class="cmp-side-range">参考 {{item.rangeB}}</text>
            </view>
          </view>
          <text wx:if="{{item.rangeMismatch}}" class="cmp-range-warn">该指标参考范围不一致</text>
        </view>

        <text class="step-label diet-label">化验前 7 天 · 系数日趋势</text>
        <view wx:if="{{!currentCompareView.hasNutritionData}}" class="diet-empty-hint">
          <text>{{currentCompareView.nutritionEmptyText}}</text>
        </view>
        <view wx:for="{{currentCompareView.nutritionCompareSeries}}" wx:key="key" class="trend-compare-block">
          <view class="trend-compare-head">
            <text class="trend-compare-title">{{item.label}}</text>
            <text class="trend-compare-unit">{{item.unit}}</text>
          </view>
          <view class="trend-compare-row">
            <view class="trend-side">
              <view class="trend-side-meta-row">
                <text class="trend-side-meta">{{item.reportA.dateRangeShort}} · {{item.reportA.coverageText}}</text>
                <text wx:if="{{item.reportA.averageText}}" class="trend-side-avg">平均值: {{item.reportA.averageText}}</text>
              </view>
              <view class="sparkline">
                <view wx:for="{{item.reportA.points}}" wx:key="date" wx:for-item="point" class="spark-col">
                  <view class="spark-bar-wrap">
                    <text wx:if="{{!point.missing}}" class="spark-val">{{point.value}}</text>
                    <view class="spark-bar {{point.missing ? 'missing' : ''}}" style="height: {{point.heightRpx || 8}}rpx;"></view>
                  </view>
                  <text class="spark-x">{{point.label}}</text>
                </view>
              </view>
            </view>
            <view class="trend-side">
              <view class="trend-side-meta-row">
                <text class="trend-side-meta">{{item.reportB.dateRangeShort}} · {{item.reportB.coverageText}}</text>
                <text wx:if="{{item.reportB.averageText}}" class="trend-side-avg alt">平均值: {{item.reportB.averageText}}</text>
              </view>
              <view class="sparkline">
                <view wx:for="{{item.reportB.points}}" wx:key="date" wx:for-item="point" class="spark-col">
                  <view class="spark-bar-wrap">
                    <text wx:if="{{!point.missing}}" class="spark-val alt">{{point.value}}</text>
                    <view class="spark-bar alt {{point.missing ? 'missing' : ''}}" style="height: {{point.heightRpx || 8}}rpx;"></view>
                  </view>
                  <text class="spark-x">{{point.label}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        </block>
      </block>
    </view>
  </view>

  <view wx:if="{{!loading}}" class="fab" bindtap="onAddReport">
    <view class="fab-icon">+</view>
  </view>
</view>
