.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 180rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff7e4 0%, #fffdf7 100%);
}

.hero-card,
.recipe-card,
.recipe-empty,
.recipe-editor {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(255, 184, 0, 0.12);
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d2416;
}

.hero-subtitle {
  font-size: 24rpx;
  color: #8f7750;
}

.hero-action {
  margin: 0;
  padding: 0 24rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  background: #ffb800;
  color: #ffffff;
  font-size: 26rpx;
}

.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.recipe-card-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2416;
}

.recipe-note,
.recipe-meta,
.editor-subtitle,
.section-meta,
.draft-item-meta,
.food-option-meta {
  font-size: 24rpx;
  color: #8f7750;
}

.recipe-card-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.text-btn {
  font-size: 26rpx;
  color: #6d5a3c;
}

.text-btn.danger,
.draft-item-remove {
  color: #d35757;
}

.recipe-empty {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #8f7750;
  font-size: 26rpx;
}

.recipe-empty.compact {
  padding: 20rpx 0;
  box-shadow: none;
  background: transparent;
}

.editor-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.32);
}

.recipe-editor {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  max-height: 84vh;
  display: none;
  flex-direction: column;
  overflow: hidden;
}

.recipe-editor.visible {
  display: flex;
}

.editor-header,
.editor-footer,
.section-header,
.draft-item,
.food-option {
  display: flex;
  align-items: center;
}

.editor-header,
.editor-footer {
  justify-content: space-between;
  padding: 24rpx;
}

.editor-title,
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2416;
}

.editor-close {
  font-size: 26rpx;
  color: #8f7750;
}

.editor-body {
  padding: 0 24rpx 24rpx;
  overflow-y: auto;
}

.field-block,
.draft-item-section,
.food-picker-section {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #6d5a3c;
}

.field-input,
.field-textarea,
.draft-item-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 2rpx solid #f1e2ba;
  background: #fffaf0;
  color: #2d2416;
}

.field-input,
.draft-item-input {
  height: 76rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
}

.field-textarea {
  min-height: 120rpx;
  padding: 20rpx 22rpx;
  font-size: 28rpx;
}

.section-header {
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.draft-item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.draft-item,
.food-option {
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #fffaf0;
}

.draft-item-main,
.food-option-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.draft-item-name,
.food-option-name {
  font-size: 28rpx;
  color: #2d2416;
}

.draft-item-input {
  width: 160rpx;
  text-align: right;
}

.draft-item-unit {
  font-size: 24rpx;
  color: #8f7750;
}

.food-option-list {
  max-height: 320rpx;
}

.food-option-add {
  margin: 0;
  border-radius: 999rpx;
  background: #ffb800;
  color: #ffffff;
}

.footer-btn {
  flex: 1;
  margin: 0 8rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.footer-btn.cancel {
  background: #f4ead2;
  color: #6d5a3c;
}

.footer-btn.confirm {
  background: #ffb800;
  color: #ffffff;
}
