<view class="page">
  <view class="hero-card">
    <view class="hero-main">
      <text class="hero-title">食谱管理</text>
      <text class="hero-subtitle">把常用搭配保存起来，下次直接复用</text>
    </view>
    <button class="hero-action" bindtap="openCreateRecipe">新建食谱</button>
  </view>

  <view class="recipe-list" wx:if="{{recipes.length > 0}}">
    <view class="recipe-card" wx:for="{{recipes}}" wx:key="_id">
      <view class="recipe-card-main">
        <text class="recipe-name">{{item.name}}</text>
        <text class="recipe-note" wx:if="{{item.note}}">{{item.note}}</text>
        <text class="recipe-meta">{{item.items.length}} 种食物</text>
      </view>
      <view class="recipe-card-actions">
        <text class="text-btn" data-id="{{item._id}}" bindtap="openEditRecipe">编辑</text>
        <text class="text-btn danger" data-id="{{item._id}}" bindtap="deleteRecipe">删除</text>
      </view>
    </view>
  </view>

  <view class="recipe-empty" wx:if="{{recipes.length === 0}}">
    <text>还没有保存过食谱，先创建一个常用搭配吧。</text>
  </view>

  <view class="editor-mask" wx:if="{{showEditor}}" bindtap="closeEditor"></view>
  <view class="recipe-editor {{showEditor ? 'visible' : ''}}">
    <view class="editor-header">
      <view>
        <text class="editor-title">{{editingRecipeId ? '编辑食谱' : '新建食谱'}}</text>
        <text class="editor-subtitle">维护名称、备注和食材基准量</text>
      </view>
      <text class="editor-close" bindtap="closeEditor">关闭</text>
    </view>

    <view class="editor-body">
      <view class="field-block">
        <text class="field-label">食谱名称</text>
        <input
          class="field-input"
          value="{{formData.name}}"
          placeholder="请输入食谱名称"
          bindinput="onRecipeNameInput"
        />
      </view>

      <view class="field-block">
        <text class="field-label">备注</text>
        <textarea
          class="field-textarea"
          value="{{formData.note}}"
          placeholder="可选，记录这个食谱的说明"
          bindinput="onRecipeNoteInput"
        />
      </view>

      <view class="draft-item-section">
        <view class="section-header">
          <text class="section-title">已选食材</text>
          <text class="section-meta">{{formData.items.length}} 种</text>
        </view>

        <view class="draft-item-list" wx:if="{{formData.items.length > 0}}">
          <view class="draft-item" wx:for="{{formData.items}}" wx:key="foodId">
            <view class="draft-item-main">
              <text class="draft-item-name">{{item.nameSnapshot}}</text>
              <text class="draft-item-meta">{{item.category || '未分类'}} · {{item.unit}}</text>
            </view>
            <input
              class="draft-item-input"
              type="digit"
              value="{{item.quantity}}"
              placeholder="份量"
              data-index="{{index}}"
              bindinput="onDraftItemQuantityInput"
            />
            <text class="draft-item-unit">{{item.unit}}</text>
            <text class="draft-item-remove" data-index="{{index}}" bindtap="removeDraftItem">删除</text>
          </view>
        </view>

        <view class="recipe-empty compact" wx:if="{{formData.items.length === 0}}">
          <text>先从下方食物库挑选食材。</text>
        </view>
      </view>

      <view class="food-picker-section">
        <view class="section-header">
          <text class="section-title">食物库</text>
          <text class="section-meta">点“加入”添加到当前食谱</text>
        </view>

        <scroll-view class="food-option-list" scroll-y="true">
          <view class="food-option" wx:for="{{foodCatalog}}" wx:key="_id">
            <view class="food-option-main">
              <text class="food-option-name">{{item.name}}</text>
              <text class="food-option-meta">{{item.category || '未分类'}} · {{item.baseQuantity}}{{item.baseUnit || 'g'}}</text>
            </view>
            <button class="food-option-add" size="mini" data-id="{{item._id}}" bindtap="addFoodToDraft">加入</button>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="editor-footer">
      <button class="footer-btn cancel" bindtap="closeEditor">取消</button>
      <button class="footer-btn confirm" bindtap="saveRecipe">保存食谱</button>
    </view>
  </view>
</view>
