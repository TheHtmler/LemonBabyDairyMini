<view class="wrap">
  <view class="warn">⚠️ 临时迁移工具 · 上线前请删除本页面</view>

  <view class="status">{{statusText}}</view>

  <view class="field">
    <input class="input" placeholder="babyUid（可选，留空=全部宝宝）" value="{{babyUid}}" bindinput="onBabyUidInput" disabled="{{running}}" />
  </view>

  <view class="section-title">全量迁移（配奶 → 喂奶 → 成长）</view>
  <view class="btns">
    <button class="btn" bindtap="onInspect" disabled="{{running}}">诊断现状</button>
    <button class="btn" bindtap="onFullDryRun" disabled="{{running}}">全量预览(dry-run)</button>
    <button class="btn" type="warn" bindtap="onFullExecute" disabled="{{running}}">全量迁移(执行)</button>
  </view>

  <view class="section-title">维护（可选）</view>
  <view class="btns">
    <button class="btn mini" size="mini" bindtap="onRealign" disabled="{{running}}">对齐版本号</button>
    <button class="btn mini" size="mini" bindtap="onCleanup" disabled="{{running}}">清理迁移记录</button>
    <button class="btn mini" size="mini" type="warn" bindtap="onAbort" disabled="{{!running}}">停止</button>
  </view>

  <view class="section-title">执行日志</view>
  <scroll-view scroll-y class="logs" scroll-into-view="">
    <view wx:for="{{logs}}" wx:key="index" class="log-line">{{item}}</view>
    <view wx:if="{{logs.length === 0}}" class="log-empty">暂无日志</view>
  </scroll-view>
</view>
