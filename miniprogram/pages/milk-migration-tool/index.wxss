.wrap {
  padding: 24rpx;
  box-sizing: border-box;
}

.warn {
  background: #fff3cd;
  color: #8a6d00;
  border: 1rpx solid #ffe08a;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.status {
  font-size: 28rpx;
  color: #333;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 20rpx;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  background: #fff;
}

.section-title {
  font-size: 26rpx;
  color: #888;
  margin: 24rpx 0 12rpx;
}

.btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn {
  flex: 1;
  min-width: 200rpx;
  font-size: 28rpx;
}

.btn.mini {
  flex: none;
}

.logs {
  margin-top: 12rpx;
  height: 700rpx;
  background: #1e1e1e;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.log-line {
  font-size: 22rpx;
  color: #c8e6c9;
  line-height: 1.6;
  word-break: break-all;
  font-family: monospace;
}

.log-empty {
  font-size: 24rpx;
  color: #777;
}
