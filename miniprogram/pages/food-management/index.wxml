<view class="container">
  <view class="page-header">
    <text class="page-title">食物管理</text>
    <text class="page-subtitle">维护常用食物，记录时可快速选择</text>
  </view>

  <view class="manage-tabs">
    <view class="manage-tab {{activeManageTab === 'food' ? 'active' : ''}}" data-tab="food" bindtap="switchManageTab">食物库</view>
    <view class="manage-tab {{activeManageTab === 'combination' ? 'active' : ''}}" data-tab="combination" bindtap="switchManageTab">菜谱</view>
  </view>

  <view class="search-bar" wx:if="{{activeManageTab === 'food' && !loading && foods.length > 0}}">
    <view class="search-input-wrap">
      <text class="search-icon">搜索</text>
      <input
        class="search-input"
        placeholder="支持模糊搜索食物名、分类或别名"
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text class="search-clear" wx:if="{{searchQuery}}" bindtap="clearSearch">清空</text>
    </view>
    <view class="search-summary">
      <text>共 {{filteredFoodCount}} 种食物</text>
      <text wx:if="{{searchQuery}}">已按关键词筛选</text>
    </view>
  </view>

  <view class="loading" wx:if="{{activeManageTab === 'food' && loading}}">
    加载中...
  </view>

  <view class="food-layout" wx:if="{{activeManageTab === 'food' && !loading && groupedFoods.length > 0}}">
    <scroll-view
      class="category-sidebar"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{categoryNavScrollIntoView}}"
    >
      <block wx:for="{{groupedFoods}}" wx:key="category">
        <view
          id="{{item.navId}}"
          class="category-nav-item {{activeCategory === item.category ? 'active' : ''}}"
          data-category="{{item.category}}"
          bindtap="switchCategory"
        >
          <text class="category-nav-name">{{item.category}}</text>
          <text class="category-nav-count">{{item.items.length}}</text>
        </view>
      </block>
    </scroll-view>

    <scroll-view
      class="food-panel"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-top="{{foodPanelScrollTop}}"
    >
      <view class="food-panel-header">
        <text class="food-panel-title">{{activeCategory}}</text>
        <text class="food-panel-count">{{activeFoods.length}} 种</text>
      </view>
      <block wx:for="{{activeFoods}}" wx:key="_id">
        <view class="food-item">
          <view class="food-main">
            <view class="food-info">
              <view class="food-name">
                <text>{{item.name}}</text>
                <text class="food-tag system" wx:if="{{item.isSystem}}">系统预设</text>
                <text class="food-tag custom" wx:if="{{!item.isSystem}}">自定义</text>
              </view>
              <view class="food-unit">单位：{{item.baseUnit}} / {{item.baseQuantity}}</view>
              <view class="food-sub-category" wx:if="{{item.categoryLevel2}}">{{item.categoryLevel2}}</view>
            </view>
            <image
              class="food-cover"
              src="{{item.displayImage || foodPlaceholderImage}}"
              mode="aspectFill"
              data-url="{{item.displayImage || foodPlaceholderImage}}"
              bindtap="previewFoodImage"
            />
          </view>
          <view class="food-nutrition">
            <view class="nutrition-item">
              <text class="label">热量</text>
              <text class="value">{{item.nutritionPerUnit.calories || 0}} kcal</text>
            </view>
            <view class="nutrition-item">
              <text class="label">蛋白</text>
              <text class="value">{{item.nutritionPerUnit.protein || 0}} g</text>
            </view>
            <view class="nutrition-item">
              <text class="label">碳水</text>
              <text class="value">{{item.nutritionPerUnit.carbs || 0}} g</text>
            </view>
            <view class="nutrition-item">
              <text class="label">脂肪</text>
              <text class="value">{{item.nutritionPerUnit.fat || 0}} g</text>
            </view>
            <view class="nutrition-item">
              <text class="label">膳纤</text>
              <text class="value">{{item.nutritionPerUnit.fiber || 0}} g</text>
            </view>
            <view class="nutrition-item">
              <text class="label">钠</text>
              <text class="value">{{item.nutritionPerUnit.sodium || 0}} mg</text>
            </view>
          </view>
          <view class="food-actions" wx:if="{{!item.isSystem}}">
            <button
              class="action-btn edit"
              size="mini"
              data-id="{{item._id}}"
              bindtap="showEditModal"
              type="default"
            >
              编辑
            </button>
            <button
              class="action-btn delete"
              size="mini"
              data-id="{{item._id}}"
              data-name="{{item.name}}"
              bindtap="onDeleteFood"
              type="warn"
            >
              删除
            </button>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <view class="empty" wx:if="{{activeManageTab === 'food' && !loading && groupedFoods.length === 0}}">
    <text wx:if="{{searchQuery}}">没有匹配的食物，换个关键词试试</text>
    <text wx:else>还没有可用的食物，请点击下方按钮添加</text>
  </view>

  <view class="combination-panel" wx:if="{{activeManageTab === 'combination'}}">
    <view class="combination-panel-header">
      <view>
        <text class="combination-panel-title">菜谱</text>
        <text class="combination-panel-subtitle">维护常用搭配和默认份量</text>
      </view>
      <view class="combination-create-btn" bindtap="showCreateCombinationModal">新增菜谱</view>
    </view>
    <view class="loading" wx:if="{{combinationLoading}}">菜谱加载中...</view>
    <view class="empty" wx:elif="{{!combinationLoading && mealCombinations.length === 0}}">
      <text>还没有菜谱，可以在本顿食物页点击“保存当前为菜谱”，或使用上方入口新增。</text>
    </view>
    <scroll-view class="combination-list" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
      <view class="combination-card" wx:for="{{mealCombinations}}" wx:key="_id">
        <view class="combination-card-top">
          <view class="combination-badge">默认搭配</view>
          <view class="combination-actions">
            <button class="action-btn recipe-action edit" size="mini" data-id="{{item._id}}" bindtap="showCombinationEditModal" type="default">编辑</button>
            <button class="action-btn recipe-action delete" size="mini" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onDeleteMealCombination" type="default">删除</button>
          </view>
        </view>
        <view class="combination-card-header">
          <view class="combination-main">
            <text class="combination-name">{{item.name}}</text>
            <text class="combination-meta">保存常用搭配和每种食物的默认份量</text>
          </view>
        </view>
        <view class="combination-summary">
          共 {{item.items.length}} 种食物 · 使用 {{item.usageCount || 0}} 次
        </view>
        <view class="combination-nutrition">
          <view class="combination-nutrition-item">
            <text class="nutrition-value">{{item.nutritionSummary.calories || 0}}</text>
            <text class="nutrition-label">kcal</text>
          </view>
          <view class="combination-nutrition-item">
            <text class="nutrition-value">{{item.nutritionSummary.protein || 0}}</text>
            <text class="nutrition-label">蛋白 g</text>
          </view>
          <view class="combination-nutrition-item">
            <text class="nutrition-value">{{item.nutritionSummary.carbs || 0}}</text>
            <text class="nutrition-label">碳水 g</text>
          </view>
          <view class="combination-nutrition-item">
            <text class="nutrition-value">{{item.nutritionSummary.fat || 0}}</text>
            <text class="nutrition-label">脂肪 g</text>
          </view>
        </view>
        <view class="combination-foods">
          <view class="combination-food" wx:for="{{item.items}}" wx:for-item="foodItem" wx:key="foodId">
            <text class="combination-food-name">{{foodItem.foodName || foodItem.foodSnapshot.name}}</text>
            <text class="combination-food-quantity">{{foodItem.plannedQuantity}}{{foodItem.unit}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="add-btn" wx:if="{{babyUid && activeManageTab === 'food'}}" bindtap="showAddModal">
    <text class="add-icon">+</text>
  </view>

  <view class="modal" wx:if="{{showCombinationModal}}">
    <view class="modal-mask" bindtap="hideCombinationModal"></view>
    <view class="modal-content combination-modal-content">
      <view class="modal-header">
        <text class="modal-title">{{combinationModalStep === 'select' ? (combinationEditingId ? '选择菜谱食物' : '新增菜谱') : '设置食物份量'}}</text>
        <text class="modal-subtitle">{{combinationModalStep === 'select' ? '先连续选择食物，再统一填写份量' : '为每种食物填写默认准备量'}}</text>
      </view>
      <view class="modal-body">
        <view class="form-section">
          <view class="form-item">
            <text class="form-label">菜谱名称</text>
            <view class="form-control">
              <input class="input" placeholder="如：南瓜米粉午餐" value="{{combinationForm.name}}" bindinput="onCombinationFormNameInput" />
            </view>
          </view>
        </view>
        <view class="form-section" wx:if="{{combinationModalStep === 'select'}}">
          <view class="form-section-header">
            <text class="form-section-title">选择食物</text>
            <text class="form-section-subtitle">可一次选择多个食物，下一步再填份量</text>
          </view>
          <view class="combination-food-selector">
            <view class="combination-food-search">
              <input
                placeholder="搜索食物名称、分类或别名"
                value="{{combinationFoodSearchQuery}}"
                bindinput="onCombinationFoodSearchInput"
              />
            </view>
            <scroll-view class="combination-category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
              <view
                class="combination-category-chip {{combinationFoodCategory === item ? 'active' : ''}}"
                wx:for="{{combinationFoodCategories}}"
                wx:key="*this"
                data-category="{{item}}"
                bindtap="switchCombinationFoodCategory"
              >
                {{item}}
              </view>
            </scroll-view>
            <view class="combination-food-options">
              <view
                class="combination-food-option {{item.isInCombination ? 'selected' : ''}}"
                wx:for="{{filteredCombinationFoodOptions}}"
                wx:key="_id"
                data-id="{{item._id}}"
                bindtap="onCombinationFoodOptionTap"
              >
                <image class="combination-food-option-image" src="{{item.displayImage || foodPlaceholderImage}}" mode="aspectFill" />
                <view class="combination-food-option-main">
                  <text class="combination-food-option-name">{{item.name}}</text>
                  <text class="combination-food-option-meta">{{item.category || '未分类'}} · {{item.nutritionPerUnit.calories || 0}} kcal / {{item.baseQuantity || 100}}{{item.baseUnit || 'g'}}</text>
                </view>
                <view class="combination-food-option-action">{{item.isInCombination ? '已选' : '选择'}}</view>
              </view>
              <view class="combination-food-empty" wx:if="{{filteredCombinationFoodOptions.length === 0}}">
                没有匹配的食物
              </view>
            </view>
          </view>
          <view class="combination-pending-bar" wx:if="{{pendingCombinationItems.length > 0}}">
            <view class="combination-pending-main">
              <text class="combination-pending-title">已选 {{pendingCombinationItems.length}} 种</text>
              <text class="combination-pending-names">
                <block wx:for="{{pendingCombinationItems}}" wx:key="foodId">{{index > 0 ? '、' : ''}}{{item.foodName || item.foodSnapshot.name}}</block>
              </text>
            </view>
            <view class="combination-pending-next" bindtap="goToCombinationQuantityStep">下一步</view>
          </view>
        </view>
        <view class="form-section" wx:if="{{combinationModalStep === 'quantity'}}">
          <view class="form-section-header">
            <text class="form-section-title">设置默认份量</text>
            <text class="form-section-subtitle">保存后，这些份量会作为菜谱默认准备量</text>
          </view>
          <view class="combination-food-empty" wx:if="{{combinationForm.items.length === 0}}">
            还没有选择食物，请返回上一步选择
          </view>
          <view class="combination-form-item" wx:for="{{combinationForm.items}}" wx:key="foodId">
            <view class="combination-form-header">
              <text class="combination-form-name">{{item.foodName || item.foodSnapshot.name}}</text>
              <view class="text-delete" data-index="{{index}}" bindtap="removeCombinationFormItem">移除</view>
            </view>
            <view class="form-item inline-compact">
              <text class="form-label">份量</text>
              <view class="form-control quantity-control">
                <input class="input" type="digit" value="{{item.quantityInput}}" data-index="{{index}}" bindinput="onCombinationItemQuantityInput" />
                <text class="quantity-unit">{{item.unit || 'g'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn cancel" wx:if="{{combinationModalStep === 'select'}}" bindtap="hideCombinationModal">取消</button>
        <button class="btn confirm" wx:if="{{combinationModalStep === 'select'}}" bindtap="goToCombinationQuantityStep">下一步</button>
        <button class="btn cancel" wx:if="{{combinationModalStep === 'quantity'}}" bindtap="backToCombinationFoodSelect">继续选择</button>
        <button class="btn confirm" wx:if="{{combinationModalStep === 'quantity'}}" bindtap="saveMealCombinationEdit">保存菜谱</button>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showAddModal}}">
    <view class="modal-mask" bindtap="hideAddModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{editingFoodId ? '编辑食物' : '添加食物'}}</text>
        <text class="modal-subtitle">先完善基础信息，再补充营养和展示信息</text>
      </view>
      <view class="modal-body">
        <view class="form-section">
          <view class="form-section-header">
            <text class="form-section-title">必填信息</text>
            <text class="form-section-subtitle">决定食物展示分类和营养计算基准</text>
          </view>

          <view class="form-item">
            <text class="form-label">名称</text>
            <view class="form-control">
              <input class="input" placeholder="如：南瓜泥" value="{{formData.name}}" data-field="name" bindinput="onInputChange" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">分类</text>
            <view class="form-control form-control-stack">
              <view class="category-picker-row">
                <picker
                  class="category-picker"
                  mode="selector"
                  range="{{categorySuggestions}}"
                  value="{{categoryPickerIndex}}"
                  bindchange="onCategoryPickerChange"
                >
                  <view class="picker-display category-picker-display {{formData.category ? '' : 'placeholder'}}">
                    {{formData.category || '请选择分类'}}
                  </view>
                </picker>
                <view class="category-add-trigger" bindtap="toggleCategoryCreator">
                  {{showCategoryCreator ? '收起' : '新增'}}
                </view>
              </view>
              <view class="custom-category-row" wx:if="{{showCategoryCreator}}">
                <input
                  class="custom-category-input"
                  placeholder="输入新分类名称"
                  value="{{customCategoryInput}}"
                  bindinput="onCustomCategoryInput"
                />
                <view class="custom-category-button" bindtap="addCustomCategory">添加</view>
              </view>
            </view>
          </view>

          <view class="form-item inline-compact">
            <text class="form-label">记录单位</text>
            <view class="form-control form-control-stack">
              <view class="category-picker-row">
                <picker
                  class="category-picker"
                  mode="selector"
                  range="{{unitSuggestions}}"
                  value="{{unitPickerIndex}}"
                  bindchange="onUnitPickerChange"
                >
                  <view class="picker-display category-picker-display {{formData.unit ? '' : 'placeholder'}}">
                    {{formData.unit || '请选择单位'}}
                  </view>
                </picker>
                <view class="category-add-trigger" bindtap="toggleUnitCreator">
                  {{showUnitCreator ? '收起' : '新增'}}
                </view>
              </view>
              <view class="custom-category-row" wx:if="{{showUnitCreator}}">
                <input
                  class="custom-category-input"
                  placeholder="输入新单位名称"
                  value="{{customUnitInput}}"
                  bindinput="onCustomUnitInput"
                />
                <view class="custom-category-button" bindtap="addCustomUnit">添加</view>
              </view>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">营养基准份量</text>
            <view class="form-control form-control-stack">
              <input class="input" type="digit" placeholder="默认 100" value="{{formData.baseQuantity}}" data-field="baseQuantity" bindinput="onInputChange" />
              <text class="field-hint">营养值按这份量计算</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">热量 (kcal)</text>
            <view class="form-control form-control-stack">
              <input class="input" type="digit" placeholder="必填" value="{{formData.calories}}" data-field="calories" bindinput="onInputChange" />
              <view class="energy-convert-row">
                <input
                  class="input energy-kj-input"
                  type="digit"
                  placeholder="输入包装标注的 kJ"
                  value="{{energyKjInput}}"
                  bindinput="onEnergyKjInput"
                />
                <view class="energy-convert-button" bindtap="applyKjToKcal">换算</view>
              </view>
              <text class="field-hint">1 kcal = 4.184 kJ，换算后会直接填入上方热量</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">蛋白 (g)</text>
            <view class="form-control">
              <input class="input" type="digit" placeholder="必填" value="{{formData.protein}}" data-field="protein" bindinput="onInputChange" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">蛋白来源</text>
            <view class="form-control form-control-stack">
              <picker class="picker" mode="selector" range="{{proteinTypeOptions}}" range-key="label" value="{{formData.proteinTypeIndex >= 0 ? formData.proteinTypeIndex : 0}}" bindchange="onProteinTypeChange">
                <view class="picker-display {{formData.proteinTypeIndex >= 0 ? '' : 'placeholder'}}">
                  {{formData.proteinTypeIndex >= 0 ? proteinTypeOptions[formData.proteinTypeIndex].label : '请选择蛋白来源'}}
                </view>
              </picker>
              <text class="field-hint protein-source-hint" wx:if="{{proteinTypeRecommendationText}}">{{proteinTypeRecommendationText}}</text>
              <text class="field-hint protein-source-hint warning" wx:else>会影响天然/特殊蛋白和优质蛋白占比统计</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">脂肪 (g)</text>
            <view class="form-control">
              <input class="input" type="digit" placeholder="必填" value="{{formData.fat}}" data-field="fat" bindinput="onInputChange" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">碳水 (g)</text>
            <view class="form-control">
              <input class="input" type="digit" placeholder="必填" value="{{formData.carbs}}" data-field="carbs" bindinput="onInputChange" />
            </view>
          </view>
        </view>

        <view class="form-section">
          <view class="form-section-header">
            <text class="form-section-title">扩展信息</text>
            <text class="form-section-subtitle">可补充图片、膳食纤维和钠</text>
          </view>

          <view class="form-item">
            <text class="form-label">图片</text>
            <view class="form-control form-control-stack">
              <view class="image-field-row">
                <view class="image-upload-button" bindtap="chooseFoodImage">
                  {{uploadingFoodImage ? '上传中...' : '上传图片'}}
                </view>
                <view class="image-clear-button" wx:if="{{formData.image}}" bindtap="clearFoodImage">
                  移除
                </view>
              </view>
              <image
                class="food-image-preview"
                wx:if="{{foodImagePreviewUrl || formData.image}}"
                src="{{foodImagePreviewUrl || formData.image}}"
                mode="aspectFill"
                data-url="{{foodImagePreviewUrl || formData.image}}"
                bindtap="previewFoodImage"
              />
            </view>
          </view>
          <view class="form-item">
            <text class="form-label">膳食纤维 (g)</text>
            <view class="form-control">
              <input class="input" type="digit" value="{{formData.fiber}}" data-field="fiber" bindinput="onInputChange" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">钠 (mg)</text>
            <view class="form-control">
              <input class="input" type="digit" value="{{formData.sodium}}" data-field="sodium" bindinput="onInputChange" />
            </view>
          </view>

        </view>
      </view>
      <view class="modal-footer">
        <button class="btn cancel" bindtap="hideAddModal">取消</button>
        <button class="btn confirm" bindtap="saveFood">保存</button>
      </view>
    </view>
  </view>
</view>
