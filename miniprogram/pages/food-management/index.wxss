.container {
  height: 100vh;
  background: #fef8ec;
  padding: 32rpx 0 120rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.page-header {
  margin-bottom: 24rpx;
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888888;
}

.search-bar {
  margin-bottom: 24rpx;
  width: 100%;
  padding: 24rpx 32rpx;
  border-radius: 0;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.12);
  box-sizing: border-box;
  flex-shrink: 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f7f7f7;
}

.search-icon {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #c47b00;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  font-size: 28rpx;
  color: #333333;
}

.search-clear {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #ff9b00;
}

.search-summary {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #999999;
}

.page-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #c47b00;
}

.loading,
.empty {
  margin-top: 120rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.food-layout {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  width: auto;
  flex: 1;
  align-self: stretch;
  min-height: 0;
  height: 100%;
  margin: 0 32rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.category-sidebar {
  width: 176rpx;
  flex-shrink: 0;
  height: 100%;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7e7b2 0%, #f3ddb0 100%);
  overflow: hidden;
}

.category-nav-item {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 28rpx 18rpx;
  color: #8b6d35;
  background: rgba(255, 255, 255, 0.12);
  border-bottom: 1px solid rgba(173, 122, 26, 0.08);
}

.category-nav-item.active {
  background: rgba(255, 252, 245, 0.96);
  color: #333333;
}

.category-nav-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 8rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #ffb800, #ff9b00);
}

.category-nav-name {
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
}

.category-nav-count {
  font-size: 22rpx;
  color: #9f7630;
}

.food-panel {
  flex: 1;
  min-width: 0;
  height: 100%;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.12);
  padding: 24rpx;
  box-sizing: border-box;
}

.food-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.food-panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.food-panel-count {
  font-size: 24rpx;
  color: #999999;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.food-item {
  border-top: 1px solid #f5f5f5;
  padding: 20rpx 0;
}

.food-item:first-child {
  border-top: none;
  padding-top: 0;
}

.food-main {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.food-info {
  flex: 1;
  min-width: 0;
  min-height: 96rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: flex-start;
}

.food-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.food-cover {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  object-fit: cover;
}

.food-unit {
  font-size: 24rpx;
  color: #999999;
}

.food-sub-category {
  font-size: 22rpx;
  color: #c47b00;
}

.food-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1;
}

.food-tag.system {
  background: rgba(255, 184, 0, 0.15);
  color: #ff9b00;
}

.food-tag.custom {
  background: rgba(57, 197, 187, 0.18);
  color: #39c5bb;
}

.food-nutrition {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nutrition-item .label {
  font-size: 22rpx;
  color: #999999;
}

.nutrition-item .value {
  font-size: 26rpx;
  color: #333333;
}

.food-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.food-actions .action-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
}

.food-actions .action-btn.edit {
  background: #f0f5ff;
  color: #3a7afe;
  border: none;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb800, #ff9b00);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 12rpx 30rpx rgba(255, 184, 0, 0.4);
}

.add-icon {
  font-size: 60rpx;
  color: #ffffff;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: linear-gradient(180deg, #fffdf8 0%, #ffffff 18%);
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  padding: 0 32rpx 32rpx;
  max-height: 84vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.modal-header {
  padding: 32rpx 0 24rpx;
  text-align: center;
  border-bottom: 1px solid rgba(255, 184, 0, 0.12);
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9b8b6d;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 8rpx 0 0;
}

.form-item {
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.form-item.inline-compact {
  align-items: flex-start;
}

.form-section {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffaf0;
  border: 1px solid rgba(255, 184, 0, 0.12);
}

.form-section:last-child {
  margin-bottom: 0;
}

.form-section-header {
  margin-bottom: 20rpx;
}

.form-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #5f4b1d;
}

.form-section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9b8b6d;
}

.form-section-mini-title {
  margin: 8rpx 0 20rpx;
  font-size: 24rpx;
  color: #8a6f3a;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.form-label {
  width: 144rpx;
  flex-shrink: 0;
  padding-top: 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #555555;
}

.form-control {
  flex: 1;
  min-width: 0;
}

.form-control-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-hint {
  margin-top: -2rpx;
  font-size: 22rpx;
  color: #9b8b6d;
}

.input,
.picker-display {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1px solid rgba(255, 184, 0, 0.12);
  font-size: 28rpx;
  color: #333333;
}

.picker {
  width: 100%;
}

.picker-display {
  display: flex;
  align-items: center;
}

.picker-display.placeholder {
  color: #b9b0a1;
}

.category-picker-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.category-picker {
  flex: 1;
  min-width: 0;
}

.category-picker-display {
  justify-content: space-between;
}

.category-add-trigger {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 184, 0, 0.12);
  color: #8a6f3a;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-field-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.energy-convert-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.energy-kj-input {
  flex: 1;
  min-width: 0;
}

.energy-convert-button {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: rgba(58, 122, 254, 0.12);
  color: #3a7afe;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-upload-button,
.image-clear-button {
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-upload-button {
  background: rgba(255, 184, 0, 0.12);
  color: #8a6f3a;
}

.image-clear-button {
  background: rgba(229, 77, 66, 0.1);
  color: #c65247;
}

.food-image-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suggestions.compact {
  margin-top: -2rpx;
}

.suggestion {
  padding: 8rpx 20rpx;
  background: rgba(255, 184, 0, 0.1);
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8a6f3a;
}

.custom-category-row {
  display: flex;
  gap: 16rpx;
}


.custom-category-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1px solid rgba(255, 184, 0, 0.12);
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
}

.custom-category-button {
  min-width: 140rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ffb800, #ff9b00);
  color: #ffffff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(255, 184, 0, 0.12);
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.btn.cancel {
  background: #f5f5f5;
  color: #666666;
}

.btn.confirm {
  background: linear-gradient(135deg, #ffb800, #ff9b00);
  color: #ffffff;
}
