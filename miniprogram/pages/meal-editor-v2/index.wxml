<view class="page">
  <view class="overview-card">
    <view class="overview-main">
      <text class="overview-title">{{mode === 'edit' ? '编辑本顿食物' : (mealDraft.mealLabel || '本顿食物')}}</text>
      <text class="overview-subtitle">{{formattedSelectedDate}} · {{mealDraft.mealTime}}</text>
    </view>
    <view class="overview-count">
      <text class="overview-count-value">{{mealDraft.items.length}}</text>
      <text class="overview-count-label">已加食物</text>
    </view>
  </view>

  <view class="section-card meal-meta-card">
    <view class="section-header">
      <text class="section-title">餐次设置</text>
      <text class="section-meta">{{mode === 'edit' ? '修改后会覆盖原餐次' : '这顿饭只设置一次'}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">时间</text>
      <picker mode="time" value="{{mealDraft.mealTime}}" bindchange="onMealTimeChange">
        <view class="field-picker">{{mealDraft.mealTime}}</view>
      </picker>
    </view>
    <view class="field-row completion-row">
      <text class="field-label">吃了多少</text>
      <view class="completion-controls">
        <view
          class="completion-chip {{completionPercent == item ? 'active' : ''}}"
          wx:for="{{completionPercentOptions}}"
          wx:key="*this"
          data-percent="{{item}}"
          bindtap="onCompletionPercentTap"
        >
          <text>{{item}}%</text>
        </view>
        <view class="completion-input-wrap">
          <input
            type="digit"
            class="completion-input"
            value="{{completionPercent}}"
            placeholder="自定义"
            bindinput="onCompletionPercentInput"
          />
          <text class="completion-suffix">%</text>
        </view>
      </view>
    </view>
    <view class="label-group">
      <view
        class="label-chip {{mealDraft.mealLabel === item ? 'active' : ''}}"
        wx:for="{{mealLabels}}"
        wx:key="*this"
        data-label="{{item}}"
        bindtap="onMealLabelTap"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section-card items-card">
    <view class="section-header items-header">
      <view class="section-title-wrap">
        <text class="section-title">本顿食物</text>
        <text class="section-meta left">已添加 {{mealDraft.items.length}} 种</text>
      </view>
      <view class="combination-save-btn compact {{mealDraft.items.length === 0 ? 'disabled' : ''}}" bindtap="showSaveCombinationInput">保存当前为菜谱</view>
    </view>
    <view class="combination-name-panel" wx:if="{{combinationNameInputVisible}}">
      <input
        class="combination-name-input"
        type="text"
        value="{{combinationDraftName}}"
        placeholder="给这份菜谱起个名字，例如：南瓜米粉午餐"
        bindinput="onCombinationNameInput"
      />
      <view class="combination-name-actions">
        <view class="combination-name-cancel" bindtap="hideSaveCombinationInput">取消</view>
        <view class="combination-name-confirm" bindtap="saveCurrentMealAsCombination">保存菜谱</view>
      </view>
    </view>
    <view class="meal-summary-compact" wx:if="{{mealDraft.items.length > 0}}">
      <view class="meal-summary-compact-head">
        <text class="meal-summary-compact-title">准备 / 实际摄入</text>
        <text class="meal-summary-compact-percent">吃了 {{completionPercent || 0}}%</text>
      </view>
      <view class="meal-summary-macro-grid">
        <view class="meal-summary-macro">
          <text class="meal-summary-macro-label">热量 kcal</text>
          <view class="meal-summary-macro-amounts">
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">准备</text>
              <text class="meal-summary-macro-value">{{displayPlannedMealSummary.calories || 0}}</text>
            </view>
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">实际</text>
              <text class="meal-summary-macro-value">{{displayActualMealSummary.calories || 0}}</text>
            </view>
          </view>
        </view>
        <view class="meal-summary-macro">
          <text class="meal-summary-macro-label">蛋白 g</text>
          <view class="meal-summary-macro-amounts">
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">准备</text>
              <text class="meal-summary-macro-value">{{displayPlannedMealSummary.protein || 0}}</text>
            </view>
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">实际</text>
              <text class="meal-summary-macro-value">{{displayActualMealSummary.protein || 0}}</text>
            </view>
          </view>
        </view>
        <view class="meal-summary-macro">
          <text class="meal-summary-macro-label">碳水 g</text>
          <view class="meal-summary-macro-amounts">
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">准备</text>
              <text class="meal-summary-macro-value">{{displayPlannedMealSummary.carbs || 0}}</text>
            </view>
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">实际</text>
              <text class="meal-summary-macro-value">{{displayActualMealSummary.carbs || 0}}</text>
            </view>
          </view>
        </view>
        <view class="meal-summary-macro">
          <text class="meal-summary-macro-label">脂肪 g</text>
          <view class="meal-summary-macro-amounts">
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">准备</text>
              <text class="meal-summary-macro-value">{{displayPlannedMealSummary.fat || 0}}</text>
            </view>
            <view class="meal-summary-macro-amount">
              <text class="meal-summary-macro-amount-label">实际</text>
              <text class="meal-summary-macro-value">{{displayActualMealSummary.fat || 0}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{mealDraft.items.length === 0}}">
      <text>先点底部“添加食物”，把这顿饭的食物逐个加进来。</text>
    </view>
    <view class="meal-display-group {{group.type === 'meal_combination' ? 'meal-combination-group' : 'manual-food-group'}}" wx:for="{{mealDisplayGroups}}" wx:for-item="group" wx:key="id">
      <view class="meal-display-group-header" data-id="{{group.id}}" bindtap="toggleMealDisplayGroup">
        <view class="meal-display-group-copy">
          <text class="meal-display-group-kicker">{{group.type === 'meal_combination' ? '食谱' : '单独添加'}}</text>
          <text class="meal-display-group-title">{{group.title}}</text>
          <text class="meal-display-group-meta">{{group.itemCount}}种食物</text>
        </view>
        <view class="meal-display-group-summary">
          <text>{{group.summary.calories || 0}} kcal</text>
          <text>蛋白 {{group.summary.protein || 0}}g</text>
          <text>{{group.expanded ? '收起' : '展开'}}</text>
        </view>
      </view>
      <view class="meal-display-group-items" wx:if="{{group.expanded}}">
        <view class="meal-item" wx:for="{{group.items}}" wx:for-item="foodItem" wx:key="localId">
          <view class="meal-item-main">
            <text class="meal-item-name">{{foodItem.nameSnapshot}} · {{foodItem.quantity}}{{foodItem.unit}}</text>
            <view class="meal-item-nutrition-row">
              <text>热量 {{foodItem.displayNutrition.calories || 0}} kcal</text>
              <text>蛋白 {{foodItem.displayNutrition.protein || 0}} g</text>
              <text>碳水 {{foodItem.displayNutrition.carbs || 0}} g</text>
              <text>脂肪 {{foodItem.displayNutrition.fat || 0}} g</text>
            </view>
          </view>
          <view class="meal-item-actions">
            <view class="text-btn" data-id="{{foodItem.localId}}" bindtap="editMealItem">编辑</view>
            <view class="text-btn danger" data-id="{{foodItem.localId}}" bindtap="removeMealItem">删除</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card note-card">
    <view class="section-header">
      <text class="section-title">备注</text>
      <text class="section-meta">可选，不影响主要记录流程</text>
    </view>
    <view class="field-block">
      <textarea
        class="notes-input"
        value="{{mealDraft.mealNote}}"
        placeholder="可选，记录这顿饭的说明"
        bindinput="onMealNoteInput"
      />
    </view>
  </view>

  <view class="footer-bar">
    <button class="footer-btn cancel" bindtap="onCancel">取消</button>
    <button class="footer-btn secondary" bindtap="openFoodDrawer">添加食物</button>
    <button class="footer-btn confirm" bindtap="saveMeal" disabled="{{mealDraft.items.length === 0}}">
      {{mode === 'edit' ? '保存修改' : '保存本顿'}}
    </button>
  </view>

  <view class="drawer-mask" wx:if="{{drawerVisible}}" bindtap="closeFoodDrawer"></view>
  <view class="food-drawer {{drawerVisible ? 'visible' : ''}}">
    <view class="drawer-handle"></view>
    <view class="drawer-header">
      <view class="drawer-header-main">
        <text class="drawer-title">{{drawerStep === 'select' ? '添加食物' : (drawerStep === 'batchQuantity' ? '设置份量' : (editingItemId ? '编辑食物' : '添加食物'))}}</text>
        <text class="drawer-subtitle">{{drawerStep === 'select' ? '先连续选择，再统一填写份量' : (drawerStep === 'batchQuantity' ? '确认每种食物的准备量' : '确认份量后加入这顿饭')}}</text>
      </view>
      <view class="drawer-close" bindtap="closeFoodDrawer">关闭</view>
    </view>

    <view class="drawer-body select-body" wx:if="{{drawerStep === 'select'}}">
      <view class="drawer-tabs">
        <view class="drawer-tab {{drawerActiveTab === 'food' ? 'active' : ''}}" data-tab="food" bindtap="onDrawerTabTap">食物</view>
        <view class="drawer-tab {{drawerActiveTab === 'combination' ? 'active' : ''}}" data-tab="combination" bindtap="onDrawerTabTap">菜谱</view>
      </view>
      <view class="drawer-food-panel" wx:if="{{drawerActiveTab === 'food'}}">
        <view class="search-input">
          <input
            type="text"
            value="{{foodSearchQuery}}"
            placeholder="搜索食物名称、分类或别名"
            bindinput="onFoodSearchInput"
          />
        </view>
        <view class="drawer-utility-row">
          <view class="drawer-utility-btn" bindtap="navigateToFoodManagement">去添加食物</view>
        </view>
        <view class="food-select-layout">
          <scroll-view class="category-sidebar" scroll-y="true" show-scrollbar="false">
            <view
              class="category-nav-item {{activeCategory === item.value ? 'active' : ''}}"
              wx:for="{{foodCategories}}"
              wx:key="value"
              data-category="{{item.value}}"
              bindtap="onCategoryTap"
            >
              <text class="category-nav-label">{{item.label}}</text>
            </view>
          </scroll-view>
          <scroll-view class="food-list-panel" scroll-y="true" show-scrollbar="false">
            <view class="food-list-header">
              <text class="food-list-title">{{activeCategory === 'recent' ? '最近使用' : activeCategory}}</text>
              <text class="food-list-count">{{filteredFoodOptions.length}} 种</text>
            </view>
            <view
              class="food-option {{item.isPendingSelected ? 'selected' : ''}}"
              wx:for="{{filteredFoodOptions}}"
              wx:key="_id"
              data-id="{{item._id}}"
              bindtap="onFoodOptionTap"
            >
              <image
                class="food-option-image"
                src="{{item.displayImage}}"
                mode="aspectFill"
                data-url="{{item.displayImage}}"
                catchtap="previewFoodOptionImage"
              />
              <view class="food-option-main">
                <text class="food-option-name">{{item.name}}</text>
                <view class="food-option-meta-row">
                  <text class="food-option-energy">{{item.nutritionPerUnit.calories || 0}}</text>
                  <text class="food-option-meta">kcal / {{item.baseQuantity || 100}}{{item.baseUnit || 'g'}}</text>
                </view>
                <text class="food-option-sub" wx:if="{{item.aliasText}}">{{item.aliasText}}</text>
              </view>
              <view class="food-option-add {{item.isPendingSelected ? 'selected' : ''}}" data-id="{{item._id}}" catchtap="onFoodOptionTap">
                {{item.isPendingSelected ? '已选' : '+'}}
              </view>
            </view>
            <view class="empty-state compact" wx:if="{{filteredFoodOptions.length === 0}}">
              <text>未找到匹配的食物</text>
            </view>
          </scroll-view>
        </view>
      </view>
      <view class="drawer-combination-panel" wx:elif="{{drawerActiveTab === 'combination'}}">
        <view class="drawer-utility-row">
          <view class="drawer-utility-btn" bindtap="navigateToCombinationManagement">去添加菜谱</view>
        </view>
        <view class="empty-state compact" wx:if="{{combinationLoading}}">
          <text>正在准备宝宝的菜谱...</text>
        </view>
        <view class="empty-state compact" wx:elif="{{mealCombinations.length === 0}}">
          <text>还没有菜谱，先保存一份常用菜谱，下次就能一键加入啦。</text>
        </view>
        <scroll-view class="drawer-combination-list" scroll-y="true" show-scrollbar="false" wx:else>
          <view
            class="combination-item"
            wx:for="{{mealCombinations}}"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="applyMealCombination"
          >
            <view class="combination-item-main">
              <text class="combination-item-name">{{item.name}}</text>
              <text class="combination-item-meta">{{item.items.length}} 种食物 · 已用 {{item.usageCount || 0}} 次</text>
            </view>
            <view class="combination-item-apply">加入</view>
          </view>
        </scroll-view>
      </view>
      <view class="pending-select-bar" wx:if="{{pendingMealItems.length > 0}}">
        <view class="pending-select-main">
          <text class="pending-select-title">已选 {{pendingMealItems.length}} 种</text>
          <text class="pending-select-names">
            <block wx:for="{{pendingMealItems}}" wx:key="pendingId">{{index > 0 ? '、' : ''}}{{item.nameSnapshot}}</block>
          </text>
        </view>
        <view class="pending-select-next" bindtap="goToBatchQuantityStep">下一步</view>
      </view>
    </view>

    <view class="drawer-body batch-body" wx:if="{{drawerStep === 'batchQuantity'}}">
      <view class="batch-hint-card">
        <text class="batch-hint-title">统一设置准备量</text>
        <text class="batch-hint-text">这里填写的是计划准备量，保存本顿时再按吃了多少计入实际营养。</text>
      </view>
      <scroll-view class="batch-item-list" scroll-y="true" show-scrollbar="false">
        <view class="batch-item" wx:for="{{pendingMealItems}}" wx:key="pendingId">
          <view class="batch-item-header">
            <view class="batch-item-title-wrap">
              <text class="batch-item-title">{{item.nameSnapshot}}</text>
              <text class="batch-item-source" wx:if="{{item.mealCombinationSource}}">来自 {{item.mealCombinationSource.combinationName}}</text>
            </view>
            <view class="text-btn danger" data-id="{{item.pendingId}}" bindtap="removePendingMealItem">移除</view>
          </view>
          <view class="field-row quantity-row">
            <text class="field-label">份量</text>
            <input
              type="digit"
              class="quantity-input"
              value="{{item.quantity}}"
              placeholder="请输入份量"
              data-id="{{item.pendingId}}"
              bindinput="onPendingQuantityInput"
            />
            <text class="unit-text">{{item.unit || 'g'}}</text>
          </view>
          <view class="preview-grid compact" wx:if="{{item.nutritionPreview}}">
            <view class="preview-item">
              <text class="preview-value">{{item.nutritionPreview.calories || 0}}</text>
              <text class="preview-label">kcal</text>
            </view>
            <view class="preview-item">
              <text class="preview-value">{{item.nutritionPreview.protein || 0}}</text>
              <text class="preview-label">蛋白</text>
            </view>
            <view class="preview-item">
              <text class="preview-value">{{item.nutritionPreview.carbs || 0}}</text>
              <text class="preview-label">碳水</text>
            </view>
            <view class="preview-item">
              <text class="preview-value">{{item.nutritionPreview.fat || 0}}</text>
              <text class="preview-label">脂肪</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="batch-actions">
        <button class="batch-btn secondary" bindtap="backToBatchSelect">上一步：继续选择</button>
        <button class="batch-btn confirm" bindtap="addPendingItemsToMeal">加入本顿</button>
      </view>
    </view>

    <view class="drawer-body edit-body" wx:if="{{drawerStep === 'edit'}}">
      <view class="selected-food-card">
        <view class="selected-food-main">
          <text class="selected-food-name">{{currentFoodDraft.food ? currentFoodDraft.food.name : '未选择食物'}}</text>
          <text class="selected-food-sub">{{currentFoodDraft.food ? (currentFoodDraft.food.category || '未分类') : '请先选择食物'}}</text>
        </view>
        <view class="selected-food-switch" bindtap="backToFoodSelect">换一种</view>
      </view>
      <view class="field-row quantity-row">
        <text class="field-label">份量</text>
        <input
          type="digit"
          class="quantity-input"
          value="{{currentFoodDraft.quantity}}"
          placeholder="请输入份量"
          bindinput="onDraftQuantityInput"
        />
        <text class="unit-text">{{currentFoodDraft.unit || 'g'}}</text>
      </view>
      <view class="preview-grid" wx:if="{{currentFoodDraft.nutritionPreview}}">
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.calories || 0}}</text>
          <text class="preview-label">kcal</text>
        </view>
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.protein || 0}}</text>
          <text class="preview-label">蛋白</text>
        </view>
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.carbs || 0}}</text>
          <text class="preview-label">碳水</text>
        </view>
        <view class="preview-item">
          <text class="preview-value">{{currentFoodDraft.nutritionPreview.fat || 0}}</text>
          <text class="preview-label">脂肪</text>
        </view>
      </view>
      <button class="add-item-btn" bindtap="addOrUpdateMealItem">
        {{editingItemId ? '更新这项食物' : '加入本顿'}}
      </button>
    </view>
  </view>
</view>
