.feedback-page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 122, 0.4), transparent 28%),
    linear-gradient(180deg, #FFF7DC 0%, #FFF2C8 100%);
  box-sizing: border-box;
}

.hero-card,
.section-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.08);
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.hero-card {
  background: linear-gradient(135deg, #FFCB38 0%, #FFB800 100%);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #5F3900;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(95, 57, 0, 0.78);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.section-meta {
  font-size: 22rpx;
  color: #8A7C60;
}

.type-chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-chip {
  min-width: 140rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  color: #8A7C60;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.type-chip.active {
  background: #FFB800;
  border-color: #FFB800;
  color: #ffffff;
}

.feedback-textarea,
.contact-input {
  width: 100%;
  box-sizing: border-box;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #333333;
}

.feedback-textarea {
  min-height: 260rpx;
  padding: 20rpx;
}

.contact-input {
  height: 84rpx;
  padding: 0 20rpx;
}

.submit-bar {
  margin-top: 8rpx;
  padding: 8rpx 0 12rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #FFC933 0%, #FFB800 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(255, 184, 0, 0.2);
}

.submit-btn[disabled] {
  background: #F0D98B;
  color: rgba(255, 255, 255, 0.88);
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}

.qr-card {
  text-align: center;
}

.qr-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-image {
  width: 360rpx;
  border-radius: 16rpx;
}

.qr-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8A7C60;
}
