.calorie-container { padding: 16rpx 24rpx 120rpx; }
.picker { padding: 20rpx; background:#f6f6f6; border-radius: 12rpx; margin-bottom: 16rpx; }
.tips { font-size: 24rpx; color:#666; margin: 12rpx 0 24rpx; line-height: 1.5; }
.search input { padding: 20rpx; border: 1px solid #eee; border-radius: 12rpx; }
.table { margin-top: 16rpx; }
.thead, .trow { display: flex; padding: 18rpx 8rpx; border-bottom: 1px solid #f0f0f0; }
.thead { font-weight: 600; color:#333; background:#fafafa; }
.col.name { flex: 2; }
.col.energy, .col.protein { flex: 1; text-align: right; }
.trow .col { color:#333; }