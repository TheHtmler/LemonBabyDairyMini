/* 角色选择页面样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #FFF5D6;
  padding: 40rpx;
  position: relative;
}

/* Loading 遮罩样式 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 245, 214, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(10rpx);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 480rpx;
  max-width: calc(100vw - 96rpx);
  box-sizing: border-box;
  padding: 16rpx 32rpx;
  background: transparent;
  box-shadow: none;
  animation: fadeIn 0.3s ease-out;
}

.loading-logo {
  position: relative;
  width: 268rpx;
  height: 224rpx;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-logo::before {
  content: '';
  position: absolute;
  width: 248rpx;
  height: 154rpx;
  border-radius: 50%;
  background: rgba(255, 214, 102, 0.22);
  filter: blur(32rpx);
  transform: translateY(28rpx);
}

.milk-lemon-art {
  position: relative;
  width: 260rpx;
  height: 210rpx;
  animation: lemon-breath 2s ease-in-out infinite;
  filter: drop-shadow(0 8rpx 16rpx rgba(255, 184, 0, 0.18));
}

.loading-logo.entering .milk-lemon-art {
  animation-duration: 1.35s;
}

.loading-message {
  width: 100%;
  box-sizing: border-box;
  font-size: 32rpx;
  color: #FFB800;
  font-weight: 500;
  min-height: 46rpx;
  text-align: center;
  white-space: nowrap;
}

/* 重试按钮样式 */
.retry-button {
  background-color: #FFB800;
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.3);
  transition: all 0.3s ease;
}

.retry-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 0, 0.3);
}

/* 动画定义 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

@keyframes lemon-breath {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.045);
  }
}

@media (prefers-reduced-motion: reduce) {
  .loading-content,
  .milk-lemon-art,
  .loading-message,
  .retry-button,
  .role-card {
    animation-duration: 0.01ms;
    animation-iteration-count: 1;
    transition-duration: 0.01ms;
  }
}

/* 头部样式 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 42rpx;
  font-weight: bold;
  color: #FFB800;
  text-shadow: 0 2rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 指引文字 */
.guide-text {
  font-size: 36rpx;
  color: #333;
  margin-bottom: 50rpx;
  text-align: center;
}

/* 角色卡片容器 */
.role-cards {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 600rpx;
  gap: 40rpx;
  margin-bottom: 50rpx;
}

/* 角色卡片通用样式 */
.role-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.role-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 创建者角色卡片 */
.creator {
  background-color: #FFE082;
  border: 2rpx solid #FFB800;
}

/* 参与者角色卡片 */
.participant {
  background-color: #FFECB3;
  border: 2rpx solid #FFC107;
}

/* 角色图标 */
.role-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

/* 角色名称 */
.role-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #333;
}

/* 角色描述 */
.role-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

/* 底部文字 */
.footer-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 30rpx;
  text-align: center;
} 