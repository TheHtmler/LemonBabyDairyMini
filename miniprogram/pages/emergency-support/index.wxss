.emergency-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 122, 0.35), transparent 26%),
    linear-gradient(180deg, #FFF7DC 0%, #FFF2C8 100%);
}

.hero-card,
.support-card,
.calculator-card,
.formula-card,
.notice-card,
.reference-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.12);
  box-shadow: 0 10rpx 24rpx rgba(255, 184, 0, 0.08);
}

.hero-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5F3900;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(95, 57, 0, 0.76);
}

.support-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.support-card-main {
  flex: 1;
  min-width: 0;
}

.support-card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.support-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.support-card-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #FFF4D0;
  color: #9A6500;
  font-size: 22rpx;
  font-weight: 600;
}

.support-card-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A7C60;
}

.support-card-arrow {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #C6A767;
}

.calculator-card {
  padding: 24rpx;
}

.calculator-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calculator-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.calculator-tag {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #FFF4D0;
  color: #9A6500;
  font-size: 22rpx;
  font-weight: 600;
}

.calculator-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A7C60;
}

.input-group {
  margin-top: 24rpx;
}

.input-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5F3900;
}

.input-control {
  width: 100%;
  height: 84rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  background: #FFF7E3;
  color: #333333;
  font-size: 28rpx;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.preset-chip {
  min-width: 104rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.16);
  color: #8A7C60;
  font-size: 22rpx;
  text-align: center;
  box-sizing: border-box;
}

.preset-chip.active {
  background: #FFB800;
  border-color: #FFB800;
  color: #ffffff;
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.result-item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #FFF7E3;
  border: 2rpx solid rgba(255, 184, 0, 0.12);
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #8A7C60;
}

.result-value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.4;
}

.result-value.highlight {
  color: #D65B00;
}

.formula-card,
.notice-card {
  padding: 20rpx;
  margin-top: 20rpx;
  background: #FFF7E3;
  box-shadow: none;
}

.reference-card {
  padding: 20rpx;
  margin-top: 20rpx;
  background: #FFFDF5;
  box-shadow: none;
}

.formula-title,
.notice-title,
.reference-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #5F3900;
}

.formula-line,
.notice-line {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8A7C60;
}

.formula-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9A6500;
}

.reference-item,
.example-item {
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(255, 184, 0, 0.08);
}

.reference-item:last-child,
.example-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.reference-main,
.example-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.reference-label,
.example-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #333333;
}

.reference-desc,
.example-desc {
  font-size: 22rpx;
  color: #8A7C60;
}

.reference-note,
.example-result {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8A7C60;
}
