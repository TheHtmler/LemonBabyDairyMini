page {
  background: #FFF9E6;
}

.home {
  padding: 20rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* 公告（单行跑马灯） */
.notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(90deg, rgba(255, 184, 0, 0.95), rgba(255, 205, 64, 0.95));
  border-radius: 16rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.16);
  overflow: hidden;
}
.notice-fixed {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-right: 14rpx;
  border-right: 2rpx solid rgba(255, 255, 255, 0.45);
}
.notice-prefix {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}
.notice-marquee {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.notice-track {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  will-change: transform;
  animation: notice-scroll 18s linear infinite;
}
.notice-copy {
  flex-shrink: 0;
  padding-right: 80rpx;
  font-size: 23rpx;
  color: #fff;
  font-weight: 500;
}
.notice-close {
  flex: 0 0 auto;
  font-size: 34rpx;
  color: #fff;
  padding: 0 4rpx;
}
@keyframes notice-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* 宝宝卡（含问候语） */
.hero {
  margin-bottom: 22rpx;
}
.baby-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: linear-gradient(135deg, #FFFDF5, #FFF1C6);
  border: 2rpx solid #FBE6A6;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(255, 184, 0, 0.14);
}
.baby-greet {
  font-size: 22rpx;
  color: #B07D00;
  margin-bottom: 8rpx;
}
.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #FFE27A;
  flex: 0 0 auto;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.32);
  animation: baby-breathe 3.2s ease-in-out infinite;
}
@keyframes baby-breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}
.baby-main {
  flex: 1;
  min-width: 0;
}
.baby-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.baby-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.baby-gender {
  font-size: 20rpx;
  color: #8A8A8A;
  background: #F0EFE6;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}
.baby-gender.male {
  color: #5B9DF9;
  background: #E8F1FE;
}
.baby-gender.female {
  color: #FF6F8B;
  background: #FFE9ED;
}
.baby-sub {
  font-size: 24rpx;
  color: #8A8A8A;
  margin-top: 8rpx;
}
.baby-days {
  flex: 0 0 auto;
  text-align: center;
  background: #fff;
  border: 2rpx solid #FBE6A6;
  border-radius: 18rpx;
  padding: 12rpx 18rpx;
}
.baby-days-n {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #F59E0B;
  line-height: 1;
}
.baby-days-l {
  display: block;
  font-size: 18rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 26rpx 24rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 184, 0, 0.1);
  border: 2rpx solid rgba(255, 184, 0, 0.1);
}
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}
.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: #FFB800;
}
.card-more {
  font-size: 24rpx;
  color: #B0B0B0;
}

/* 营养达成 */
.metric-chips {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.weight-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 23rpx;
  color: #B07D00;
  background: #FFF3D6;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}
.weight-chip.alt {
  color: #2E9E6B;
  background: #E7F7EF;
}
.weight-chip.alt .weight-edit {
  color: #2E9E6B;
}
.weight-edit {
  font-size: 22rpx;
  color: #D9A400;
}
.nutri-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.ring {
  flex: 0 0 auto;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.anim-on .ring {
  animation: ring-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
@keyframes ring-pop {
  0% { transform: scale(0.82); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.ring-hole {
  width: 150rpx;
  height: 150rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.ring-big {
  font-size: 44rpx;
  font-weight: 800;
  color: #F59E0B;
  line-height: 1;
}
.ring-unit {
  font-size: 20rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}
.ring-lbl {
  font-size: 22rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}
.macro-list {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.macro-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.macro-k {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}
.macro-v {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
}
.macro-sub {
  font-size: 20rpx;
  color: #B0B0B0;
  font-weight: 500;
}
.bar {
  height: 14rpx;
  border-radius: 999rpx;
  background: #F0EFE6;
  overflow: hidden;
}
.bar-i {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.bar-i.nat { background: linear-gradient(90deg, #FFD45E, #FFB800); }
.bar-i.spe { background: linear-gradient(90deg, #8FD3FF, #5B9DF9); }
.bar-i.cal { background: linear-gradient(90deg, #FFB27A, #FF9F45); }

/* 今日营养摄入：实际值（无目标进度） */
.ring.static {
  background: conic-gradient(from 180deg, #FFE27A, #FFB800, #FFD45E, #FFE27A);
}
.macro-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ms-k {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}
.ms-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  line-height: 1.15;
}
.ms-v {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
}
.ms-v.nat { color: #F59E0B; }
.ms-v.spe { color: #5B9DF9; }
.ms-v.tot { color: #2E9E6B; }
.ms-u {
  font-size: 20rpx;
  font-weight: 500;
  color: #B0B0B0;
  margin-left: 4rpx;
}
.ms-c {
  font-size: 20rpx;
  color: #B0B0B0;
  font-weight: 600;
  margin-top: 2rpx;
}

/* 喂养进度 */
.feed-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.feed-meals {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.feed-meals-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.feed-n {
  font-size: 44rpx;
  font-weight: 800;
  color: #F59E0B;
}
.feed-t {
  font-size: 24rpx;
  color: #8A8A8A;
}
.feed-food {
  font-size: 22rpx;
  color: #2E9E6B;
  background: #E7F7EF;
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.dots {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: flex-end;
  max-width: 320rpx;
}
.dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}
.dot.done { background: #FFB800; color: #fff; }
.dot.todo { background: #FFF0BF; color: #D9A400; border: 2rpx dashed #E9C24D; }
.next {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #FFFBEF;
  border: 2rpx solid #FBE6A6;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
}
.next-l {
  flex: 1;
  min-width: 0;
}
.next-title {
  font-size: 25rpx;
  font-weight: 600;
  color: #444;
}
.next-chips {
  margin-top: 10rpx;
}
.chip {
  display: inline-block;
  font-size: 21rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 600;
}
.chip.breast { background: #FFF3D6; color: #C98A00; }
.calc-btn {
  flex: 0 0 auto;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #FFC93C, #FFB800);
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.36);
}

/* 快捷记录 */
.qgrid {
  display: flex;
  flex-wrap: wrap;
}
.qa {
  width: 25%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 0 16rpx;
}
.qa-ic {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.qa-ic.milk { background: #FFF3CC; }
.qa-ic.food { background: #E7F7EF; }
.qa-ic.med { background: #E8F1FE; }
.qa-ic.treat { background: #F0EBFF; }
.qa-ic.bowel { background: #FFF0E0; }
.qa-ic.weight { background: #FFE9ED; }
.qa-ic.height { background: #E3F6F5; }
.qa-ic.report { background: #FFF0E0; }
.qa-nm {
  font-size: 22rpx;
  color: #444;
  font-weight: 600;
}

/* 用药打卡 */
.med-badge {
  font-size: 22rpx;
  color: #2E9E6B;
  background: #E7F7EF;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
}
.med-badge.all-done {
  color: #fff;
  background: #4CC38A;
}
.med-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #F5F0E0;
}
.med-item:last-child { border-bottom: none; }
.med-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
}
.med-check.done { background: #4CC38A; }
.med-check.partial { background: #fff; border: 3rpx solid #4CC38A; }
.med-check.todo { background: #fff; border: 3rpx solid #E6D9B0; }
.med-tick {
  animation: tick-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
.med-check-half {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  background: #4CC38A;
}
@keyframes tick-pop {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.25); opacity: 1; }
  100% { transform: scale(1); }
}
.med-main {
  flex: 1;
  min-width: 0;
}
.med-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.med-name.done { color: #B0B0B0; text-decoration: line-through; }
.med-dose-count { font-size: 22rpx; color: #4CC38A; font-weight: 700; }
.med-dose {
  display: block;
  font-size: 22rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}
.med-pips {
  display: flex;
  gap: 6rpx;
  margin-top: 10rpx;
}
.med-pip {
  width: 28rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #ECE6D2;
  transition: background 0.3s ease;
}
.med-pip.on { background: #4CC38A; }
.med-right {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.med-time {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}
.med-cta {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #FFC93C, #FFB800);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(255, 184, 0, 0.3);
}
.med-cta.again {
  color: #2E9E6B;
  background: #E7F7EF;
  box-shadow: none;
}
/* 按压反馈 */
.med-press { background: #FFFCF2; }
.med-empty .empty-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 25rpx;
  color: #8A8A8A;
}
.empty-btn {
  font-size: 24rpx;
  color: #fff;
  background: #FFB800;
  padding: 12rpx 24rpx;
  border-radius: 14rpx;
  font-weight: 600;
}

/* 时间轴 */
.tl-empty {
  font-size: 24rpx;
  color: #B0B0B0;
  text-align: center;
  padding: 24rpx 0 8rpx;
}
.tl {
  max-height: 560rpx;
}
.tl-item {
  display: flex;
  gap: 16rpx;
}
.tl-time {
  flex: 0 0 auto;
  width: 76rpx;
  font-size: 22rpx;
  color: #B0B0B0;
  padding-top: 4rpx;
}
.tl-line {
  flex: 0 0 auto;
  width: 22rpx;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  position: relative;
}
.tl-line::before {
  content: '';
  position: absolute;
  top: 8rpx;
  bottom: -16rpx;
  width: 3rpx;
  background: #F0E6C8;
}
.tl-item:last-child .tl-line::before { display: none; }
.tl-node {
  flex: 0 0 auto;
  box-sizing: border-box;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #FFB800;
  margin-top: 8rpx;
  z-index: 1;
}
.tl-node.food { border-color: #4CC38A; }
.tl-node.med { border-color: #5B9DF9; }
.tl-node.treatment { border-color: #A78BFA; }
.tl-body {
  flex: 1;
  min-width: 0;
  padding-bottom: 24rpx;
}
.tl-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}
.tl-desc {
  display: block;
  font-size: 22rpx;
  color: #B0B0B0;
  margin-top: 4rpx;
}

/* 趋势 */
.trend-tabs {
  white-space: nowrap;
  margin-bottom: 22rpx;
}
.ttab {
  display: inline-block;
  margin-right: 10rpx;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #F5F0E0;
  color: #8A8A8A;
  transition: background 0.2s ease, color 0.2s ease;
}
.ttab.on {
  background: #FFB800;
  color: #fff;
  font-weight: 600;
}
.trend-bars {
  display: flex;
  align-items: flex-end;
  height: 200rpx;
  gap: 8rpx;
}
.trend-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}
.trend-bar-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}
.trend-val {
  font-size: 18rpx;
  color: #B07D00;
  margin-bottom: 6rpx;
}
.trend-bar {
  width: 48rpx;
  max-width: 70%;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #FFD45E, #FFB800);
  min-height: 8rpx;
  transition: height 0.55s cubic-bezier(0.22, 1, 0.36, 1);
}
.trend-bar.today {
  background: linear-gradient(180deg, #FF9F45, #F59E0B);
}
.trend-bar.empty {
  background: #F0EFE6;
  min-height: 8rpx;
}
.trend-label {
  font-size: 20rpx;
  color: #B0B0B0;
  margin-top: 10rpx;
}
.trend-label.today {
  color: #F59E0B;
  font-weight: 700;
}
.trend-foot {
  display: flex;
  margin-top: 22rpx;
  border-top: 2rpx solid #F5F0E0;
  padding-top: 18rpx;
}
.tf-it {
  flex: 1;
  text-align: center;
}
.tf-n {
  font-size: 30rpx;
  font-weight: 800;
  color: #333;
}
.tf-n.up { color: #4CC38A; }
.tf-u {
  font-size: 20rpx;
  font-weight: 500;
  color: #B0B0B0;
}
.tf-l {
  display: block;
  font-size: 20rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}

/* 更多 */
.more-grid {
  display: flex;
  flex-wrap: wrap;
}
.me {
  width: 25%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 0;
}
.me-ic {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: #FFFDF7;
  border: 2rpx solid #F3E7C0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.me-nm {
  font-size: 22rpx;
  color: #8A8A8A;
}

.foot-tip {
  text-align: center;
  font-size: 22rpx;
  color: #C8B888;
  margin: 20rpx 0;
}

/* 体重弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.weight-modal {
  width: 560rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx 32rpx;
}
.wm-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  display: block;
}
.wm-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFF9E6;
  border: 2rpx solid #FBE6A6;
  border-radius: 18rpx;
  padding: 16rpx 24rpx;
  margin: 32rpx 0;
}
.wm-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}
.wm-unit {
  font-size: 26rpx;
  color: #B0B0B0;
}
.wm-actions {
  display: flex;
  gap: 20rpx;
}
.wm-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-weight: 600;
}
.wm-btn.cancel {
  background: #F4F1E8;
  color: #8A8A8A;
}
.wm-btn.confirm {
  background: linear-gradient(135deg, #FFC93C, #FFB800);
  color: #fff;
}

/* ===== 全局微动效（纯 WXSS，无三方依赖） ===== */
/* 卡片入场：轻微上浮淡入。挂在 .anim-on 下，onShow 时先卸下再挂上即可重播。 */
.anim-on .notice,
.anim-on .hero,
.anim-on .card {
  animation: home-rise 0.45s ease-out both;
}
@keyframes home-rise {
  from { opacity: 0; transform: translateY(18rpx); }
  to { opacity: 1; transform: none; }
}

/* 按压反馈：轻缩放 + 透明度（配合 hover-class 使用）
   transition 写在基础元素上，按下/松开两个方向都平滑 */
.baby-card,
.weight-chip,
.calc-btn,
.qa,
.me {
  transition: transform 0.14s ease, opacity 0.14s ease;
}
.press-soft {
  transform: scale(0.97);
  opacity: 0.92;
}
.press-pop {
  transform: scale(0.92);
  opacity: 0.85;
}
