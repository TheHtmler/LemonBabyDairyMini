}
.trend-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}
.trend-bar-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}
.trend-val {
  font-size: 18rpx;
  color: #B07D00;
  margin-bottom: 6rpx;
}
.trend-bar {
  width: 48rpx;
  max-width: 70%;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
