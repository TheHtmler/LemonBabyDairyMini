  text-align: center;
}
.tf-n {
  font-size: 30rpx;
  font-weight: 800;
  color: #333;
}
.tf-n.up { color: #4CC38A; }
.tf-u {
  font-size: 20rpx;
  font-weight: 500;
  color: #B0B0B0;
}
.tf-c {
  display: block;
  font-size: 19rpx;
  font-weight: 700;
  color: #FF9F45;
  margin-top: 3rpx;
  min-height: 24rpx;
}
.tf-cu {
  font-size: 17rpx;
  font-weight: 500;
  color: #C9A06A;
}
.tf-l {
  display: block;
  font-size: 20rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}

/* 更多 */
.more-grid {
