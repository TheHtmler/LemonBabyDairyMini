.qa-ic.food { background: #E7F7EF; }
.qa-ic.med { background: #E8F1FE; }
.qa-ic.treat { background: #F0EBFF; }
.qa-ic.bowel { background: #FFF0E0; }
.qa-ic.water { background: #E3F4FF; }
.qa-ic.mark { background: #FFF3D6; }
.qa-ic.weight { background: #FFE9ED; }
.qa-ic.height { background: #E3F6F5; }
.qa-ic.remind { background: #FFF0E0; }
.qa-ic.report { background: #FFF0E0; }
.qa-ic.powder { background: #F0EBFF; }
.qa-ic.foods { background: #E7F7EF; }
.qa-ic.medcfg { background: #E8F1FE; }
.qa-ic.growth { background: #E8F8EE; }
.qa-ic.diary { background: #FFF3CC; }
.qa-ic.emergency { background: #FFE9ED; }
.qa-ic.member { background: #E3F6F5; }
.qa-nm {
  font-size: 20rpx;
  color: #444;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
  white-space: normal;
}

/* 用药打卡 */
.med-badge {
  font-size: 22rpx;
  color: #2E9E6B;
  background: #E7F7EF;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
}
.med-badge.all-done {
  color: #fff;
  background: #4CC38A;
}
.med-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #F5F0E0;
}
.med-item:last-child { border-bottom: none; }
.med-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
}
.med-check.done { background: #4CC38A; }
.med-check.partial { background: #fff; border: 3rpx solid #4CC38A; }
.med-check.todo { background: #fff; border: 3rpx solid #E6D9B0; }
.med-tick {
  animation: tick-pop 0.28s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.med-check-half {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  background: #4CC38A;
}
@keyframes tick-pop {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.med-main {
  flex: 1;
  min-width: 0;
}
.med-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.med-name.done { color: #B0B0B0; text-decoration: line-through; }
.med-dose-count { font-size: 22rpx; color: #4CC38A; font-weight: 700; }
.med-dose {
  display: block;
  font-size: 22rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}
.med-pips {
  display: flex;
  gap: 6rpx;
  margin-top: 10rpx;
}
.med-pip {
  width: 28rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #ECE6D2;
  transition: background 0.3s ease;
}
.med-pip.on { background: #4CC38A; }
.med-right {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.med-time {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}
.med-cta {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #FFC93C, #FFB800);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(255, 184, 0, 0.3);
}
.med-cta.again {
  color: #2E9E6B;
  background: #E7F7EF;
  box-shadow: none;
}
/* 按压反馈 */
.med-press { background: #FFFCF2; transform: scale(0.99); transition: transform 0.1s ease; }
.med-hint {
  display: block;
  font-size: 21rpx;
  color: #B7AE96;
  margin: -4rpx 0 8rpx;
}

/* 打卡撤销条 */
.med-undo {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: -160rpx;
  z-index: 200;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(38, 38, 38, 0.94);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.28);
  opacity: 0;
  transition: bottom 0.32s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.28s ease;
}
.med-undo.show {
  bottom: 48rpx;
  opacity: 1;
}
.med-undo-icon {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: #4CC38A;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.med-undo-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.med-undo-title {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}
.med-undo-sub {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2rpx;
}
.med-undo-btn {
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFD45E;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 212, 94, 0.16);
}

/* 行右侧操作区：打卡 + 查看 */
.med-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.med-cta.done-edit {
  color: #9A9A9A;
  background: #F2F2F2;
  box-shadow: none;
}
.med-view {
  font-size: 22rpx;
  font-weight: 700;
  color: #6E8BBF;
  background: #EEF3FB;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

/* 用药打卡面板（底部弹层） */
.mp-mask {
  position: fixed;
  inset: 0;
  z-index: 300;
  background: rgba(0, 0, 0, 0);
  visibility: hidden;
  transition: background 0.28s ease, visibility 0s linear 0.28s;
}
.mp-mask.show {
  background: rgba(0, 0, 0, 0.42);
  visibility: visible;
  transition: background 0.28s ease;
}
.mp-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFDF6;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.12);
}
.mp-sheet.show { transform: translateY(0); }
.mp-grip {
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #E7E0CC;
  margin: 4rpx auto 18rpx;
}
.mp-head { margin-bottom: 18rpx; }
.mp-title { font-size: 32rpx; font-weight: 800; color: #3A3326; }
.mp-meta { display: block; font-size: 23rpx; color: #9A9079; margin-top: 6rpx; }
.mp-section { display: block; font-size: 24rpx; font-weight: 700; color: #6E6550; margin: 8rpx 0 12rpx; }
.mp-empty { font-size: 24rpx; color: #B7AE96; padding: 16rpx 0; }
.mp-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F3EEDD;
}
.mp-entry-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #3A3326;
}
.mp-entry-ops {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.mp-entry-edit {
  font-size: 24rpx;
  color: #FFB800;
  background: #FFF4D6;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}
.mp-entry-del {
  font-size: 24rpx;
  color: #E8654F;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #FCEBE7;
}
.mp-close {
  margin-top: 22rpx;
  text-align: center;
  font-size: 27rpx;
  color: #9A9079;
  padding: 20rpx 0 4rpx;
}
.med-empty .empty-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 25rpx;
  color: #8A8A8A;
}
.empty-btn {
  font-size: 24rpx;
  color: #fff;
  background: #FFB800;
  padding: 12rpx 24rpx;
  border-radius: 14rpx;
