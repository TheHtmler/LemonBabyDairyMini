/* 体重弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.weight-modal {
  width: 560rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx 32rpx;
}
.wm-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  display: block;
}
.wm-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFF9E6;
  border: 2rpx solid #FBE6A6;
  border-radius: 18rpx;
  padding: 16rpx 24rpx;
  margin: 32rpx 0;
}
.wm-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}
.wm-unit {
  font-size: 26rpx;
  color: #B0B0B0;
}
.wm-actions {
  display: flex;
  gap: 20rpx;
}
.wm-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  padding: 20rpx 0;
