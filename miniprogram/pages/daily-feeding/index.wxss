}
.wm-btn.cancel {
  background: #F4F1E8;
  color: #8A8A8A;
}
.wm-btn.confirm {
  background: linear-gradient(135deg, #FFC93C, #FFB800);
  color: #fff;
}

/* ===== 全局微动效（纯 WXSS，无三方依赖） ===== */
/* 卡片入场：轻微上浮淡入。挂在 .anim-on 下，onShow 时先卸下再挂上即可重播。 */
.anim-on .notice,
.anim-on .hero,
.anim-on .card {
  animation: home-rise 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.anim-on .hero {
  animation-delay: 0.04s;
}
.anim-on .hero-nutri {
  animation-delay: 0.08s;
}
@keyframes home-rise {
  from { opacity: 0; transform: translateY(18rpx); }
  to { opacity: 1; transform: none; }
}

/* 按压反馈：轻缩放 + 透明度（配合 hover-class 使用）
   transition 写在基础元素上，按下/松开两个方向都平滑 */
.baby-card,
.weight-chip,
.calc-btn,
.qa,
.me {
  transition: transform 0.14s ease, opacity 0.14s ease;
}
.press-soft {
  transform: scale(0.97);
  opacity: 0.92;
}
.press-pop {
  transform: scale(0.92);
  opacity: 0.85;
}

@media (prefers-reduced-motion: reduce) {
  .home-boot-card,
  .home-milk-lemon-art,
  .notice-track,
  .baby-avatar,
  .anim-on .notice,
  .anim-on .hero,
  .anim-on .card,
  .anim-on .ring,
  .med-tick {
    animation-duration: 0.01ms;
    animation-iteration-count: 1;
  }
}
