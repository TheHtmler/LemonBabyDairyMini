page {
  background: #FFF9E6;
}

.home {
  padding: 20rpx 24rpx 60rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.home.data-pending .baby-card,
.home.data-pending .card {
  position: relative;
  overflow: hidden;
}

.home.data-pending .baby-card::after,
.home.data-pending .card::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: -45%;
  width: 42%;
  background: linear-gradient(90deg, transparent, rgba(255, 236, 179, 0.42), transparent);
  animation: home-skeleton-shimmer 1.2s ease-in-out infinite;
  pointer-events: none;
}

.home.data-pending .baby-name,
.home.data-pending .baby-sub,
.home.data-pending .ring,
.home.data-pending .macro-stat,
.home.data-pending .qa,
.home.data-pending .feed-top,
.home.data-pending .next,
.home.data-pending .trend {
  opacity: 0.48;
}

@keyframes home-skeleton-shimmer {
  from { transform: translateX(0); }
  to { transform: translateX(340%); }
}

.home-boot-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 24% 18%, rgba(255, 232, 143, 0.72), transparent 30%),
    radial-gradient(circle at 78% 76%, rgba(181, 226, 140, 0.24), transparent 28%),
    linear-gradient(180deg, #FFF9E6 0%, #FFF1C6 100%);
}
.home-boot-card {
  width: 520rpx;
  max-width: 100%;
  padding: 24rpx 42rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
  text-align: center;
  animation: boot-card-in 0.42s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.lemon-loader {
  position: relative;
  width: 280rpx;
  height: 230rpx;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lemon-loader::before {
  content: '';
  position: absolute;
  width: 260rpx;
  height: 162rpx;
  border-radius: 50%;
  background: rgba(255, 214, 102, 0.24);
  filter: blur(34rpx);
  transform: translateY(30rpx);
}
.home-milk-lemon-art {
  position: relative;
  width: 270rpx;
  height: 218rpx;
  animation: lemon-breathe 2.2s ease-in-out infinite;
  filter: drop-shadow(0 10rpx 18rpx rgba(255, 184, 0, 0.2));
}
.home-boot-title {
  display: block;
  font-size: 31rpx;
  color: #8A6200;
  font-weight: 800;
}
.home-boot-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #B07D00;
}
@keyframes boot-card-in {
  from { opacity: 0; transform: translateY(20rpx) scale(0.98); }
  to { opacity: 1; transform: none; }
}
@keyframes lemon-breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.045); }
}
/* 公告（单行跑马灯） */
.notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(90deg, rgba(255, 184, 0, 0.95), rgba(255, 205, 64, 0.95));
  border-radius: 16rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.16);
  overflow: hidden;
}
.notice-fixed {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-right: 14rpx;
  border-right: 2rpx solid rgba(255, 255, 255, 0.45);
}
.notice-prefix {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}
.notice-marquee {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.notice-track {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  will-change: transform;
  animation: notice-scroll 18s linear infinite;
}
.notice-copy {
  flex-shrink: 0;
  padding-right: 80rpx;
  font-size: 23rpx;
  color: #fff;
  font-weight: 500;
}
@keyframes notice-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* 宝宝卡（含问候语） */
.hero {
  margin-bottom: 22rpx;
}
.baby-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: linear-gradient(135deg, #FFFDF5, #FFF1C6);
  border: 2rpx solid #FBE6A6;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(255, 184, 0, 0.14);
}
.baby-greet {
  font-size: 22rpx;
  color: #B07D00;
  margin-bottom: 8rpx;
}
.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #FFE27A;
  flex: 0 0 auto;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.32);
  animation: baby-breathe 3.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
}
@keyframes baby-breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}
.baby-main {
  flex: 1;
  min-width: 0;
}
.baby-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.baby-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.baby-gender {
  font-size: 20rpx;
  color: #8A8A8A;
  background: #F0EFE6;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}
.baby-gender.male {
  color: #5B9DF9;
  background: #E8F1FE;
}
.baby-gender.female {
  color: #FF6F8B;
  background: #FFE9ED;
}
.baby-sub {
  font-size: 24rpx;
  color: #8A8A8A;
  margin-top: 8rpx;
}
.baby-days {
  flex: 0 0 auto;
  text-align: center;
  background: #fff;
  border: 2rpx solid #FBE6A6;
  border-radius: 18rpx;
  padding: 12rpx 18rpx;
}
.baby-days-n {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #F59E0B;
  line-height: 1;
}
.baby-days-l {
  display: block;
  font-size: 18rpx;
  color: #B0B0B0;
  margin-top: 6rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 26rpx 24rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 184, 0, 0.1);
  border: 2rpx solid rgba(255, 184, 0, 0.1);
}
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}
.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: #FFB800;
}
.card-more {
  font-size: 24rpx;
  color: #B0B0B0;
}

/* 营养达成 */
.metric-chips {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.weight-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 23rpx;
  color: #B07D00;
  background: #FFF3D6;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}
.weight-chip.alt {
  color: #2E9E6B;
  background: #E7F7EF;
}
.weight-chip.alt .weight-edit {
  color: #2E9E6B;
}
.weight-edit {
  font-size: 22rpx;
  color: #D9A400;
}
.target-empty {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFF7DD, #FFF0C4);
  border: 2rpx dashed rgba(255, 184, 0, 0.42);
}
.target-empty-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.target-empty-title {
  font-size: 24rpx;
  color: #9A6C0C;
  font-weight: 800;
}
.target-empty-desc {
  font-size: 20rpx;
  color: #B07D00;
  line-height: 1.35;
}
.target-empty-action {
  flex: 0 0 auto;
  font-size: 23rpx;
  color: #fff;
  background: linear-gradient(135deg, #FFB800, #F59E0B);
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.22);
}
.target-tabs {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #FFF7DD;
  border-radius: 18rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}
.target-tab {
  flex: 1;
  text-align: center;
  font-size: 23rpx;
  color: #B07D00;
  background: rgba(255, 255, 255, 0.62);
  border-radius: 14rpx;
  padding: 10rpx 8rpx;
  font-weight: 700;
}
.target-tab.on {
  color: #fff;
  background: linear-gradient(135deg, #FFB800, #F59E0B);
  box-shadow: 0 6rpx 12rpx rgba(255, 184, 0, 0.2);
}
.target-tab.disabled {
  color: #C9B98F;
  background: rgba(255, 255, 255, 0.42);
}
.target-tab.setup {
  flex: 0 0 88rpx;
  color: #2E9E6B;
  background: #E7F7EF;
}
.nutri-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.ring {
  flex: 0 0 auto;
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.anim-on .ring {
  animation: ring-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes ring-pop {
  0% { transform: scale(0.82); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.ring-hole {
  width: 140rpx;
  height: 140rpx;
  box-sizing: border-box;
  padding-top: 8rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.ring-big {
  font-size: 38rpx;
  font-weight: 800;
  color: #F59E0B;
  line-height: 1;
}
.target-pct-text {
  max-width: 124rpx;
  font-size: 34rpx;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  letter-spacing: -1rpx;
}
.ring-unit {
  font-size: 18rpx;
  color: #B0B0B0;
  margin-top: 0;
}
.ring-lbl {
  font-size: 22rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}
/* 热量系数：移进圆环中心（去掉环下吊牌） */
.ring-perkg {
  font-size: 18rpx;
  color: #FF9F45;
  font-weight: 700;
  margin-top: 2rpx;
}
.ring-col {
  flex: 0 0 184rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.ring-cap {
  font-size: 20rpx;
  color: #B07A00;
  background: #FFF4D6;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}
.macro-list {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.macro-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.macro-k {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}
.macro-v {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
}
.macro-sub {
  font-size: 20rpx;
  color: #B0B0B0;
  font-weight: 500;
}
.bar {
  height: 14rpx;
  border-radius: 999rpx;
  background: #F0EFE6;
  overflow: hidden;
}
.bar-i {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.bar-i.nat { background: linear-gradient(90deg, #FFD45E, #FFB800); }
.bar-i.spe { background: linear-gradient(90deg, #8FD3FF, #5B9DF9); }
.bar-i.cal { background: linear-gradient(90deg, #FFB27A, #FF9F45); }

/* 今日营养摄入：实际值（无目标进度） */
.ring.static {
  background: conic-gradient(from 180deg, #FFE27A, #FFB800, #FFD45E, #FFE27A);
}
.ring.target-ring {
  box-shadow: inset 0 0 0 2rpx rgba(255, 184, 0, 0.12), 0 8rpx 18rpx rgba(255, 184, 0, 0.16);
}
.ring.target-ring.done {
  box-shadow: inset 0 0 0 2rpx rgba(46, 158, 107, 0.12), 0 8rpx 18rpx rgba(46, 158, 107, 0.14);
}
.ring.target-ring.over {
  box-shadow: inset 0 0 0 2rpx rgba(255, 122, 26, 0.14), 0 8rpx 18rpx rgba(255, 122, 26, 0.15);
}
.ring-status {
  font-size: 18rpx;
  font-weight: 800;
  margin-top: 2rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
}
.ring-status-below {
  max-width: 184rpx;
  box-sizing: border-box;
  margin-top: 0;
  padding: 5rpx 14rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ring-status.pending {
  color: #B07D00;
  background: #FFF3D6;
}
.ring-status.done {
  color: #2E9E6B;
  background: #E7F7EF;
}
.ring-status.over {
  color: #D46B2C;
  background: #FFF0E8;
}
.macro-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ms-k {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}
.ms-right {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 12rpx;
  line-height: 1.15;
}
.ms-v {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
}
.ms-v.nat { color: #F59E0B; }
.ms-v.spe { color: #5B9DF9; }
.ms-v.tot { color: #2E9E6B; }
.ms-u {
  font-size: 20rpx;
  font-weight: 500;
  color: #B0B0B0;
  margin-left: 4rpx;
}
.ms-c {
  font-size: 20rpx;
  color: #B0B0B0;
  font-weight: 600;
  margin-top: 0;
}
.target-list {
  gap: 14rpx;
}
.target-stat {
  background: #FFFDF5;
  border: 2rpx solid rgba(255, 184, 0, 0.1);
  border-radius: 18rpx;
  padding: 14rpx;
}
.target-stat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.target-stat-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #333;
}
.target-stat-title.nat { color: #F59E0B; }
.target-stat-title.spe { color: #5B9DF9; }
.target-stat-title.cal { color: #FF7A1A; }
.target-stat-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.target-stat-pct {
  font-size: 22rpx;
  font-weight: 900;
  color: #F59E0B;
  background: #FFF3D6;
  border-radius: 999rpx;
  padding: 3rpx 12rpx;
}
.target-stat-pct.done {
  color: #2E9E6B;
  background: #E7F7EF;
}
.target-stat-pct.over {
  color: #D46B2C;
  background: #FFF0E8;
}
.target-stat-tip {
  font-size: 20rpx;
  font-weight: 800;
  color: #B07D00;
}
.target-stat-tip.done {
  color: #2E9E6B;
}
.target-stat-tip.over {
  color: #D46B2C;
}
.target-values {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 10rpx;
}
.target-value {
  min-width: 0;
  background: #F8F6EF;
  border-radius: 12rpx;
  padding: 8rpx 6rpx;
  text-align: center;
}
.target-value.target {
  background: linear-gradient(135deg, #FFF3D6, #FFE5A3);
  border: 2rpx solid rgba(255, 184, 0, 0.24);
  padding: 6rpx 4rpx;
}
.target-value.remain {
  background: #FFF0E8;
}
.target-stat .target-value.remain .target-value-label,
.target-stat .target-value.remain .target-value-number {
  color: #D46B2C;
}
.target-value-label {
  display: block;
  font-size: 18rpx;
  color: #8A8A8A;
  font-weight: 700;
  margin-bottom: 2rpx;
}
.target-value.target .target-value-label,
.target-value.target .target-value-number {
  color: #B36B00;
}
.target-value.remain .target-value-label,
.target-value.remain .target-value-number {
  color: #D46B2C;
}
.target-value-number {
  display: block;
  font-size: 21rpx;
  color: #333;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.target-bar {
  position: relative;
  height: 14rpx;
  border-radius: 999rpx;
  background: #F0EFE6;
  overflow: hidden;
}
.target-bar-i {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.target-bar-over {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: 999rpx;
  background: repeating-linear-gradient(
    45deg,
    #FF7A1A 0,
    #FF7A1A 8rpx,
    #FFC18F 8rpx,
    #FFC18F 16rpx
  );
  opacity: 0.9;
}
.target-bar-i.tot { background: linear-gradient(90deg, #FFCE4F, #FFB800); }
.target-bar-i.nat { background: linear-gradient(90deg, #FFD45E, #FFB800); }
.target-bar-i.spe { background: linear-gradient(90deg, #8FD3FF, #5B9DF9); }
.target-bar-i.cal { background: linear-gradient(90deg, #FFB27A, #FF9F45); }
.target-helper {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #A68A52;
  line-height: 1.35;
}
.target-helper.done {
  color: #2E9E6B;
}
.target-helper.over {
  color: #D46B2C;
}

/* 喂养进度 */
.feed-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.feed-meals {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.feed-meals-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.feed-n {
  font-size: 44rpx;
  font-weight: 800;
  color: #F59E0B;
}
.feed-t {
  font-size: 24rpx;
  color: #8A8A8A;
}
.feed-food {
  font-size: 22rpx;
  color: #2E9E6B;
  background: #E7F7EF;
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.dots {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: flex-end;
  max-width: 320rpx;
}
.dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}
.dot.done { background: #FFB800; color: #fff; }
.dot.todo { background: #FFF0BF; color: #D9A400; border: 2rpx dashed #E9C24D; }
.next {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #FFFBEF;
  border: 2rpx solid #FBE6A6;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
}
.next-l {
  flex: 1;
  min-width: 0;
}
.next-title {
  font-size: 25rpx;
  font-weight: 600;
  color: #444;
}
.next-chips {
  margin-top: 10rpx;
}
.chip {
  display: inline-block;
  font-size: 21rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 600;
}
.chip.breast { background: #FFF3D6; color: #C98A00; }
.calc-btn {
  flex: 0 0 auto;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #FFC93C, #FFB800);
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 14rpx rgba(255, 184, 0, 0.36);
}
/* 快捷记录 */
.qscroll-hint {
  font-size: 22rpx;
  color: #C8C0B0;
  font-weight: 400;
}
.qscroll {
  width: 100%;
  white-space: nowrap;
}
.qgrid {
