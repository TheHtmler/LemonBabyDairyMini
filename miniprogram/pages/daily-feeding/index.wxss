}

/* 时间轴 */
.tl-empty {
  font-size: 24rpx;
  color: #B0B0B0;
  text-align: center;
  padding: 24rpx 0 8rpx;
}
.tl {
  max-height: 560rpx;
}
.tl-entry:last-child .tl-body {
  padding-bottom: 0;
}
.tl-item {
  display: flex;
  gap: 16rpx;
}
.tl-time {
  flex: 0 0 auto;
  width: 76rpx;
  font-size: 22rpx;
  color: #B0B0B0;
  padding-top: 4rpx;
}
.tl-line {
  flex: 0 0 auto;
  width: 22rpx;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  position: relative;
}
.tl-line::before {
  content: '';
