<view class="home {{animReady ? 'anim-on' : ''}} {{homeDataReady ? 'data-ready' : 'data-pending'}}">
  <view class="home-boot-mask" wx:if="{{isHomeBooting}}">
    <view class="home-boot-card">
      <view class="lemon-loader">
        <image class="home-milk-lemon-art" src="/images/milk-lemon-loading.png" mode="aspectFit"></image>
      </view>
      <text class="home-boot-title">柠檬宝宝正在准备今日记录</text>
      <text class="home-boot-sub">{{homeLoadingText || '马上就好啦～'}}</text>
    </view>
  </view>

  <!-- 公告（单行跑马灯，与旧版一致） -->
  <view class="notice" wx:if="{{releaseNoticeVisible && releaseNoticeText}}">
    <view class="notice-fixed"><text class="notice-prefix">公告</text></view>
    <view class="notice-marquee">
      <view class="notice-track">
        <text class="notice-copy">{{releaseNoticeText}}</text>
        <text class="notice-copy">{{releaseNoticeText}}</text>
      </view>
    </view>
  </view>

  <!-- 宝宝卡（问候语并入卡片内部） -->
  <view class="hero">
    <view class="baby-card" bindtap="navigateToBabyInfo" hover-class="press-soft" hover-stay-time="80">
      <image class="baby-avatar" src="{{babyAvatarUrl || '/images/LemonLogo.png'}}" mode="aspectFill"></image>
      <view class="baby-main">
        <view class="baby-greet">{{greetingText}}</view>
        <view class="baby-name-row">
          <text class="baby-name">{{babyName || '柠檬宝宝'}}</text>
          <text class="baby-gender {{babyGenderClass}}" wx:if="{{babyGender}}">{{babyGender}}</text>
        </view>
        <view class="baby-sub">
          <text wx:if="{{babyBirthdayText}}">{{babyBirthdayText}}</text>
          <text wx:if="{{babyBirthdayText && babyAgeMonthsText}}"> · </text>
          <text wx:if="{{babyAgeMonthsText}}">{{babyAgeMonthsText}}</text>
        </view>
      </view>
      <view class="baby-days">
        <text class="baby-days-n">{{babyDays}}</text>
        <text class="baby-days-l">已出生(天)</text>
      </view>
    </view>
  </view>

  <!-- 今日营养摄入：未设置目标时显示实际值，设置目标后显示目标进度 -->
  <view class="card hero-nutri">
    <view class="card-head">
      <text class="card-title">{{nutritionTarget.hasAnyTarget ? '今日目标进度' : '今日营养摄入'}}</text>
      <view class="metric-chips">
        <view class="weight-chip" catchtap="openWeightModal" hover-class="press-soft" hover-stay-time="60">
          <text>体重 {{weight ? weight : '--'}}kg</text>
          <text class="weight-edit">✎</text>
        </view>
        <view class="weight-chip alt" catchtap="openHeightModal" hover-class="press-soft" hover-stay-time="60">
          <text>身高 {{height ? height : '--'}}cm</text>
          <text class="weight-edit">✎</text>
        </view>
      </view>
    </view>
    <view class="target-tabs" wx:if="{{nutritionTarget.hasAnyTarget}}">
      <view class="target-tab {{nutritionTarget.mode === 'protein' ? 'on' : ''}} {{nutritionTarget.configuredModes.protein ? '' : 'disabled'}}" data-mode="protein" catchtap="switchNutritionTargetMode">蛋白目标</view>
      <view class="target-tab {{nutritionTarget.mode === 'calorie' ? 'on' : ''}} {{nutritionTarget.configuredModes.calorie ? '' : 'disabled'}}" data-mode="calorie" catchtap="switchNutritionTargetMode">热量目标</view>
      <view class="target-tab setup" catchtap="openNutritionTargetSetup">设置</view>
    </view>
    <view class="nutri-row">
      <view class="ring-col">
        <view class="ring static" wx:if="{{!nutritionTarget.hasAnyTarget}}">
          <view class="ring-hole">
            <text class="ring-big">{{nutrition.calories || 0}}</text>
            <text class="ring-unit">kcal</text>
            <text class="ring-perkg">{{nutrition.caloriesPerKg || 0}} kcal/kg</text>
          </view>
        </view>
        <view class="ring target-ring {{nutritionTarget.activeGoal.ringClass}}" wx:else style="background: conic-gradient(from 180deg, #FF7A1A 0% {{nutritionTarget.activeGoal.overPct}}%, transparent {{nutritionTarget.activeGoal.overPct}}% 100%), conic-gradient(from 180deg, #FFB800 0% {{nutritionTarget.activeGoal.ringPct}}%, #F7EDD4 {{nutritionTarget.activeGoal.ringPct}}% 100%);">
          <view class="ring-hole">
            <text class="ring-big">{{nutritionTarget.activeGoal.pct || 0}}%</text>
            <text class="ring-unit">{{nutritionTarget.activeGoal.label}}</text>
            <text class="ring-status {{nutritionTarget.activeGoal.status}}">{{nutritionTarget.activeGoal.statusText}}</text>
          </view>
        </view>
      </view>
      <view class="macro-list" wx:if="{{!nutritionTarget.hasAnyTarget}}">
        <view class="macro-stat">
          <text class="ms-k">天然蛋白</text>
          <view class="ms-right">
            <text class="ms-v nat">{{nutrition.naturalProtein || 0}}<text class="ms-u">g</text></text>
            <text class="ms-c">{{nutrition.naturalProteinPerKg || 0}} g/kg</text>
          </view>
        </view>
        <view class="macro-stat">
          <text class="ms-k">特殊蛋白</text>
          <view class="ms-right">
            <text class="ms-v spe">{{nutrition.specialProtein || 0}}<text class="ms-u">g</text></text>
            <text class="ms-c">{{nutrition.specialProteinPerKg || 0}} g/kg</text>
          </view>
        </view>
        <view class="macro-stat">
          <text class="ms-k">总蛋白</text>
          <view class="ms-right">
            <text class="ms-v tot">{{nutrition.totalProtein || 0}}<text class="ms-u">g</text></text>
            <text class="ms-c">{{nutrition.totalProteinPerKg || 0}} g/kg</text>
          </view>
        </view>
      </view>
      <view class="macro-list target-list" wx:else>
        <view class="target-stat" wx:for="{{nutritionTarget.rows}}" wx:key="key">
          <view class="target-stat-head">
            <text class="target-stat-title {{item.tone}}">{{item.label}}</text>
            <view class="target-stat-status">
              <text class="target-stat-pct {{item.status}}">{{item.pctText}}</text>
              <text class="target-stat-tip {{item.status}}">{{item.statusText}}</text>
            </view>
          </view>
          <view class="target-values">
            <view class="target-value">
              <text class="target-value-label">已摄入</text>
              <text class="target-value-number">{{item.valueText}}</text>
            </view>
            <view class="target-value target">
              <text class="target-value-label">目标</text>
              <text class="target-value-number">{{item.targetText}}</text>
            </view>
            <view class="target-value remain">
              <text class="target-value-label">{{item.remainingLabel}}</text>
              <text class="target-value-number">{{item.remainingText}}</text>
            </view>
          </view>
          <view class="target-bar" wx:if="{{item.hasTarget}}">
            <view class="target-bar-i {{item.tone}}" style="width: {{item.barPct}}%;"></view>
            <view class="target-bar-over" wx:if="{{item.overPct > 0}}" style="width: {{item.overPct}}%;"></view>
          </view>
          <text class="target-helper {{item.status}}">{{item.helperText}}</text>
        </view>
      </view>
    </view>
    <view class="target-empty" wx:if="{{!nutritionTarget.hasAnyTarget}}" catchtap="openNutritionTargetSetup" hover-class="press-soft" hover-stay-time="60">
      <view class="target-empty-copy">
        <text class="target-empty-title">还没有设置今日目标</text>
        <text class="target-empty-desc">设置蛋白或热量系数后，可查看完成度和还差多少</text>
      </view>
      <text class="target-empty-action">设置目标 ›</text>
    </view>
  </view>

  <!-- 快捷记录（前置到营养卡下方，保证首屏可见） -->
  <view class="card">
    <view class="card-head"><text class="card-title">快捷记录</text></view>
    <view class="qgrid">
      <view class="qa" bindtap="navigateToMilkFeedingEditor" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic milk">🍼</view><text class="qa-nm">记一顿奶</text>
      </view>
      <view class="qa" bindtap="navigateToMealEditor" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic food">🥣</view><text class="qa-nm">加食物</text>
      </view>
      <view class="qa" bindtap="openMedicationModal" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic med">💊</view><text class="qa-nm">喂药</text>
      </view>
      <view class="qa" bindtap="navigateToTreatmentRecord" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic treat">🩺</view><text class="qa-nm">治疗</text>
      </view>
      <view class="qa" bindtap="navigateToBowelRecord" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic bowel">💩</view><text class="qa-nm">记尿布</text>
      </view>
      <view class="qa" bindtap="openWeightModal" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic weight">⚖️</view><text class="qa-nm">量体重</text>
      </view>
      <view class="qa" bindtap="openHeightModal" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic height">📏</view><text class="qa-nm">量身高</text>
      </view>
      <view class="qa" bindtap="goToReport" hover-class="press-pop" hover-stay-time="60">
        <view class="qa-ic report">📊</view><text class="qa-nm">检测报告</text>
      </view>
    </view>
  </view>

  <!-- 今日喂养进度 -->
  <view class="card feed">
    <view class="card-head">
      <text class="card-title">今日喂养进度</text>
      <text class="card-more" catchtap="goToDataRecords">查看明细 ›</text>
    </view>
    <view class="feed-top">
      <view class="feed-meals">
        <view class="feed-meals-row">
          <text class="feed-n">{{feedingProgress.count}}</text>
          <text class="feed-t">/ {{feedingProgress.plannedMeals}} 顿奶 · 已喂 {{feedingProgress.totalVolume}}ml</text>
        </view>
        <text class="feed-food">🥣 今日辅食 {{foodCount}} 次</text>
      </view>
      <view class="dots">
        <view class="dot {{item.done ? 'done' : 'todo'}}" wx:for="{{feedingProgress.dots}}" wx:key="index">
          <text wx:if="{{item.done}}">✓</text>
          <text wx:else>{{item.index}}</text>
        </view>
      </view>
    </view>
    <view class="next">
      <view class="next-l">
        <text class="next-title" wx:if="{{feedingPlanHint.hasPlan}}">下一顿（第{{feedingPlanHint.seq}}顿）参考 · {{feedingPlanHint.text}}</text>
        <text class="next-title" wx:else>还没有历史喂奶记录，先记一顿或去算补奶</text>
        <view class="next-chips" wx:if="{{feedingPlanHint.hasPlan}}">
          <text class="chip breast" wx:if="{{feedingPlanHint.exceeded}}">已超出上次顿数 · 参考末顿 {{feedingPlanHint.total}}ml</text>
          <text class="chip breast" wx:else>参考上次第{{feedingPlanHint.seq}}顿 · {{feedingPlanHint.total}}ml</text>
        </view>
      </view>
      <view class="calc-btn" catchtap="navigateToMilkGoalPlanner" hover-class="press-soft" hover-stay-time="60">算补奶 ›</view>
    </view>
  </view>

  <!-- 今日用药打卡 -->
  <view class="card" wx:if="{{medicationChecklist.totalCount > 0}}">
    <view class="card-head">
      <text class="card-title">今日用药打卡</text>
      <text class="med-badge {{medicationChecklist.allDone ? 'all-done' : ''}}">{{medicationChecklist.doneCount}}/{{medicationChecklist.totalCount}} 已完成</text>
    </view>
    <text class="med-hint">点「打卡」即时记录 · 点「查看」可改时间/删除某一次</text>
    <view class="med-item {{item.status}}" wx:for="{{medicationChecklist.todayItems}}" wx:key="medicationId" data-id="{{item.medicationId}}" hover-class="med-press" hover-stay-time="60">
      <view class="med-check {{item.status}}">
        <text class="med-tick" wx:if="{{item.completed}}">✓</text>
        <view class="med-check-half" wx:elif="{{item.doseCount > 0}}"></view>
      </view>
      <view class="med-main">
        <text class="med-name {{item.completed ? 'done' : ''}}">{{item.name}}<text class="med-dose-count" wx:if="{{item.doseTotal > 1}}"> {{item.doseCount}}/{{item.doseTotal}}</text></text>
        <text class="med-dose">{{item.dosage}}{{item.unit}} · {{item.frequencyText}}</text>
        <view class="med-pips" wx:if="{{item.doseTotal > 1}}">
          <view class="med-pip {{pip.on ? 'on' : ''}}" wx:for="{{item.dosePips}}" wx:for-item="pip" wx:for-index="pidx" wx:key="pidx"></view>
        </view>
      </view>
      <view class="med-right">
        <text class="med-time" wx:if="{{item.lastTakenTime}}">{{item.lastTakenTime}}</text>
        <view class="med-actions">
          <view class="med-cta {{item.doseCount > 0 ? 'again' : ''}}" wx:if="{{!item.completed}}" catchtap="quickTakeMedication" data-id="{{item.medicationId}}">{{item.doseCount > 0 ? '再记一次' : '打卡'}}</view>
          <view class="med-cta done-edit" wx:else>已完成</view>
          <view class="med-view" wx:if="{{item.doseCount > 0}}" catchtap="openMedPanel" data-id="{{item.medicationId}}">查看</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 用药管理引导（无药物配置时） -->
  <view class="card med-empty" wx:elif="{{!medicationsList.length}}">
    <view class="card-head"><text class="card-title">今日用药打卡</text></view>
    <view class="empty-hint">
      <text>还没有配置药物，先去添加用药方案</text>
      <view class="empty-btn" catchtap="goToMedicationManage">去配置 ›</view>
    </view>
  </view>

  <!-- 今日时间轴 -->
  <view class="card" wx:if="{{hasTimeline}}">
    <view class="card-head">
      <text class="card-title">今日时间轴</text>
      <text class="card-more" catchtap="goToDataRecords">全部 ›</text>
    </view>
    <scroll-view class="trend-tabs" scroll-x="true" enhanced="true" show-scrollbar="false">
      <text class="ttab {{timelineCategory === item.key ? 'on' : ''}}" wx:for="{{timelineTabs}}" wx:key="key" data-category="{{item.key}}" catchtap="switchTimelineCategory">{{item.label}}</text>
    </scroll-view>
    <scroll-view class="tl" scroll-y="true" enhanced="true" show-scrollbar="false" wx:if="{{timeline.length > 0}}">
      <view class="tl-entry" wx:for="{{timeline}}" wx:key="index">
        <view class="tl-item">
          <text class="tl-time">{{item.time}}</text>
          <view class="tl-line"><view class="tl-node {{item.type}}"></view></view>
          <view class="tl-body">
            <text class="tl-title">{{item.title}}</text>
            <text class="tl-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
          </view>
        </view>
        <view class="tl-gap-row" wx:if="{{item.gapText}}">
          <text class="tl-gap">{{item.gapText}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="tl-empty" wx:else>该分类今日暂无记录</view>
  </view>

  <!-- 近7天趋势 -->
  <view class="card">
    <view class="card-head">
      <text class="card-title">近7天趋势</text>
    </view>
    <scroll-view class="trend-tabs" scroll-x="true" enhanced="true" show-scrollbar="false">
      <text class="ttab {{trendMetric === item.key ? 'on' : ''}}" wx:for="{{trendMetrics}}" wx:key="key" data-metric="{{item.key}}" catchtap="switchTrendMetric">{{item.label}}</text>
    </scroll-view>
    <text class="trend-loading" wx:if="{{trendLoading}}">柠檬宝宝正在轻轻补齐近7天趋势～</text>
    <view class="trend">
      <view class="trend-bars">
        <view class="trend-col" wx:for="{{weeklyTrend.points}}" wx:key="date">
          <view class="trend-bar-wrap">
            <text class="trend-val" wx:if="{{item.hasValue}}">{{item.value}}</text>
            <view class="trend-bar {{item.isToday ? 'today' : ''}} {{item.hasValue ? '' : 'empty'}}" style="height: {{item.heightPct}}%;"></view>
          </view>
          <text class="trend-label {{item.isToday ? 'today' : ''}}">{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="trend-foot">
      <view class="tf-it" wx:for="{{trendStats}}" wx:key="l">
        <text class="tf-n">{{item.n}}<text class="tf-u">{{item.u}}</text></text>
        <text class="tf-c" wx:if="{{item.coefRow}}">{{item.c}}<text class="tf-cu" wx:if="{{item.c}}"> {{item.cu}}</text></text>
        <text class="tf-l">{{item.l}}</text>
      </view>
    </view>
  </view>

  <!-- 更多功能 -->
  <view class="card">
    <view class="card-head"><text class="card-title">更多</text></view>
    <view class="more-grid">
      <view class="me" data-url="/pkg-records/growth-records/index" bindtap="onNavigate" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">📈</view><text class="me-nm">成长曲线</text>
      </view>
      <view class="me" bindtap="goToReport" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">🧪</view><text class="me-nm">检测报告</text>
      </view>
      <view class="me" bindtap="navigateToMilkGoalPlanner" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">🥛</view><text class="me-nm">配奶规划</text>
      </view>
      <view class="me" data-url="/pkg-milk/nutrition-profile-settings/index" bindtap="onNavigate" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">⚙️</view><text class="me-nm">配奶管理</text>
      </view>
      <view class="me" data-url="/pkg-milk/food-management/index" bindtap="onNavigate" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">🍽️</view><text class="me-nm">食物库</text>
      </view>
      <view class="me" data-url="/pkg-misc/medications/index" bindtap="onNavigate" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">💊</view><text class="me-nm">用药管理</text>
      </view>
      <view class="me" data-url="/pkg-misc/emergency-support/index" bindtap="onNavigate" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">🆘</view><text class="me-nm">应急支持</text>
      </view>
      <view wx:if="{{isCreator}}" class="me" data-url="/pkg-misc/share-data/index" bindtap="onNavigate" hover-class="press-pop" hover-stay-time="60">
        <view class="me-ic">🔗</view><text class="me-nm">数据共享</text>
      </view>
    </view>
  </view>

  <view class="foot-tip">柠檬宝宝 · 每一次记录都在守护成长 🍋</view>

  <!-- 体重编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showWeightModal}}" catchtap="closeWeightModal">
    <view class="weight-modal" catchtap="stopBubble">
      <text class="wm-title">记录今日体重</text>
      <view class="wm-input-row">
        <input class="wm-input" type="digit" value="{{weightInput}}" placeholder="请输入体重" focus="{{showWeightModal}}" bindinput="onWeightModalInput" />
        <text class="wm-unit">kg</text>
      </view>
      <view class="wm-actions">
        <view class="wm-btn cancel" catchtap="closeWeightModal">取消</view>
        <view class="wm-btn confirm" catchtap="saveWeightModal">保存</view>
      </view>
    </view>
  </view>

  <!-- 身高编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showHeightModal}}" catchtap="closeHeightModal">
    <view class="weight-modal" catchtap="stopBubble">
      <text class="wm-title">记录今日身高</text>
      <view class="wm-input-row">
        <input class="wm-input" type="digit" value="{{heightInput}}" placeholder="请输入身高" focus="{{showHeightModal}}" bindinput="onHeightModalInput" />
        <text class="wm-unit">cm</text>
      </view>
      <view class="wm-actions">
        <view class="wm-btn cancel" catchtap="closeHeightModal">取消</view>
        <view class="wm-btn confirm" catchtap="saveHeightModal">保存</view>
      </view>
    </view>
  </view>

  <nutrition-target-settings-modal
    visible="{{targetSettingsModalVisible}}"
    mode="{{targetSettingsMode}}"
    bind:close="closeNutritionTargetSettings"
    bind:saved="handleNutritionTargetsSaved"
  />

  <!-- 记录用药弹窗 -->
  <medication-modal
    visible="{{modals.medication}}"
    title="记录用药"
    medications="{{medicationsList}}"
    selectedMedicationIndex="{{selectedMedicationIndex}}"
    selectedMedicationName="{{selectedMedicationInfo ? selectedMedicationInfo.name : ''}}"
    showMedicationPicker="{{true}}"
    dosage="{{currentModalDosage}}"
    unit="{{selectedMedicationInfo ? selectedMedicationInfo.unit : ''}}"
    time="{{currentModalTime}}"
    frequency="{{selectedMedicationInfo ? selectedMedicationInfo.frequency : ''}}"
    notes="{{currentModalNotes}}"
    confirmText="确认"
    bind:close="closeMedicationModal"
    bind:medicationchange="onMedicationPickerChange"
    bind:dosagechange="onMedicationDosageChange"
    bind:timechange="onMedicationTimeChange"
    bind:noteschange="onMedicationNotesChange"
    bind:confirm="recordMedication"
    bind:manage="goToMedicationManage"
  />

  <!-- 打卡撤销条（5 秒内可撤销） -->
  <view class="med-undo {{medUndo.visible ? 'show' : ''}}">
    <view class="med-undo-icon">✓</view>
    <view class="med-undo-text">
      <text class="med-undo-title">{{medUndo.name}} 已打卡</text>
      <text class="med-undo-sub" wx:if="{{medUndo.time}}">{{medUndo.time}}</text>
    </view>
    <view class="med-undo-btn" catchtap="undoMedCheckin">撤销</view>
  </view>

  <!-- 用药打卡面板：改时间/补记/删除任意一次 -->
  <view class="mp-mask {{medPanel.visible ? 'show' : ''}}" catchtap="closeMedPanel">
    <view class="mp-sheet {{medPanel.visible ? 'show' : ''}}" catchtap="stopBubble">
      <view class="mp-grip"></view>
      <view class="mp-head">
        <text class="mp-title">{{medPanel.name}}</text>
        <text class="mp-meta">{{medPanel.meta}} · 今日 {{medPanel.doseCount}}/{{medPanel.doseTotal}}</text>
      </view>

      <text class="mp-section">今日打卡记录</text>
      <view class="mp-empty" wx:if="{{medPanel.entries.length === 0}}">今天还没有打卡记录</view>
      <view class="mp-entry" wx:for="{{medPanel.entries}}" wx:key="recordId">
        <view class="mp-entry-time">🕒 {{item.time || '--:--'}}</view>
        <view class="mp-entry-ops">
          <picker mode="time" value="{{item.time}}" data-record-id="{{item.recordId}}" bindchange="onMedPanelEntryTimeChange">
            <view class="mp-entry-edit">修改</view>
          </picker>
          <view class="mp-entry-del" catchtap="deleteMedPanelEntry" data-record-id="{{item.recordId}}">删除</view>
        </view>
      </view>

      <view class="mp-close" catchtap="closeMedPanel">关闭</view>
    </view>
  </view>
</view>
