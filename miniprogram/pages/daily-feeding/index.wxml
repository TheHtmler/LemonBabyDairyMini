<view class="container">
  <!-- 点击空白处关闭菜单的覆盖层 -->
  <view class="menu-overlay" wx:if="{{activeFeedingMenu !== -1 || activeFoodMenu !== -1}}" bindtap="onTapPage"></view>

  <view class="release-notice-banner" wx:if="{{releaseNoticeVisible && releaseNoticeText}}">
    <view class="release-notice-fixed">
      <text class="release-notice-prefix">公告</text>
    </view>
    <view class="release-notice-marquee">
      <view class="release-notice-track">
        <text class="release-notice-copy">{{releaseNoticeText}}</text>
        <text class="release-notice-copy">{{releaseNoticeText}}</text>
      </view>
    </view>
  </view>

  <!-- Baby Info Section -->
  <view class="section baby-info-section" bindtap="navigateToBabyInfo">
    <view class="baby-card-head">
      <view class="baby-profile">
        <image class="baby-avatar" src="{{babyAvatarUrl || '/images/LemonLogo.png'}}" mode="aspectFill"></image>
        <view class="baby-profile-main">
          <view class="baby-name-row">
            <view class="baby-name">{{babyName}}</view>
            <view class="baby-gender-tag" wx:if="{{babyGender}}">{{babyGender === 'male' ? '男孩' : '女孩'}}</view>
          </view>
          <view class="baby-subline">
            <text class="baby-birthday" wx:if="{{babyBirthdayText}}">{{babyBirthdayText}}</text>
            <text class="baby-sub-separator" wx:if="{{babyBirthdayText && babyAgeMonthsText}}">·</text>
            <text class="baby-age-months" wx:if="{{babyAgeMonthsText}}">{{babyAgeMonthsText}}</text>
          </view>
        </view>
      </view>
      <view class="baby-info-entry">宝宝信息</view>
    </view>
    <view class="baby-card-foot">
      <view class="baby-days-badge">已出生 {{babyDays}} 天</view>
      <text class="baby-date">{{todayDate}}</text>
    </view>
  </view>

  <!-- Weight Section -->
  <view class="section weight-section">
    <view class="light-section-head">
      <text class="light-section-title">今日体重</text>
      <text class="light-section-meta">kg</text>
    </view>
    <view class="weight-bar-row">
      <input
        type="digit"
        class="weight-input compact"
        value="{{weight}}"
        placeholder="请输入体重"
        bindinput="onWeightInput"
      />
    </view>
  </view>

  <!-- 目标系数改为喂奶弹窗内填写 -->

  <!-- Current Feeding Section -->
  <view class="section feeding-section">
    <view class="light-section-head">
      <text class="light-section-title">快捷记录</text>
      <text class="light-section-meta">今日操作</text>
    </view>
    <view class="quick-actions quick-actions-compact">
      <view class="quick-record-btn primary" bindtap="showQuickInputModal">
        <text>添加喂奶</text>
      </view>
      <view class="quick-record-btn secondary" bindtap="navigateToMealEditor">
        <text>添加食物</text>
      </view>
      <view class="quick-record-btn neutral" bindtap="openMedicationModal">
        <text>记录用药</text>
      </view>
    </view>
  </view>

  <!-- Intake Summary Section -->
  <view class="section intake-section">
    <view class="section-header">
      <text class="section-title">今日摄入</text>
    </view>
    <view class="intake-summary">
      <view class="summary-item">
        <text class="label">总热量</text>
        <text class="value highlight">{{macroSummary.calories || 0}} kcal</text>
      </view>
      <view class="summary-item">
        <text class="label">热量系数</text>
        <text class="value">{{macroSummary.caloriesPerKg !== '' ? macroSummary.caloriesPerKg : '—'}} kcal/kg</text>
      </view>
      <view class="summary-item">
        <text class="label">天然蛋白</text>
        <text class="value">{{macroSummary.naturalProtein || 0}} g</text>
      </view>
      <view class="summary-item">
        <text class="label">特殊蛋白</text>
        <text class="value">{{macroSummary.specialProtein || 0}} g</text>
      </view>
      <view class="summary-item">
        <text class="label">天然蛋白系数</text>
        <text class="value">{{macroSummary.naturalCoefficient !== '' ? macroSummary.naturalCoefficient : '—'}} g/kg/d</text>
      </view>
      <view class="summary-item">
        <text class="label">特殊蛋白系数</text>
        <text class="value">{{macroSummary.specialCoefficient !== '' ? macroSummary.specialCoefficient : '—'}} g/kg/d</text>
      </view>
    </view>
    <view class="macro-ratio">
      <view class="macro-ratio-header">
        <view class="macro-ratio-title">供能占比</view>
      </view>
      <view class="macro-ratio-row">
        <view class="macro-ratio-row-main">
          <text class="macro-ratio-label">蛋白</text>
          <text class="macro-ratio-value">{{macroRatios.protein || 0}}%</text>
        </view>
        <text class="macro-ratio-row-hint">参考 10%-15%</text>
      </view>
      <view class="macro-ratio-row">
        <view class="macro-ratio-row-main">
          <text class="macro-ratio-label">碳水</text>
          <text class="macro-ratio-value">{{macroRatios.carbs || 0}}%</text>
        </view>
        <text class="macro-ratio-row-hint">参考 55%-60%</text>
      </view>
      <view class="macro-ratio-row">
        <view class="macro-ratio-row-main">
          <view class="macro-ratio-label-group">
            <text class="macro-ratio-label">脂肪</text>
            <text class="ratio-info-icon" bindtap="showFatRatioPopup">i</text>
          </view>
          <text class="macro-ratio-value">{{macroRatios.fat || 0}}%</text>
        </view>
        <text class="macro-ratio-row-hint">参考 {{fatRatioRangeText || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- Records Section -->
  <view class="section records-section">
    <text class="section-title">今日数据汇总</text>
    
    <!-- 摄入来源概览 -->
    <view class="records-summary">
      <view class="summary-card milk-card">
        <view class="card-header">
          <text class="card-title">喂奶</text>
          <text class="card-meta">热量 {{intakeOverview.milk.totalCalories || 0}} kcal</text>
        </view>
        <view class="card-body milk-body">
          <view class="milk-column">
            <text class="column-title">天然</text>
            <view class="stat-row">
              <text>体积</text>
              <text>{{intakeOverview.milk.normal.volume || 0}} ml</text>
            </view>
            <view class="stat-row">
              <text>蛋白</text>
              <text>{{intakeOverview.milk.normal.protein || 0}} g</text>
            </view>
            <view class="stat-row">
              <text>蛋白系数</text>
              <text>{{intakeOverview.milk.normal.coefficient !== '' ? intakeOverview.milk.normal.coefficient : '—'}} g/kg/d</text>
            </view>
            <view class="stat-row">
              <text>热量</text>
              <text>{{intakeOverview.milk.normal.calories || 0}} kcal</text>
            </view>
            <view class="stat-row">
              <text>碳水</text>
              <text>{{intakeOverview.milk.normal.carbs || 0}} g</text>
            </view>
            <view class="stat-row">
              <text>脂肪</text>
              <text>{{intakeOverview.milk.normal.fat || 0}} g</text>
            </view>
          </view>
          <view class="milk-column">
            <text class="column-title">特奶</text>
            <view class="stat-row">
              <text>体积</text>
              <text>{{intakeOverview.milk.special.volume || 0}} ml</text>
            </view>
            <view class="stat-row">
              <text>蛋白</text>
              <text>{{intakeOverview.milk.special.protein || 0}} g</text>
            </view>
            <view class="stat-row">
              <text>蛋白系数</text>
              <text>{{intakeOverview.milk.special.coefficient !== '' ? intakeOverview.milk.special.coefficient : '—'}} g/kg/d</text>
            </view>
            <view class="stat-row">
              <text>热量</text>
              <text>{{intakeOverview.milk.special.calories || 0}} kcal</text>
            </view>
            <view class="stat-row">
              <text>碳水</text>
              <text>{{intakeOverview.milk.special.carbs || 0}} g</text>
            </view>
            <view class="stat-row">
              <text>脂肪</text>
              <text>{{intakeOverview.milk.special.fat || 0}} g</text>
            </view>
          </view>
        </view>
      </view>

      <view class="summary-card food-card">
        <view class="card-header">
          <text class="card-title">食物</text>
          <text class="card-meta">热量 {{intakeOverview.food.totalCalories || 0}} kcal</text>
        </view>
        <view class="card-body food-body">
          <view class="body-summary">
            <text>蛋白 {{intakeOverview.food.protein || 0}} g</text>
            <text>蛋白系数 {{intakeOverview.food.coefficient !== '' ? intakeOverview.food.coefficient : '—'}} g/kg/d</text>
            <text>碳水 {{intakeOverview.food.carbs || 0}} g · 脂肪 {{intakeOverview.food.fat || 0}} g</text>
          </view>
          <view class="empty-record" wx:if="{{foodIntakes.length === 0}}">
            <text>暂无食物摄入记录</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 选项卡标题 -->
    <view class="tabs">
      <view class="tab {{activeTab === 'feeding' ? 'active' : ''}}" bindtap="switchTab" data-tab="feeding">
        <text>喂奶记录</text>
      </view>
      <view class="tab {{activeTab === 'food' ? 'active' : ''}}" bindtap="switchTab" data-tab="food">
        <text>食物记录</text>
      </view>
      <view class="tab {{activeTab === 'medication' ? 'active' : ''}}" bindtap="switchTab" data-tab="medication">
        <text>用药记录</text>
      </view>
    </view>
    
    <!-- 喂养记录 -->
    <view class="tab-content" hidden="{{activeTab !== 'feeding'}}">
      <view class="records-list">
        <feeding-record-card
          wx:for="{{feedingsDisplay}}"
          wx:key="index"
          record="{{item}}"
          index="{{index}}"
          showLabel="{{false}}"
          bind:recordtap="openEditModal"
          bind:edit="openEditModal"
          bind:delete="deleteFeeding"
        />
        <view class="empty-record" wx:if="{{feedingsDisplay.length === 0}}">
          <text>暂无喂养记录</text>
        </view>
      </view>
    </view>

    <!-- 食物记录 -->
    <view class="tab-content" hidden="{{activeTab !== 'food'}}">
      <view class="records-list">
        <view class="meal-group-card" wx:for="{{foodMealGroups}}" wx:key="id">
          <view class="meal-group-header" bindtap="toggleFoodMealGroup" data-id="{{item.id}}">
            <view class="meal-group-top">
              <view class="meal-group-main">
                <text class="meal-group-title">{{item.mealLabel || '食物记录'}}</text>
                <text class="meal-group-meta inline">{{item.mealTime || '--:--'}} · {{item.itemCount}}种食物</text>
              </view>
              <view class="meal-group-actions">
                <text class="meal-group-edit" catchtap="navigateToMealGroupEditor" data-meal-batch-id="{{item.mealBatchId}}">编辑本顿</text>
                <text class="meal-group-toggle">{{item.expanded ? '收起' : '展开'}}</text>
              </view>
            </view>
            <view class="meal-group-summary-grid">
              <view class="meal-group-summary-item">
                <text class="meal-group-summary-label">热量：</text>
                <text class="meal-group-summary-value">{{item.summary.calories}} kcal</text>
              </view>
              <view class="meal-group-summary-item">
                <text class="meal-group-summary-label">蛋白：</text>
                <text class="meal-group-summary-value">{{item.summary.protein}} g</text>
              </view>
              <view class="meal-group-summary-item">
                <text class="meal-group-summary-label">碳水：</text>
                <text class="meal-group-summary-value">{{item.summary.carbs}} g</text>
              </view>
              <view class="meal-group-summary-item">
                <text class="meal-group-summary-label">脂肪：</text>
                <text class="meal-group-summary-value">{{item.summary.fat}} g</text>
              </view>
            </view>
          </view>
          <view class="meal-group-note" wx:if="{{item.expanded && item.mealNote}}">
            <text>{{item.mealNote}}</text>
          </view>
          <view class="meal-group-items" wx:if="{{item.expanded}}">
            <view class="food-record-item" wx:for="{{item.items}}" wx:key="_id" wx:for-item="foodItem">
              <view class="record-content">
                <food-record-item record="{{foodItem}}" />
              </view>
            </view>
          </view>
        </view>
        <view class="food-record-item" wx:for="{{legacyFoodIntakes}}" wx:key="_id">
          <view class="record-content">
            <food-record-item record="{{item}}" />
          </view>
          <view class="action-buttons">
            <view class="action-btn edit-btn" bindtap="openEditFoodModal" data-index="{{item.originalIndex}}" data-id="{{item._id}}">
              <image class="action-icon" src="/images/icons/edit.svg" mode="aspectFit"></image>
            </view>
            <view class="action-btn delete-btn" bindtap="deleteFoodIntake" data-index="{{item.originalIndex}}" data-id="{{item._id}}">
              <image class="action-icon" src="/images/icons/delete.svg" mode="aspectFit"></image>
            </view>
          </view>
        </view>
        <view class="empty-record" wx:if="{{foodMealGroups.length === 0 && legacyFoodIntakes.length === 0}}">
          <text>暂无食物摄入记录</text>
        </view>
      </view>
    </view>

    <!-- 药物记录 -->
    <view class="tab-content" hidden="{{activeTab !== 'medication'}}">
      <view class="medication-records">
          <view class="medication-group-records">
          <view class="medication-record-item" wx:for="{{medicationRecords}}" wx:key="_id" wx:for-item="record">
            <view class="record-content" data-index="{{record.originalIndex}}">
              <medication-record-item record="{{record}}" />
            </view>
            <!-- 操作按钮 -->
            <view class="action-buttons">
              <view class="action-btn edit-btn" bindtap="openMedicationRecordModal" data-medication-id="{{record._id}}" data-action="view">
                <image class="action-icon" src="/images/icons/edit.svg" mode="aspectFit"></image>
              </view>
              <view class="action-btn delete-btn" bindtap="deleteMedication" data-medication-id="{{record._id}}" data-action="delete">
                <image class="action-icon" src="/images/icons/delete.svg" mode="aspectFit"></image>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-record" wx:if="{{medicationRecords.length === 0}}">
          <text>暂无用药记录</text>
        </view>
      </view>
    </view>
  </view>

  <fat-ratio-popup
    visible="{{showFatRatioPopup}}"
    lines="{{fatRatioPopupLines}}"
    bind:close="hideFatRatioPopup"
  />

  <medication-modal
    visible="{{modals.medication}}"
    title="记录用药"
    medications="{{medicationsList}}"
    selectedMedicationIndex="{{selectedMedicationIndex}}"
    selectedMedicationName="{{selectedMedicationInfo ? selectedMedicationInfo.name : ''}}"
    showMedicationPicker="{{true}}"
    dosage="{{currentModalDosage}}"
    unit="{{selectedMedicationInfo ? selectedMedicationInfo.unit : ''}}"
    time="{{currentModalTime}}"
    frequency="{{selectedMedicationInfo ? selectedMedicationInfo.frequency : ''}}"
    notes="{{currentModalNotes}}"
    confirmText="确认"
    bind:close="closeMedicationModal"
    bind:medicationchange="onMedicationPickerChange"
    bind:dosagechange="onMedicationDosageChange"
    bind:timechange="onMedicationTimeChange"
    bind:noteschange="onMedicationNotesChange"
    bind:confirm="recordMedication"
    bind:manage="goToMedicationManage"
  />
  
  <!-- 编辑记录弹窗 -->
  <feeding-modal
    visible="{{modals.edit}}"
    title="编辑喂奶记录"
    feedingData="{{editingFeedingDisplay}}"
    showGoalHint="{{false}}"
    confirmText="保存"
    bind:close="closeEditModal"
    bind:confirm="saveEditedFeeding"
    bind:timechange="handleEditModalTimeChange"
    bind:inputchange="handleEditModalInputChange"
    bind:adjust="handleEditModalAdjust"
    bind:typechange="handleEditModalTypeChange"
  />
  
  <medication-modal
    visible="{{modals.medicationRecord}}"
    title="药物记录详情"
    selectedMedicationName="{{selectedMedicationRecord.medicationName}}"
    showMedicationPicker="{{false}}"
    dosage="{{selectedMedicationRecord.dosage}}"
    unit="{{selectedMedicationRecord.unit}}"
    time="{{selectedMedicationRecord.actualTime}}"
    frequency="{{selectedMedicationRecord.frequency}}"
    notes="{{selectedMedicationRecord.notes}}"
    confirmText="保存"
    bind:close="closeMedicationRecordModal"
    bind:dosagechange="onMedicationRecordDosageChange"
    bind:timechange="onMedicationRecordTimeChange"
    bind:noteschange="onMedicationRecordNotesChange"
    bind:confirm="saveMedicationRecordChanges"
    bind:manage="goToMedicationManage"
  />
  
  <!-- 快捷记录弹窗 -->
  <feeding-modal
    visible="{{modals.quickInput}}"
    title="添加喂奶记录"
    feedingData="{{quickFeedingData}}"
    showGoalHint="{{true}}"
    quickGoalTarget="{{quickGoalTarget}}"
    quickGoalSuggestion="{{quickGoalSuggestion}}"
    naturalProteinCoefficientInput="{{naturalProteinCoefficientInput}}"
    specialProteinCoefficientInput="{{specialProteinCoefficientInput}}"
    calorieCoefficientInput="{{calorieCoefficientInput}}"
    bind:close="hideQuickInputModal"
    bind:confirm="saveQuickFeeding"
    bind:timechange="handleQuickModalTimeChange"
    bind:inputchange="handleQuickModalInputChange"
    bind:adjust="handleQuickModalAdjust"
    bind:typechange="handleQuickModalTypeChange"
    bind:goaltarget="handleQuickModalGoalTargetChange"
    bind:coefficient="handleQuickModalCoefficientChange"
  />

  <!-- 食物摄入弹窗 -->
  <view class="modal feeding-modal" wx:if="{{modals.foodIntake}}" bindtap="hideFoodIntakeModal" catchtouchmove="preventBubble">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text>添加食物记录</text>
      </view>
      <scroll-view class="modal-body modal-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view class="content-box">
          <view class="input-group">
          <text class="label">食物</text>
          <view class="food-selection-card">
            <view class="food-list-header">
              <view class="food-header-title">请选择食物</view>
              <view class="food-add-btn" bindtap="openFoodManage">
                <text class="food-add-icon">＋</text>
                <text>添加食物</text>
              </view>
            </view>
            <view class="food-search-input">
              <text class="search-icon">🔍</text>
              <input type="text" value="{{foodSearchQuery}}" placeholder="搜索食物名称或类别" confirm-type="search" bindinput="onFoodSearchInput" />
            </view>
            <scroll-view class="food-option-list" scroll-y="true">
                <view class="food-option {{newFoodIntake.foodId === item._id ? 'selected' : ''}}"
                      wx:for="{{filteredFoodOptions}}" wx:key="_id"
                      data-id="{{item._id}}" bindtap="onFoodOptionTap">
                  <view class="food-option-main">
                    <text class="food-option-name">{{item.name}}</text>
                    <text class="food-option-tag">{{item.category || '未分类'}}</text>
                  </view>
                  <text class="food-option-sub" wx:if="{{item.aliasText}}">{{item.aliasText}}</text>
                </view>
                <view class="food-option-empty" wx:if="{{filteredFoodOptions.length === 0}}">
                  <text>未找到匹配的食物，请调整搜索条件</text>
                </view>
              </scroll-view>
            </view>
          </view>
          <view class="input-group">
            <text class="label">重量 ({{newFoodIntake.unit || 'g'}})</text>
            <input type="digit" value="{{newFoodIntake.quantity}}" bindinput="onFoodQuantityInput" placeholder="请输入重量" />
          </view>
          <view class="input-group">
            <text class="label">时间</text>
            <picker mode="time" value="{{newFoodIntake.recordTime}}" bindchange="onFoodRecordTimeChange">
              <view class="picker-value">{{newFoodIntake.recordTime || '选择时间'}}</view>
            </picker>
          </view>
          <view class="input-group">
            <text class="label">备注</text>
            <textarea class="notes-input" placeholder="可选，记录特殊说明"
                      value="{{newFoodIntake.notes}}" bindinput="onFoodNotesInput"></textarea>
          </view>
          <view class="nutrition-preview" wx:if="{{newFoodIntake.nutritionPreview}}">
            <view class="preview-row">
              <text>热量</text>
              <text>{{newFoodIntake.nutritionPreview.calories}} kcal</text>
            </view>
            <view class="preview-row">
              <text>蛋白</text>
              <text>{{newFoodIntake.nutritionPreview.protein}} g</text>
            </view>
            <view class="preview-row">
              <text>碳水</text>
              <text>{{newFoodIntake.nutritionPreview.carbs}} g</text>
            </view>
            <view class="preview-row">
              <text>脂肪</text>
              <text>{{newFoodIntake.nutritionPreview.fat}} g</text>
            </view>
            <view class="preview-row">
              <text>膳纤</text>
              <text>{{newFoodIntake.nutritionPreview.fiber}} g</text>
            </view>
            <view class="preview-row">
              <text>钠</text>
              <text>{{newFoodIntake.nutritionPreview.sodium}} mg</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideFoodIntakeModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveFoodIntake">保存</button>
      </view>
    </view>
  </view>

  <!-- 食物摄入实验弹窗 -->
  <food-intake-modal
    visible="{{modals.foodIntakeExperiment}}"
    step="{{foodExperimentStep}}"
    searchQuery="{{foodExperimentSearchQuery}}"
    categories="{{foodExperimentCategories}}"
    activeCategory="{{foodExperimentCategory}}"
    options="{{filteredFoodExperimentOptions}}"
    selectedFoodId="{{foodExperiment.foodId}}"
    foodExperiment="{{foodExperiment}}"
    confirmDisabled="{{!foodExperiment.foodId}}"
    formCancelText="{{foodModalMode === 'edit' ? '取消' : '上一步'}}"
    bind:close="hideFoodIntakeExperimentModal"
    bind:openmanage="openFoodManage"
    bind:searchinput="onFoodExperimentSearchInput"
    bind:categorytap="onFoodExperimentCategoryTap"
    bind:optiontap="onFoodExperimentOptionTap"
    bind:confirmselect="confirmFoodExperimentSelection"
    bind:backtoselect="backToFoodExperimentSelection"
    bind:quantityinput="onFoodExperimentQuantityInput"
    bind:notesinput="onFoodExperimentNotesInput"
    bind:timechange="onFoodExperimentRecordTimeChange"
    bind:formcancel="handleFoodExperimentFormCancel"
    bind:formsave="saveFoodIntakeExperiment"
  />

  <!-- 排便记录弹窗 -->
  <view class="modal bowel-record-modal" wx:if="{{modals.bowelRecord}}" bindtap="hideBowelRecordModal" catchtouchmove="preventBubble">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text>记录排便</text>
      </view>
      <scroll-view class="modal-body" scroll-y="true" enhanced="true" show-scrollbar="false">
        <!-- 时间选择 -->
        <view class="modal-info-row">
          <text class="modal-label">时间:</text>
          <picker mode="time" value="{{newBowelRecord.time}}" start="00:00" end="23:59" bindchange="onBowelTimeChange">
            <view class="modal-time-picker">{{newBowelRecord.time}} <text class="edit-icon">✎</text></view>
          </picker>
        </view>
        
        <!-- 类型选择 -->
        <view class="modal-info-row">
