/* pages/add-report/index.wxss */

.container {
  display: block;
  width: 100%;
  min-height: 100vh;
  align-items: stretch;
  padding: 0;
  background: #f6f8fb;
  box-sizing: border-box;
}

.content {
  width: 100%;
  padding: 20rpx 20rpx 240rpx;
  box-sizing: border-box;
}

.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 420rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #d9dee7;
  border-top: 4rpx solid #2f6fed;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #76839a;
}

.report-meta-bar {
  display: block;
  margin-bottom: 24rpx;
}

.meta-card {
  background: #ffffff;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #7b8798;
  margin-bottom: 12rpx;
}

.meta-value {
  display: block;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #1f2d3d;
}

.meta-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7b8798;
}

.meta-picker {
  display: block;
}

.meta-picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 54rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.report-type-section,
.indicator-list {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.type-scroll {
  width: 100%;
  white-space: nowrap;
  box-sizing: border-box;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-right: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #dde4ee;
  color: #516072;
}

.type-chip.active {
  background: #2f6fed;
  border-color: #2f6fed;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(47, 111, 237, 0.24);
}

.type-chip-icon {
  font-size: 24rpx;
}

.type-chip-name {
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.indicator-list {
  display: flex;
  flex-direction: column;
  width: 100%;
  background: #ffffff;
  border-radius: 18rpx;
  border: 1rpx solid #e6ebf2;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(31, 45, 61, 0.04);
}

.indicator-row {
  padding: 16rpx 20rpx 18rpx;
  border-top: 1rpx solid #eef2f7;
}

.indicator-row:first-child {
  border-top: none;
}

.indicator-row-top {
  margin-bottom: 14rpx;
}

.indicator-meta {
  width: 100%;
}

.indicator-title {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.indicator-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.indicator-abbr {
  font-size: 22rpx;
  color: #7b8798;
}

.required-mark {
  font-size: 28rpx;
  color: #e5484d;
  font-weight: 700;
}

.compact-input-grid {
  display: grid;
  grid-template-columns: 2.1fr 1fr 1fr;
  gap: 8rpx;
}

.compact-input-grid.value-only {
  grid-template-columns: minmax(0, 1fr);
}

.compact-cell {
  min-width: 0;
  width: 100%;
}

.compact-cell.value-cell {
  width: 100%;
}

.compact-label {
  display: block;
  margin-bottom: 6rpx;
  font-size: 18rpx;
  color: #8a95a5;
}

.compact-input {
  width: 100%;
  height: 68rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  border: 1rpx solid #dbe3ee;
  background: #f9fbfd;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f2d3d;
}

.optimal-range {
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #eff5ff;
}

.optimal-label {
  font-size: 22rpx;
  color: #5376b4;
  margin-right: 8rpx;
}

.optimal-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #2f6fed;
}

.bottom-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 20rpx calc(env(safe-area-inset-bottom) + 14rpx);
  background: #ffffff;
  border-top: 1rpx solid #e6ebf2;
  box-sizing: border-box;
  z-index: 20;
  box-shadow: 0 -8rpx 24rpx rgba(31, 45, 61, 0.06);
}

.disclaimer {
  margin-bottom: 10rpx;
}

.disclaimer-text {
  display: block;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a95a5;
  text-align: center;
}

.save-section {
  display: flex;
  width: 100%;
}

.save-button {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 18rpx;
  background: #2f6fed;
  box-shadow: 0 8rpx 18rpx rgba(47, 111, 237, 0.26);
}

.save-button[disabled] {
  background: #b7c3d6;
  box-shadow: none;
}

.save-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}
